<%# ============================================================ %>
<%# Formulaire de création d'une nouvelle histoire %>
<%# story-creation controller gère : validation, feedback bouton, insertions d'idées %>
<%# ============================================================ %>

<%# data-action="change" : écoute les radio/checkbox en bubbling %>
<%# data-action="submit" : valide avant d'envoyer le formulaire %>
<div class="container py-4"
     data-controller="story-creation"
     data-action="change->story-creation#onRadioChange submit->story-creation#validateForm">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <%# En-tête %>
      <div class="mb-4">
        <p class="text-muted text-uppercase letter-spacing mb-1">✨ Nouvelle histoire</p>
        <h1 class="fw-bold display-6">Crée ton histoire magique</h1>
      </div>

      <%= simple_form_for @story, url: stories_path do |f| %>
        <%= f.error_notification %>

        <%# ================================================ %>
        <%# ÉTAPE 1 — Choix des héros %>
        <%# ================================================ %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-1">👤 Qui sont les héros ?</h2>
            <p class="text-muted small mb-3">Tu peux sélectionner plusieurs enfants.</p>

            <% if @children.any? %>
              <div class="row g-2">
                <% @children.each do |child| %>
                  <div class="col-sm-6">
                    <%# data-action="change" déclenche onCheckboxChange pour la validation en temps réel %>
                    <label class="child-selector w-100 p-3 rounded-3 border d-flex align-items-center gap-3"
                           style="cursor: pointer;">
                      <input type="checkbox"
                             name="story[child_ids][]"
                             value="<%= child.id %>"
                             class="form-check-input me-1"
                             data-action="change->story-creation#onCheckboxChange">
                      <div>
                        <div class="fw-semibold"><%= child.name %></div>
                        <small class="text-muted"><%= child.age %> ans • <%= child.gender == "boy" ? "Garçon" : "Fille" %></small>
                      </div>
                    </label>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%# Message d'erreur — caché par défaut, affiché si soumission sans enfant %>
            <p class="text-danger small mt-2 d-none" data-story-creation-target="childError">
              ⚠️ Sélectionne au moins un enfant pour créer l'histoire.
            </p>

            <div class="mt-2">
              <%= link_to "+ Nouveau profil", new_child_path, class: "btn btn-sm btn-outline-secondary" %>
            </div>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 2 — Description libre de l'aventure %>
        <%# ================================================ %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-1">💬 Qu'est-ce qu'il/elle veut vivre aujourd'hui ?</h2>
            <p class="text-muted small mb-3">
              Décris librement l'aventure — un rêve, un endroit magique, un super-pouvoir...
            </p>

            <%= f.text_area :custom_theme,
                  rows: 4,
                  class: "form-control",
                  placeholder: "Ex : Elle veut être une exploratrice qui découvre une île secrète avec des animaux parlants..." %>

            <%# Idées cliquables — s'ajoutent au texte existant sans l'écraser %>
            <div class="mt-2 d-flex flex-wrap gap-2">
              <span class="text-muted small me-1 align-self-center">Inspiration :</span>
              <% [
                "🚀 Astronaute qui découvre une planète habitée par des robots gentils",
                "🦄 Princesse qui part à l'aventure avec sa licorne magique",
                "🦕 Voyage dans le temps chez les dinosaures",
                "🏴‍☠️ Pirate qui cherche un trésor caché sous la mer",
                "🌳 Gardien de la forêt qui sauve les animaux"
              ].each do |idea| %>
                <%# data-action="click" → insertIdea() qui ajoute sans écraser %>
                <%# data-idea stocke le texte pour éviter les problèmes de quotes %>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        data-action="click->story-creation#insertIdea"
                        data-idea="<%= idea %>">
                  <%= idea %>
                </button>
              <% end %>
            </div>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 3 — Paramètres de l'histoire %>
        <%# ================================================ %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <h2 class="h5 fw-bold mb-4">⚙️ Paramètres de l'histoire</h2>

            <%# Valeur éducative — courage sélectionné par défaut %>
            <div class="mb-4">
              <label class="form-label fw-semibold">💫 Valeur à transmettre</label>
              <div class="d-flex flex-wrap gap-2">
                <% [
                  { value: "courage",    label: "💪 Courage",    default: true  },
                  { value: "sharing",    label: "🤝 Partage",    default: false },
                  { value: "kindness",   label: "❤️ Gentillesse", default: false },
                  { value: "confidence", label: "⭐ Confiance",   default: false }
                ].each do |val| %>
                  <%# checked: true sur le premier → visuellement actif dès le chargement %>
                  <label class="badge-selector btn btn-sm btn-outline-primary <%= 'selected' if @story.educational_value == val[:value] %>">
                    <%= f.radio_button :educational_value, val[:value], class: "d-none" %>
                    <%= val[:label] %>
                  </label>
                <% end %>
              </div>
            </div>

            <%# Durée — cartes visuelles au lieu de simples radio buttons %>
            <div class="mb-4">
              <label class="form-label fw-semibold">⏱️ Durée de l'histoire</label>
              <div class="d-flex gap-3 flex-wrap">
                <% [
                  { mins: 5,  icon: "⚡", label: "5 min",  sub: "Court"  },
                  { mins: 10, icon: "📖", label: "10 min", sub: "Moyen"  },
                  { mins: 15, icon: "🌟", label: "15 min", sub: "Long"   }
                ].each do |d| %>
                  <label class="duration-selector <%= 'selected' if @story.duration_minutes == d[:mins] %>">
                    <%= f.radio_button :duration_minutes, d[:mins], class: "d-none", checked: d[:mins] == 5 %>
                    <span class="duration-icon"><%= d[:icon] %></span>
                    <span class="duration-label"><%= d[:label] %></span>
                    <span class="duration-sub"><%= d[:sub] %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <%# Mode interactif (Premium uniquement) %>
            <div class="mb-2">
              <div class="form-check form-switch">
                <% if current_user.premium? %>
                  <%= f.check_box :interactive, class: "form-check-input", id: "interactive-toggle" %>
                  <label class="form-check-label fw-semibold" for="interactive-toggle">
                    🎮 Activer le mode interactif
                    <small class="text-muted d-block">L'enfant fait des choix qui changent l'histoire</small>
                  </label>
                <% else %>
                  <input class="form-check-input" type="checkbox" disabled>
                  <label class="form-check-label text-muted">
                    🎮 Mode interactif
                    <span class="badge bg-warning text-dark ms-2">Premium</span>
                    <small class="d-block">
                      <%= link_to "Passer en Premium", subscription_path %> pour débloquer les histoires interactives
                    </small>
                  </label>
                <% end %>
              </div>
            </div>

          </div>
        </div>

        <%# Bouton de génération avec feedback visuel %>
        <%# data-story-creation-target="submitBtn" : le controller le désactive et change son texte %>
        <div class="d-grid">
          <%= f.submit "✨ Générer l'histoire magique",
                class: "btn btn-primary btn-lg py-3",
                data: { "story-creation-target": "submitBtn" } %>
        </div>

      <% end %>

    </div>
  </div>
</div>
