<%# ============================================================ %>
<%# Formulaire de création d'une nouvelle histoire %>
<%# DA cosmique : cartes dark, accents dorés, Cormorant Garamond %>
<%# story-creation controller gère : validation, feedback bouton, insertions d'idées %>
<%# ============================================================ %>

<%# Styles inline — DA cosmique pour le formulaire de création %>
<style nonce="<%= content_security_policy_nonce %>">
  /* ── Wrapper de page ── */
  .new-story-page { padding: 2.5rem 0 4rem; }

  /* ── En-tête ── */
  .new-story-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #f0c97a;
    margin-bottom: 0.5rem;
  }
  /* Titre Cormorant Garamond italic */
  .new-story-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 300;
    color: #fdf6e3;
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  /* ── Section (carte dark) — chaque étape du formulaire ── */
  .new-story-section {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }
  /* Titre de section en Cormorant italic */
  .new-story-section-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: #fdf6e3;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  /* Sous-texte de section */
  .new-story-section-hint {
    color: #8a8578;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }

  /* ── Inputs / Textarea — fond sombre, bordure dorée ── */
  .new-story-textarea,
  .new-story-input {
    display: block;
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(240, 201, 122, 0.2);
    border-radius: 10px;
    color: #d4cfc4;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    padding: 0.7rem 1rem;
    transition: border-color 0.2s ease;
    resize: vertical;
  }
  .new-story-textarea::placeholder,
  .new-story-input::placeholder { color: rgba(138, 133, 120, 0.6); }
  .new-story-textarea:focus,
  .new-story-input:focus {
    outline: none;
    border-color: #f0c97a;
    background: rgba(240, 201, 122, 0.03);
    box-shadow: 0 0 0 3px rgba(240, 201, 122, 0.08);
  }

  /* ── Sélecteur d'enfant (child-selector) — pill sombre, selected = bordure dorée ── */
  /* :has(input:checked) détecte si la checkbox cachée est cochée */
  .child-selector {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
    color: #d4cfc4;
  }
  /* État sélectionné : bordure dorée + fond mist */
  .child-selector:has(input:checked) {
    border-color: rgba(240, 201, 122, 0.5);
    background: rgba(240, 201, 122, 0.08);
  }
  .child-selector:hover { border-color: rgba(240, 201, 122, 0.3); }
  /* Nom de l'enfant en crème */
  .child-selector .child-name { font-weight: 600; color: #fdf6e3; font-size: 0.92rem; }
  /* Méta (âge, genre) en text-dim */
  .child-selector .child-meta { color: #8a8578; font-size: 0.8rem; }

  /* ── Boutons idées cliquables — pills transparents ── */
  .idea-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.8rem;
    background: transparent;
    border: 1px solid rgba(240, 201, 122, 0.2);
    border-radius: 50px;
    color: #8a8578;
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .idea-pill:hover {
    background: rgba(240, 201, 122, 0.08);
    color: #f0c97a;
    border-color: rgba(240, 201, 122, 0.4);
  }

  /* ── Label section — petit, uppercase, text-dim ── */
  .new-story-label {
    display: block;
    color: #8a8578;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  /* ── Badge-selector (valeur éducative) — pills ── */
  /* Classe "selected" ajoutée par story-creation#onRadioChange */
  .badge-selector {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: transparent;
    border: 1px solid rgba(240, 201, 122, 0.2);
    border-radius: 50px;
    color: #8a8578;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .badge-selector input { display: none; }
  /* Sélectionné : fond doré, texte sombre */
  .badge-selector:has(input:checked),
  .badge-selector.selected {
    background: #f0c97a;
    color: #0b0e1a;
    border-color: #f0c97a;
    font-weight: 600;
  }
  .badge-selector:hover:not(:has(input:checked)):not(.selected) {
    border-color: rgba(240, 201, 122, 0.4);
    color: #d4cfc4;
    background: rgba(240, 201, 122, 0.06);
  }

  /* ── Sélecteur de durée — cartes visuelles ── */
  .duration-selector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 12px;
    cursor: pointer;
    min-width: 90px;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.1s ease;
  }
  .duration-selector input { display: none; }
  /* Sélectionné : bordure dorée + fond mist + légère élévation */
  .duration-selector:has(input:checked),
  .duration-selector.selected {
    border-color: rgba(240, 201, 122, 0.55);
    background: rgba(240, 201, 122, 0.08);
    transform: scale(1.04);
  }
  .duration-selector:hover { border-color: rgba(240, 201, 122, 0.3); }
  /* Emoji grande taille */
  .duration-icon { font-size: 1.6rem; line-height: 1; }
  /* Label principal */
  .duration-label { font-size: 0.92rem; font-weight: 600; color: #d4cfc4; margin-top: 4px; }
  /* Sous-label discret */
  .duration-sub { font-size: 0.72rem; color: #8a8578; }

  /* ── Toggle mode interactif — form-switch adapté ── */
  .new-story-toggle-label { color: #d4cfc4; font-weight: 500; }
  .new-story-toggle-hint { color: #8a8578; font-size: 0.82rem; }
  /* Badge "Premium" dans le toggle désactivé */
  .new-story-premium-badge {
    display: inline-flex;
    padding: 0.15rem 0.6rem;
    background: rgba(240, 201, 122, 0.15);
    color: #f0c97a;
    border: 1px solid rgba(240, 201, 122, 0.3);
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
    margin-left: 0.4rem;
  }
  /* Lien "passer en premium" dans le mode interactif désactivé */
  .new-story-upgrade-link { color: rgba(240, 201, 122, 0.7); }
  .new-story-upgrade-link:hover { color: #f0c97a; }

  /* Override form-check-input pour le toggle cosmique */
  .new-story-section .form-check-input:checked {
    background-color: #f0c97a;
    border-color: #f0c97a;
  }
  .new-story-section .form-check-input:focus {
    box-shadow: 0 0 0 3px rgba(240, 201, 122, 0.15);
    border-color: rgba(240, 201, 122, 0.5);
  }

  /* ── Message d'erreur enfant manquant ── */
  .new-story-child-error { color: rgba(220, 100, 100, 0.9); font-size: 0.85rem; }

  /* ── Bouton lien secondaire — outline doré pill ── */
  .new-story-link-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.9rem;
    background: transparent;
    border: 1px solid rgba(240, 201, 122, 0.25);
    border-radius: 50px;
    color: rgba(240, 201, 122, 0.7);
    font-size: 0.82rem;
    text-decoration: none;
    transition: all 0.15s ease;
  }
  .new-story-link-secondary:hover {
    border-color: rgba(240, 201, 122, 0.5);
    color: #f0c97a;
    background: rgba(240, 201, 122, 0.06);
    text-decoration: none;
  }

  /* ── Bouton submit principal ── */
  .new-story-submit {
    display: block;
    width: 100%;
    padding: 0.9rem;
    background: #f0c97a;
    color: #0b0e1a;
    border: none;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.1s ease;
  }
  .new-story-submit:hover { opacity: 0.88; transform: translateY(-1px); }
  .new-story-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
</style>

<%# data-action="change" : écoute les radio/checkbox en bubbling %>
<%# data-action="submit" : valide avant d'envoyer le formulaire %>
<div class="container new-story-page"
     data-controller="story-creation"
     data-action="change->story-creation#onRadioChange submit->story-creation#validateForm">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <%# En-tête %>
      <p class="new-story-eyebrow">✦ Nouvelle histoire</p>
      <h1 class="new-story-title">Crée ton histoire magique</h1>

      <%= simple_form_for @story, url: stories_path do |f| %>
        <%= f.error_notification %>

        <%# ================================================ %>
        <%# ÉTAPE 1 — Choix des héros %>
        <%# ================================================ %>
        <div class="new-story-section">
          <h2 class="new-story-section-title">👤 Qui sont les héros ?</h2>
          <p class="new-story-section-hint">Tu peux sélectionner plusieurs enfants.</p>

          <% if @children.any? %>
            <div class="row g-2">
              <% @children.each do |child| %>
                <div class="col-sm-6">
                  <%# data-action="change" déclenche onCheckboxChange pour la validation en temps réel %>
                  <label class="child-selector w-100 d-flex align-items-center gap-3">
                    <input type="checkbox"
                           name="story[child_ids][]"
                           value="<%= child.id %>"
                           class="form-check-input d-none"
                           data-action="change->story-creation#onCheckboxChange">
                    <div>
                      <div class="child-name"><%= child.name %></div>
                      <div class="child-meta"><%= child.age %> ans · <%= child.gender == "boy" ? "Garçon" : "Fille" %></div>
                    </div>
                  </label>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# Message d'erreur — caché par défaut %>
          <p class="new-story-child-error small mt-2 d-none" data-story-creation-target="childError">
            ⚠️ Sélectionne au moins un enfant pour créer l'histoire.
          </p>

          <div class="mt-3">
            <%= link_to "+ Nouveau profil", new_child_path, class: "new-story-link-secondary" %>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 2 — Description libre de l'aventure %>
        <%# ================================================ %>
        <div class="new-story-section">
          <h2 class="new-story-section-title">💬 Qu'est-ce qu'il/elle veut vivre aujourd'hui ?</h2>
          <p class="new-story-section-hint">
            Décris librement l'aventure — un rêve, un endroit magique, un super-pouvoir...
          </p>

          <%= f.text_area :custom_theme,
                rows: 4,
                class: "new-story-textarea",
                placeholder: "Ex : Elle veut être une exploratrice qui découvre une île secrète avec des animaux parlants..." %>

          <%# Idées cliquables — s'ajoutent au texte existant sans l'écraser %>
          <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
            <span class="new-story-section-hint mb-0" style="font-size: 0.75rem;">Inspiration :</span>
            <% [
              "🚀 Astronaute qui découvre une planète habitée par des robots gentils",
              "🦄 Princesse qui part à l'aventure avec sa licorne magique",
              "🦕 Voyage dans le temps chez les dinosaures",
              "🏴‍☠️ Pirate qui cherche un trésor caché sous la mer",
              "🌳 Gardien de la forêt qui sauve les animaux"
            ].each do |idea| %>
              <%# data-action="click" → insertIdea() qui ajoute sans écraser %>
              <%# data-idea stocke le texte pour éviter les problèmes de quotes %>
              <button type="button"
                      class="idea-pill"
                      data-action="click->story-creation#insertIdea"
                      data-idea="<%= idea %>">
                <%= idea %>
              </button>
            <% end %>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 3 — Paramètres de l'histoire %>
        <%# ================================================ %>
        <div class="new-story-section">
          <h2 class="new-story-section-title" style="margin-bottom: 1.5rem;">⚙️ Paramètres</h2>

          <%# Valeur éducative — courage sélectionné par défaut %>
          <div class="mb-4">
            <span class="new-story-label">💫 Valeur à transmettre</span>
            <div class="d-flex flex-wrap gap-2">
              <% [
                { value: "courage",    label: "💪 Courage"     },
                { value: "sharing",    label: "🤝 Partage"     },
                { value: "kindness",   label: "❤️ Gentillesse" },
                { value: "confidence", label: "⭐ Confiance"   }
              ].each do |val| %>
                <%# La classe "selected" est gérée par story-creation#onRadioChange %>
                <label class="badge-selector <%= 'selected' if @story.educational_value == val[:value] %>">
                  <%= f.radio_button :educational_value, val[:value] %>
                  <%= val[:label] %>
                </label>
              <% end %>
            </div>
          </div>

          <%# Durée — cartes visuelles au lieu de simples radio buttons %>
          <div class="mb-4">
            <span class="new-story-label">⏱️ Durée de l'histoire</span>
            <div class="d-flex gap-3 flex-wrap">
              <% [
                { mins: 5,  icon: "⚡", label: "5 min",  sub: "Court" },
                { mins: 10, icon: "📖", label: "10 min", sub: "Moyen" },
                { mins: 15, icon: "🌟", label: "15 min", sub: "Long"  }
              ].each do |d| %>
                <%# La classe "selected" est gérée par story-creation#onRadioChange %>
                <label class="duration-selector <%= 'selected' if @story.duration_minutes == d[:mins] %>">
                  <%= f.radio_button :duration_minutes, d[:mins], checked: d[:mins] == 5 %>
                  <span class="duration-icon"><%= d[:icon] %></span>
                  <span class="duration-label"><%= d[:label] %></span>
                  <span class="duration-sub"><%= d[:sub] %></span>
                </label>
              <% end %>
            </div>
          </div>

          <%# Mode interactif (Premium uniquement) %>
          <div>
            <div class="form-check form-switch">
              <% if current_user.premium? %>
                <%# Utilisateur premium — toggle actif %>
                <%= f.check_box :interactive, class: "form-check-input", id: "interactive-toggle" %>
                <label class="form-check-label new-story-toggle-label" for="interactive-toggle">
                  🎮 Activer le mode interactif
                  <span class="new-story-toggle-hint d-block">
                    L'enfant fait des choix qui changent l'histoire
                  </span>
                </label>
              <% else %>
                <%# Utilisateur gratuit — toggle désactivé %>
                <input class="form-check-input" type="checkbox" disabled>
                <label class="form-check-label new-story-toggle-label">
                  🎮 Mode interactif
                  <span class="new-story-premium-badge">Premium</span>
                  <span class="new-story-toggle-hint d-block">
                    <%= link_to "Passer en Premium", subscription_path, class: "new-story-upgrade-link" %>
                    pour débloquer les histoires interactives
                  </span>
                </label>
              <% end %>
            </div>
          </div>

        </div>

        <%# Bouton de génération — avec feedback visuel géré par story-creation controller %>
        <%# data-story-creation-target="submitBtn" : le controller le désactive et change son texte %>
        <%= f.submit "✨ Générer l'histoire magique",
              class: "new-story-submit",
              data: { "story-creation-target": "submitBtn" } %>

      <% end %>
    </div>
  </div>
</div>
