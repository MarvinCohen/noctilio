<%# ============================================================ %>
<%# Formulaire de création d'histoire — Wizard 5 étapes %>
<%# Navigation gérée par story-creation Stimulus controller %>
<%# Le formulaire est unique — tous les champs sont soumis ensemble %>
<%# ============================================================ %>
<%# Les styles de cette page sont dans app/assets/stylesheets/components/_story_new.scss %>


<%# ── Wrapper principal — data-controller Stimulus ── %>
<%# Les data-*-value transmettent au JS les chaînes traduites qu'il doit écrire
    dynamiquement (titre d'étape, libellés du récap, état du bouton…). Ainsi le
    contrôleur Stimulus n'a plus aucun texte français en dur. %>
<div class="container wizard-page"
     data-controller="story-creation"
     data-action="change->story-creation#onRadioChange submit->story-creation#validateForm"
     data-story-creation-step-word-value="<%= t("wizard.step_word") %>"
     data-story-creation-summary-empty-value="<%= t("wizard.summary_empty") %>"
     data-story-creation-summary-not-set-value="<%= t("wizard.summary_not_set") %>"
     data-story-creation-summary-auto-value="<%= t("wizard.summary_auto") %>"
     data-story-creation-interactive-on-value="<%= t("wizard.interactive_on") %>"
     data-story-creation-interactive-off-value="<%= t("wizard.interactive_off") %>"
     data-story-creation-minute-short-value="<%= t("wizard.minute_short") %>"
     data-story-creation-generating-value="<%= t("wizard.generating") %>">

  <div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">

      <%# ── En-tête du wizard ── %>
      <div class="wizard-header">
        <div class="wizard-header-top">

          <%# Titre + label étape %>
          <div>
            <h1 class="wizard-page-title"><%= t("wizard.page_title") %></h1>
            <%# Rendu initial : le JS réécrit ce libellé dès connect() (6 étapes) %>
            <p class="wizard-step-label" data-story-creation-target="stepTitle"><%= t("wizard.step_word") %> 1 / 6</p>
          </div>

          <%# Cercles indicateurs — 6 étapes désormais %>
          <div class="wizard-indicators">
            <% 6.times do |i| %>
              <div class="wizard-indicator <%= i == 0 ? 'wizard-indicator--active' : '' %>"
                   data-story-creation-target="indicator">
                <%= i + 1 %>
              </div>
            <% end %>
          </div>

        </div>

        <%# Barre de progression %>
        <div class="wizard-progress-track">
          <div class="wizard-progress-fill" data-story-creation-target="progressFill"></div>
        </div>
      </div>

      <%# ── Bannière offre découverte ── %>
      <%# Affichée uniquement pour un compte gratuit qui n'a encore créé aucune histoire :
          sa 1re histoire est offerte en accès complet (illustration + audio + interactif).
          But : accroche de conversion dès la création de la 1re histoire. %>
      <% if !current_user.premium? && current_user.first_story_pending? %>
        <div class="wizard-offer-banner">
          <span class="wizard-offer-banner__icon">🎁</span>
          <span><%= t("wizard.offer_banner_html") %></span>
        </div>
      <% end %>

      <%# ── Formulaire unique — tous les champs soumis ensemble ── %>
      <%= simple_form_for @story, url: stories_path do |f| %>
        <%= f.error_notification %>

        <%# Wrapper overflow:hidden — nécessaire pour que les slides ne débordent pas %>
        <div class="wizard-steps-wrapper">

        <%# ================================================ %>
        <%# ÉTAPE 1 — Qui sont les héros ? %>
        <%# ================================================ %>
        <div class="wizard-step" data-story-creation-target="step" data-step="1">
          <div class="wizard-card">
            <h2 class="wizard-question"><%= t("wizard.step1_question") %></h2>
            <p class="wizard-hint"><%= t("wizard.step1_hint") %></p>

            <div class="d-flex flex-column gap-2">
              <% if @children.any? %>
                <% @children.each do |child| %>
                  <%# Label-carte cliquable — checkbox cachée à l'intérieur %>
                  <label class="child-selector">
                    <input type="checkbox"
                           name="story[child_ids][]"
                           value="<%= child.id %>"
                           data-gender="<%= child.gender %>"
                           data-action="change->story-creation#onCheckboxChange">

                    <%# Avatar DiceBear personnalisé — même rendu que la page "Mes enfants" %>
                    <%# dicebear_avatar_url(child) génère l'URL selon couleur de peau/cheveux/genre %>
                    <%# L'image remplit le cercle de 38px (object-fit: cover) %>
                    <div class="child-selector-avatar">
                      <%= image_tag dicebear_avatar_url(child),
                            alt: child.name,
                            width: 38,
                            height: 38,
                            style: "border-radius: 50%; object-fit: cover;" %>
                    </div>

                    <%# Infos enfant %>
                    <div>
                      <div class="child-name"><%= child.name %></div>
                      <%# Genre traduit via les clés wizard.boy / wizard.girl %>
                      <div class="child-meta"><%= t("wizard.child_meta", age: child.age, gender: child.gender == "boy" ? t("wizard.boy") : t("wizard.girl")) %></div>
                    </div>

                    <%# Coche de sélection %>
                    <div class="child-selector-check">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                  </label>
                <% end %>
              <% else %>
                <%# Aucun enfant — invite à en créer un %>
                <p style="color:#8a8578; font-size:0.88rem;"><%= t("wizard.no_child") %></p>
              <% end %>
            </div>

            <%# Message d'erreur — caché par défaut %>
            <p class="wizard-error d-none" data-story-creation-target="childError">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <%= t("wizard.child_error") %>
            </p>

            <%= link_to t("wizard.new_profile"), new_child_path, class: "wizard-link-secondary" %>
          </div>

          <%# Navigation %>
          <div class="wizard-nav">
            <button type="button" class="wizard-btn-next" data-action="click->story-creation#nextStep">
              <%= t("wizard.next") %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 2 — Quelle aventure ? %>
        <%# ================================================ %>
        <div class="wizard-step d-none" data-story-creation-target="step" data-step="2">
          <div class="wizard-card">
            <h2 class="wizard-question"><%= t("wizard.step2_question") %></h2>
            <p class="wizard-hint"><%= t("wizard.step2_hint") %></p>

            <%= f.text_area :custom_theme,
                  rows: 4,
                  class: "wizard-textarea",
                  placeholder: t("wizard.textarea_placeholder") %>

            <%# Idées cliquables — cachées derrière un bouton "Inspire moi" %>
            <%# <details>/<summary> : ouverture/fermeture native, zéro JS %>
            <details class="wizard-inspire-details">

              <%# Le bouton visible — clique pour dérouler les inspirations %>
              <summary class="wizard-inspire-btn">
                <%= t("wizard.inspire") %>
              </summary>

              <%# Grille de chips — emoji + clé de traduction ; label et idea sont
                  récupérés via t("wizard.ideas.<clé>.label" / ".idea") %>
              <div class="wizard-inspire-grid">
                <% [
                  { emoji: "🚀", key: "space" },
                  { emoji: "🦄", key: "unicorn" },
                  { emoji: "🦕", key: "dinos" },
                  { emoji: "🏴‍☠️", key: "pirates" },
                  { emoji: "🌳", key: "forest" },
                  { emoji: "🧙", key: "wizard" },
                  { emoji: "🐉", key: "dragon" },
                  { emoji: "🌊", key: "ocean" },
                  { emoji: "🦸", key: "superhero" },
                  { emoji: "🌙", key: "moon" },
                  { emoji: "🤖", key: "robot" },
                  { emoji: "⏳", key: "time" }
                ].each do |item| %>
                  <button type="button"
                          class="idea-chip"
                          data-action="click->story-creation#insertIdea"
                          data-idea="<%= t("wizard.ideas.#{item[:key]}.idea") %>">
                    <span class="idea-chip-emoji"><%= item[:emoji] %></span>
                    <span class="idea-chip-label"><%= t("wizard.ideas.#{item[:key]}.label") %></span>
                  </button>
                <% end %>
              </div>

            </details>
          </div>

          <%# Navigation %>
          <div class="wizard-nav">
            <button type="button" class="wizard-btn-back" data-action="click->story-creation#prevStep">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <%= t("wizard.back") %>
            </button>
            <button type="button" class="wizard-btn-next" data-action="click->story-creation#nextStep">
              <%= t("wizard.next") %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 3 — Ce qu'ils vont apprendre %>
        <%# ================================================ %>
        <div class="wizard-step d-none" data-story-creation-target="step" data-step="3">
          <div class="wizard-card">
            <h2 class="wizard-question"><%= t("wizard.step3_question") %></h2>
            <p class="wizard-hint"><%= t("wizard.step3_hint") %></p>

            <div class="value-grid">
              <%# Courage %>
              <label class="value-card <%= 'selected' if @story.educational_value == 'courage' %>">
                <%= f.radio_button :educational_value, "courage" %>
                <div class="value-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                </div>
                <span class="value-label"><%= t("wizard.value_courage") %></span>
              </label>

              <%# Partage %>
              <label class="value-card <%= 'selected' if @story.educational_value == 'sharing' %>">
                <%= f.radio_button :educational_value, "sharing" %>
                <div class="value-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                </div>
                <span class="value-label"><%= t("wizard.value_sharing") %></span>
              </label>

              <%# Gentillesse %>
              <label class="value-card <%= 'selected' if @story.educational_value == 'kindness' %>">
                <%= f.radio_button :educational_value, "kindness" %>
                <div class="value-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <span class="value-label"><%= t("wizard.value_kindness") %></span>
              </label>

              <%# Confiance %>
              <label class="value-card <%= 'selected' if @story.educational_value == 'confidence' %>">
                <%= f.radio_button :educational_value, "confidence" %>
                <div class="value-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                </div>
                <span class="value-label"><%= t("wizard.value_confidence") %></span>
              </label>
            </div>
          </div>

          <%# Navigation %>
          <div class="wizard-nav">
            <button type="button" class="wizard-btn-back" data-action="click->story-creation#prevStep">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <%= t("wizard.back") %>
            </button>
            <button type="button" class="wizard-btn-next" data-action="click->story-creation#nextStep">
              <%= t("wizard.next") %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 4 — Combien de temps ? %>
        <%# ================================================ %>
        <div class="wizard-step d-none" data-story-creation-target="step" data-step="4">
          <div class="wizard-card">
            <h2 class="wizard-question"><%= t("wizard.step4_question") %></h2>
            <p class="wizard-hint"><%= t("wizard.step4_hint") %></p>

            <div class="duration-grid">
              <%# sub : clé de traduction du libellé (court/moyen/long) %>
              <% [
                { mins: 5,  sub: "wizard.duration_short"  },
                { mins: 10, sub: "wizard.duration_medium" },
                { mins: 15, sub: "wizard.duration_long"   }
              ].each do |d| %>
                <label class="duration-card <%= 'selected' if @story.duration_minutes == d[:mins] %>">
                  <%= f.radio_button :duration_minutes, d[:mins], checked: d[:mins] == 5 %>
                  <span class="duration-number"><%= d[:mins] %></span>
                  <span class="duration-unit"><%= t("wizard.minutes") %></span>
                  <span class="duration-sub"><%= t(d[:sub]) %></span>
                </label>
              <% end %>
            </div>
          </div>

          <%# Navigation %>
          <div class="wizard-nav">
            <button type="button" class="wizard-btn-back" data-action="click->story-creation#prevStep">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <%= t("wizard.back") %>
            </button>
            <button type="button" class="wizard-btn-next" data-action="click->story-creation#nextStep">
              <%= t("wizard.next") %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 5 — Style de l'illustration %>
        <%# ================================================ %>
        <div class="wizard-step d-none" data-story-creation-target="step" data-step="5">
          <div class="wizard-card">
            <h2 class="wizard-question"><%= t("wizard.step5_question") %></h2>
            <p class="wizard-hint"><%= t("wizard.step5_hint") %></p>

            <%# Grille de 4 tuiles — une par style visuel %>
            <div class="style-grid">

              <%# ── Boucle sur les 4 styles ── %>
              <%# data-style permet au JS de trouver l'image à mettre à jour %>
              <%# L'image affichée (_girl ou _boy) change selon le genre de l'enfant sélectionné %>

              <%# name/desc récupérés via t("wizard.style_<clé>_name" / "_desc") %>
              <% [
                   { key: "ghibli" },
                   { key: "comics" },
                   { key: "pixar" },
                   { key: "watercolor" },
                   { key: "cinematic" }
                 ].each do |style| %>
                <%# Libellés traduits du style courant %>
                <% style_name = t("wizard.style_#{style[:key]}_name") %>
                <% style_desc = t("wizard.style_#{style[:key]}_desc") %>

                <label class="style-card <%= 'selected' if @story.image_style == style[:key] %>">
                  <%= f.radio_button :image_style, style[:key] %>
                  <div class="style-card-inner">

                    <%# Image d'exemple — src mise à jour par JS selon le genre de l'enfant %>
                    <%# Par défaut on charge _girl ; si garçon sélectionné, JS bascule vers _boy %>
                    <% girl_path = "public/images/style_examples/#{style[:key]}_girl.jpg" %>
                    <% boy_path  = "public/images/style_examples/#{style[:key]}_boy.jpg"  %>
                    <% has_girl  = File.exist?(Rails.root.join(girl_path)) %>
                    <% has_boy   = File.exist?(Rails.root.join(boy_path))  %>

                    <% if has_girl || has_boy %>
                      <%# data-style-key : identifie le style pour que le JS puisse swapper le src %>
                      <%# data-girl-src / data-boy-src : URLs des deux versions %>
                      <%# loading="lazy" : chargement différé — ne charge que si visible dans le viewport %>
                      <%# width/height : évite le CLS (Cumulative Layout Shift) en réservant l'espace %>
                      <img src="/images/style_examples/<%= style[:key] %>_girl.jpg"
                           alt="<%= t("wizard.style_example_alt", name: style_name) %>"
                           class="style-card-img"
                           width="400" height="400"
                           loading="lazy"
                           data-style-key="<%= style[:key] %>"
                           data-girl-src="/images/style_examples/<%= style[:key] %>_girl.jpg"
                           data-boy-src="/images/style_examples/<%= style[:key] %>_boy.jpg">
                    <% else %>
                      <%# Fallback palette de couleurs si aucune image n'est encore générée %>
                      <div class="style-card-img-placeholder style-card-img-placeholder--<%= style[:key] %>">
                        <span></span><span></span><span></span>
                      </div>
                    <% end %>

                    <div class="style-card-text">
                      <div class="style-name"><%= style_name %></div>
                      <div class="style-desc"><%= style_desc %></div>
                    </div>
                  </div>
                </label>

              <% end %>

            </div>

            <%# Note : si aucun style choisi, le service applique le fallback automatique %>
            <p style="font-size:0.75rem; color:#8a8578; margin-top:1rem; text-align:center;">
              <%= t("wizard.style_auto_note") %>
            </p>
          </div>

          <%# Navigation %>
          <div class="wizard-nav">
            <button type="button" class="wizard-btn-back" data-action="click->story-creation#prevStep">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <%= t("wizard.back") %>
            </button>
            <button type="button" class="wizard-btn-next" data-action="click->story-creation#nextStep">
              <%= t("wizard.next") %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <%# ================================================ %>
        <%# ÉTAPE 6 — Les derniers réglages + Générer %>
        <%# ================================================ %>
        <div class="wizard-step d-none" data-story-creation-target="step" data-step="6">
          <div class="wizard-card">
            <h2 class="wizard-question"><%= t("wizard.step6_question") %></h2>
            <p class="wizard-hint"><%= t("wizard.step6_hint") %></p>

            <%# Toggle mode interactif %>
            <%# interactive_unlocked : le mode interactif est débloqué si l'utilisateur
                est Premium OU si c'est sa 1re histoire (offre découverte en accès complet). %>
            <% interactive_unlocked = current_user.premium? || current_user.first_story_pending? %>
            <div class="wizard-toggle-row">
              <div>
                <div class="wizard-toggle-label">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px;vertical-align:-2px"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="8" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="14" r="1" fill="currentColor" stroke="none"/><circle cx="16" cy="12" r="1" fill="currentColor" stroke="none"/></svg>
                  <%= t("wizard.interactive") %>
                  <%# Badge contextuel : "Offert" pour la 1re histoire gratuite, "Premium" pour les gratuits ayant déjà des histoires %>
                  <% if !current_user.premium? && current_user.first_story_pending? %>
                    <span class="wizard-premium-badge"><%= t("wizard.badge_free") %></span>
                  <% elsif !current_user.premium? %>
                    <span class="wizard-premium-badge"><%= t("wizard.badge_premium") %></span>
                  <% end %>
                </div>
                <div class="wizard-toggle-hint">
                  <% if current_user.premium? %>
                    <%= t("wizard.interactive_hint_premium") %>
                  <% elsif current_user.first_story_pending? %>
                    <%= t("wizard.interactive_hint_first") %>
                  <% elsif current_user.essentiel? %>
                    <%# Abonné Essentiel : upgrade direct vers Premium en un clic (POST swap_plan).
                        button_to rendu en ligne (display:inline) pour rester dans le texte du hint. %>
                    <%= button_to t("wizard.interactive_upgrade_essentiel"), subscription_swap_path, method: :post,
                          style: "display:inline; background:none; border:none; padding:0; color:rgba(240,201,122,0.65); cursor:pointer; font:inherit;" %>
                  <% else %>
                    <%# Compte gratuit : lien vers la page de tarifs (il doit choisir une offre). %>
                    <%= link_to t("wizard.interactive_hint_link"), subscription_path, style: "color:rgba(240,201,122,0.65);" %> <%= t("wizard.interactive_hint_locked") %>
                  <% end %>
                </div>
              </div>
              <div class="form-check form-switch mb-0">
                <%# Case activée si le mode interactif est débloqué (Premium ou 1re histoire) %>
                <% if interactive_unlocked %>
                  <%= f.check_box :interactive, class: "form-check-input", id: "interactive-toggle" %>
                <% else %>
                  <input class="form-check-input" type="checkbox" disabled>
                <% end %>
              </div>
            </div>

            <%# Récapitulatif %>
            <div class="summary-card">
              <div class="summary-row">
                <span class="summary-key"><%= t("wizard.summary_heroes") %></span>
                <span class="summary-val" data-story-creation-target="summaryChildren"><%= t("wizard.summary_empty") %></span>
              </div>
              <div class="summary-row">
                <span class="summary-key"><%= t("wizard.summary_adventure") %></span>
                <span class="summary-val" data-story-creation-target="summaryTheme"><%= t("wizard.summary_empty") %></span>
              </div>
              <div class="summary-row">
                <span class="summary-key"><%= t("wizard.summary_value") %></span>
                <span class="summary-val" data-story-creation-target="summaryValue"><%= t("wizard.summary_empty") %></span>
              </div>
              <div class="summary-row">
                <span class="summary-key"><%= t("wizard.summary_duration") %></span>
                <span class="summary-val" data-story-creation-target="summaryDuration"><%= t("wizard.summary_empty") %></span>
              </div>
              <div class="summary-row">
                <span class="summary-key"><%= t("wizard.summary_interactive") %></span>
                <span class="summary-val" data-story-creation-target="summaryInteractive"><%= t("wizard.interactive_off") %></span>
              </div>
              <div class="summary-row">
                <span class="summary-key"><%= t("wizard.summary_illustration") %></span>
                <%# Mis à jour dynamiquement par le Stimulus controller %>
                <span class="summary-val" data-story-creation-target="summaryStyle"><%= t("wizard.summary_auto") %></span>
              </div>
            </div>
          </div>

          <%# Navigation — Retour + Générer %>
          <div class="wizard-nav" style="flex-direction:column; gap:0.75rem;">
            <%= f.submit t("wizard.generate"),
                  class: "wizard-btn-generate",
                  data: { "story-creation-target": "submitBtn" } %>

            <button type="button" class="wizard-btn-back" style="margin:0 auto;" data-action="click->story-creation#prevStep">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <%= t("wizard.back") %>
            </button>
          </div>
        </div>

        </div><%# /wizard-steps-wrapper %>

      <% end %>
    </div>
  </div>
</div>
