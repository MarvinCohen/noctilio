<%# ============================================================ %>
<%# Page de lecture d'une histoire %>
<%# Gère 3 états : en attente / en génération / terminée %>
<%# ============================================================ %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <%# ================================================ %>
      <%# CAS 1 : Histoire en cours de génération %>
      <%# Stimulus controller poll le statut toutes les 2 secondes %>
      <%# ================================================ %>
      <% if @story.pending? || @story.generating? %>
        <div class="text-center py-6"
             data-controller="story-status"
             data-story-status-url-value="<%= status_story_path(@story) %>"
             data-story-status-redirect-value="<%= story_path(@story) %>">

          <div class="mb-4" style="font-size: 5rem;">🌙</div>

          <h1 class="h3 fw-bold mb-3">La magie opère...</h1>
          <p class="text-muted mb-4">
            Votre histoire est en cours de création.<br>
            Cela prend généralement 15 à 30 secondes.
          </p>

          <%# Barre de progression animée %>
          <div class="progress mx-auto mb-4" style="max-width: 400px; height: 8px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                 style="width: 100%"></div>
          </div>

          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Génération en cours...</span>
          </div>

          <p class="text-muted mt-3 small">
            Status : <%= @story.status %>
          </p>
        </div>

      <%# ================================================ %>
      <%# CAS 2 : Génération échouée %>
      <%# ================================================ %>
      <% elsif @story.failed? %>
        <div class="text-center py-6">
          <div class="mb-4" style="font-size: 4rem;">😔</div>
          <h1 class="h3 fw-bold mb-3">Oups, une erreur s'est produite</h1>
          <p class="text-muted mb-4">La génération de l'histoire a échoué. Veuillez réessayer.</p>
          <%= link_to "Réessayer", new_story_path, class: "btn btn-primary me-2" %>
          <%= link_to "Mes histoires", stories_path, class: "btn btn-outline-secondary" %>
        </div>

      <%# ================================================ %>
      <%# CAS 3 : Histoire terminée — affichage de la lecture %>
      <%# ================================================ %>
      <% else %>

        <%# Métadonnées de l'histoire %>
        <div class="d-flex align-items-center gap-3 mb-3">
          <%= link_to stories_path, class: "text-muted text-decoration-none" do %>
            ← Mes histoires
          <% end %>
          <span class="badge bg-light text-dark"><%= @story.world_emoji %> <%= @story.world_label %></span>
          <span class="badge bg-light text-dark">Pour <%= @story.child.name %></span>
        </div>

        <%# Titre de l'histoire %>
        <h1 class="fw-bold display-6 mb-4"><%= @story.title || "Mon histoire magique" %></h1>

        <%# Contrôles de lecture vocale — Web Speech API %>
        <%# data-controller connecte le Stimulus controller story-reader %>
        <div data-controller="story-reader" class="mb-5">
          <%# Message affiché si le navigateur ne supporte pas la synthèse vocale %>
          <%# (Firefox mobile, certains navigateurs Android) — caché par défaut %>
          <p class="reader-unsupported text-muted small d-none mb-3">
            🎙️ La lecture vocale n'est pas disponible sur ce navigateur.
          </p>

          <%# Boutons de contrôle de lecture %>
          <div class="reader-controls d-flex align-items-center gap-2 mb-3">
            <span class="text-muted small fw-semibold">🎙️ Lecture vocale :</span>

            <%# Bouton Play — visible quand la lecture est arrêtée %>
            <button data-story-reader-target="playBtn"
                    data-action="click->story-reader#play"
                    class="btn btn-sm btn-outline-primary">
              ▶ Écouter
            </button>

            <%# Bouton Pause — masqué par défaut, affiché quand la lecture est en cours %>
            <button data-story-reader-target="pauseBtn"
                    data-action="click->story-reader#pause"
                    class="btn btn-sm btn-outline-secondary d-none">
              ⏸ Pause
            </button>

            <%# Bouton Stop — arrête complètement la lecture %>
            <button data-story-reader-target="stopBtn"
                    data-action="click->story-reader#stop"
                    class="btn btn-sm btn-outline-danger">
              ⏹ Arrêter
            </button>
          </div>

          <%# Contenu de l'histoire — data-story-reader-target="text" permet au controller de le lire %>
          <%# render_story_markdown convertit ## et **bold** en vrai HTML (sans symboles parasites) %>
          <%# Le TTS lit innerText, donc il ne verra que le texte propre sans les balises %>
          <div class="story-content" data-story-reader-target="text">
            <%= render_story_markdown(@story.content) %>

            <%# Si un choix interactif est en attente, on insère le texte du choix ICI %>
            <%# pour que la voix le lise naturellement dans la continuité de l'histoire %>
            <% if @story.interactive? && @pending_choice %>
              <div class="story-choice-voice-text">
                <p class="story-paragraph">
                  À toi de décider ! <%= @pending_choice.question %>
                </p>
                <p class="story-paragraph">
                  Option A : <%= @pending_choice.option_a %>
                </p>
                <p class="story-paragraph">
                  Option B : <%= @pending_choice.option_b %>
                </p>
              </div>
            <% end %>
          </div>
        </div>

        <%# ================================================ %>
        <%# Mode interactif — affiche le choix si disponible %>
        <%# ================================================ %>
        <% if @story.interactive? && @pending_choice %>
          <%# data-controller="story-choice" : gère le choix sans rechargement de page %>
          <%# data-story-choice-status-url-value : URL de polling pour détecter la fin de génération %>
          <div class="interactive-choice card border-primary border-2 shadow-sm mb-5"
               data-controller="story-choice"
               data-story-choice-status-url-value="<%= status_story_path(@story) %>">
            <div class="card-body p-4">
              <div class="text-center mb-4">
                <span style="font-size: 2.5rem;">🤔</span>
                <h3 class="h5 fw-bold mt-2">À toi de décider !</h3>
                <p class="text-muted"><%= @pending_choice.question %></p>
              </div>

              <div class="row g-3">
                <%# Option A — formulaire intercepté par story-choice#submit (pas de rechargement) %>
                <div class="col-md-6">
                  <%= form_tag choose_story_path(@story), method: :post,
                        data: { action: "submit->story-choice#submit" } do %>
                    <input type="hidden" name="chosen_option" value="a">
                    <button type="submit" class="btn btn-outline-primary w-100 p-4">
                      <div class="fw-bold mb-1">Option A</div>
                      <div class="small"><%= @pending_choice.option_a %></div>
                    </button>
                  <% end %>
                </div>

                <%# Option B — même principe %>
                <div class="col-md-6">
                  <%= form_tag choose_story_path(@story), method: :post,
                        data: { action: "submit->story-choice#submit" } do %>
                    <input type="hidden" name="chosen_option" value="b">
                    <button type="submit" class="btn btn-outline-primary w-100 p-4">
                      <div class="fw-bold mb-1">Option B</div>
                      <div class="small"><%= @pending_choice.option_b %></div>
                    </button>
                  <% end %>
                </div>
              </div>

            </div>
          </div>

        <%# Si les choix ont tous été faits — affiche la suite %>
        <% elsif @story.interactive? && @story.story_choices.resolved.any? %>
          <div class="story-continuation mb-5">
            <% @story.story_choices.resolved.ordered.each do |choice| %>
              <div class="choice-result p-3 bg-primary bg-opacity-10 rounded-3 mb-3">
                <div class="small text-muted mb-1">✅ <%= choice.question %></div>
                <div class="fw-semibold">→ <%= choice.chosen_text %></div>
              </div>
              <% if choice.context_chosen.present? %>
                <%= simple_format(choice.context_chosen) %>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <%# ================================================ %>
        <%# ILLUSTRATION DE FIN — image du moment clé de l'histoire %>
        <%# Placée à la fin pour ne pas spoiler et avoir un effet "récompense" %>
        <%# ================================================ %>
        <%# Section illustration — toujours affichée pour une histoire terminée %>
        <%# Le skeleton est visible en attendant que Pollinations génère et charge l'image %>
        <div class="story-illustration-section">
          <div class="story-illustration-label">✦ L'illustration de ton aventure</div>

          <div class="story-illustration-wrapper" id="story-illustration">

            <%# Skeleton — visible par défaut, masqué quand l'image est chargée %>
            <div class="story-illustration-skeleton" id="story-illustration-skeleton">
              <div class="story-illustration-skeleton-icon"><%= @story.world_emoji %></div>
              <p class="story-illustration-skeleton-text">Illustration en cours de création...</p>
            </div>

            <%# Image — n'existe que si l'URL est sauvegardée en base %>
            <% if @story.cover_image.attached? || @story.cover_image_url.present? %>
              <% image_src = @story.cover_image.attached? ? url_for(@story.cover_image) : @story.cover_image_url %>
              <%= image_tag image_src,
                    alt:     "Illustration de #{@story.title}",
                    class:   "story-illustration-img",
                    style:   "display:none",
                    onload:  "this.style.display='block'; document.getElementById('story-illustration-skeleton').style.display='none';",
                    onerror: "document.getElementById('story-illustration-skeleton').innerHTML='<p style=\"color:#777;font-size:0.8rem;\">Illustration non disponible</p>';" %>
            <% end %>

          </div>
        </div>

        <%# Boutons de navigation %>
        <div class="d-flex gap-3 justify-content-center flex-wrap mt-4">
          <%= link_to "✨ Nouvelle histoire", new_story_path, class: "btn btn-primary" %>
          <%= link_to "📚 Mes histoires", stories_path, class: "btn btn-outline-secondary" %>
          <%= link_to "🏆 Trophées", trophy_room_path, class: "btn btn-outline-secondary" %>

          <%# Bouton sauvegarder — affiché seulement si l'histoire n'est pas encore sauvegardée %>
          <%# saved? utilise la méthode générée automatiquement par Rails pour le boolean saved %>
          <% if @story.saved? %>
            <%# Badge désactivé si déjà sauvegardée — évite les doubles sauvegardes %>
            <span class="btn btn-success disabled">✅ Sauvegardée</span>
          <% else %>
            <%# button_to génère un formulaire POST — nécessaire car c'est une action qui modifie les données %>
            <%= button_to "💾 Sauvegarder", save_story_story_path(@story),
                  method: :post,
                  class: "btn btn-warning fw-bold" %>
          <% end %>
        </div>

      <% end %>
    </div>
  </div>
</div>
