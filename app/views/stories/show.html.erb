<%# ============================================================ %>
<%# Page de lecture d'une histoire %>
<%# DA cosmique : fond sombre, accents dorés, Cormorant Garamond %>
<%# Gère 3 états : en attente / en génération / terminée %>
<%# ============================================================ %>


<div class="container story-page">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <%# ================================================ %>
      <%# CAS 1 : Histoire en cours de génération %>
      <%# Stimulus controller poll le statut toutes les 2 secondes %>
      <%# ================================================ %>
      <% if @story.pending? || @story.generating? %>
        <div class="story-generating"
             data-controller="story-status"
             data-story-status-url-value="<%= status_story_path(@story) %>"
             data-story-status-redirect-value="<%= story_path(@story) %>"
             <%# Messages rotatifs passés au JS via des data-values (i18n) %>
             data-story-status-msg1-value="<%= t("story_show.gen_msg_1") %>"
             data-story-status-msg2-value="<%= t("story_show.gen_msg_2") %>"
             data-story-status-msg3-value="<%= t("story_show.gen_msg_3") %>"
             data-story-status-msg4-value="<%= t("story_show.gen_msg_4") %>">

          <span class="story-generating-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
          </span>
          <h1 class="story-generating-title"><%= t("story_show.generating_title") %></h1>

          <%# Message de progression rotatif — animé par story_status_controller %>
          <%# Donne l'impression que les étapes avancent (texte, illustration…) %>
          <p class="story-generating-message" data-story-status-target="message">
            <%= t("story_show.gen_msg_1") %>
          </p>

          <p class="story-generating-hint">
            <%= t("story_show.generating_hint_html") %>
          </p>

          <%# Barre de progression animée en doré %>
          <div class="story-progress-bar">
            <div class="story-progress-fill"></div>
          </div>

          <%# Spinner doré — remplace le spinner Bootstrap bleu %>
          <div class="story-spinner"></div>

          <%# ---------------------------------------------------------------- %>
          <%# Skeleton de chargement — esquisse de la future histoire (esprit app) %>
          <%# Donne à voir la forme de la page à venir (couverture + lignes de texte) %>
          <%# avec un effet "shimmer" doré, plutôt qu'un simple écran vide. %>
          <%# aria-hidden : purement décoratif, ignoré par les lecteurs d'écran. %>
          <%# ---------------------------------------------------------------- %>
          <div class="story-skeleton" aria-hidden="true">
            <%# Bloc couverture (image à venir) %>
            <div class="story-skeleton-cover"></div>
            <%# Lignes de texte simulées — largeurs variables pour un rendu naturel %>
            <div class="story-skeleton-line story-skeleton-line--title"></div>
            <div class="story-skeleton-line"></div>
            <div class="story-skeleton-line"></div>
            <div class="story-skeleton-line story-skeleton-line--short"></div>
          </div>

          <p class="story-status-text"><%= t("story_show.status_label", status: @story.status) %></p>
        </div>

      <%# ================================================ %>
      <%# CAS 2 : Génération échouée %>
      <%# ================================================ %>
      <% elsif @story.failed? %>
        <div class="story-error">
          <span class="story-error-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </span>
          <h1 class="story-error-title"><%= t("story_show.error_title") %></h1>
          <p class="story-error-hint"><%= t("story_show.error_hint") %></p>
          <div class="d-flex gap-3 justify-content-center">
            <%# "Réessayer" relance la MÊME histoire via l'action retry (POST) :
                on conserve le profil enfant + l'univers choisis par le parent,
                au lieu de le renvoyer vers un formulaire vierge (new_story_path).
                button_to génère un <form> POST ; on garde le style story-btn-primary. %>
            <%= button_to t("library.retry"), retry_story_path(@story), method: :post, class: "story-btn-primary" %>
            <%= link_to t("story_show.my_stories"), stories_path, class: "story-btn-secondary" %>
          </div>
        </div>

      <%# ================================================ %>
      <%# CAS 3 : Histoire terminée — lecture %>
      <%# ================================================ %>
      <% else %>

        <%# Fil d'Ariane + méta %>
        <div class="story-breadcrumb">
          <%= link_to t("story_show.back_to_stories"), stories_path, class: "story-back-link" %>
          <span class="story-meta-pill"><%= @story.world_emoji %> <%= @story.world_label %></span>
          <%# "Pour %{name}" partagé avec la bibliothèque (library.for_child) %>
          <span class="story-meta-pill"><%= t("library.for_child", name: @story.child.name) %></span>
          <%# Badge épisode — affiché seulement si l'histoire fait partie d'une saga %>
          <% if @story.sequel? || @story.has_sequel? %>
            <span class="story-meta-pill story-meta-pill--episode">
              <%= t("story_show.episode", number: @story.episode_number) %>
            </span>
          <% end %>
        </div>

        <%# Titre de l'histoire — Cormorant Garamond italic %>
        <h1 class="story-title"><%= @story.title || t("story_show.default_title") %></h1>

        <%# Navigation entre épisodes — affiché si l'histoire fait partie d'une saga %>
        <% if @story.sequel? || @story.has_sequel? %>
          <div class="story-saga-nav">
            <%# Lien vers l'épisode précédent %>
            <% if @story.sequel? %>
              <%= link_to story_path(@story.parent_story), class: "story-saga-link story-saga-link--prev" do %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                <%= t("story_show.episode", number: @story.episode_number - 1) %>
              <% end %>
            <% else %>
              <span></span>
            <% end %>
            <%# Indicateur de position dans la saga %>
            <span class="story-saga-label"><%= t("story_show.episode", number: @story.episode_number) %></span>
            <%# Lien vers l'épisode suivant s'il existe %>
            <% if @story.has_sequel? %>
              <%= link_to story_path(@story.next_sequel), class: "story-saga-link story-saga-link--next" do %>
                <%= t("story_show.episode", number: @story.episode_number + 1) %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              <% end %>
            <% else %>
              <span></span>
            <% end %>
          </div>
        <% end %>

        <%# ── ILLUSTRATION — image du moment clé, placée sous le titre ── %>
        <%# Remontée ici (au lieu de la fin) pour l'effet "livre illustré" : %>
        <%# le lecteur voit l'image dès le début, avant de lire le texte. %>
        <%# illustrations_for? : Essentiel/Premium OU 1re histoire offerte → l'illustration
            est générée. Sinon (gratuit, histoire en texte seul) : aucune image ne
            viendra, on affiche un encart d'upsell à la place (moment de conversion). %>
        <% if current_user.illustrations_for?(@story) %>
        <div class="story-illustration-section">
          <div class="story-illustration-label"><%= t("story_show.illustration_label") %></div>

          <%# CAS 1 : l'image est déjà disponible %>
          <% if @story.cover_image.attached? || @story.cover_image_url.present? %>
            <% image_src = @story.cover_image.attached? ? url_for(@story.cover_image) : @story.cover_image_url %>
            <div class="story-illustration-wrapper">
              <div class="story-illustration-skeleton" id="story-illustration-skeleton">
                <div class="story-illustration-skeleton-icon"><%= @story.world_emoji %></div>
                <p class="story-illustration-skeleton-text"><%= t("story_show.illustration_loading") %></p>
              </div>
              <%# L'image démarre cachée — un script nonce l'affiche après chargement %>
              <%# On utilise un script nonce (au lieu de onload inline) car la CSP bloque %>
              <%# les handlers inline (onload=, onerror=) sans 'unsafe-inline' %>
              <%= image_tag image_src,
                    alt:   t("story_show.illustration_alt", title: @story.title),
                    class: "story-illustration-img",
                    id:    "story-cover-img-#{@story.id}",
                    style: "display:none" %>
            </div>
            <script nonce="<%= content_security_policy_nonce %>">
              (function() {
                // Récupère l'image et le skeleton par leur ID unique (évite les conflits si plusieurs histoires)
                var img      = document.getElementById('story-cover-img-<%= @story.id %>');
                var skeleton = document.getElementById('story-illustration-skeleton');
                if (!img) return;

                // Quand l'image est chargée : l'affiche et cache le skeleton
                img.addEventListener('load', function() {
                  img.style.display = 'block';
                  if (skeleton) skeleton.style.display = 'none';
                });

                // Si l'image est déjà chargée (cache navigateur), déclenche manuellement
                if (img.complete && img.naturalWidth > 0) {
                  img.style.display = 'block';
                  if (skeleton) skeleton.style.display = 'none';
                }

                // En cas d'erreur : affiche un message discret dans le skeleton
                img.addEventListener('error', function() {
                  if (skeleton) skeleton.innerHTML = '<p style="color:#8a8578;font-size:0.8rem;"><%= j t("story_show.illustration_unavailable") %></p>';
                });
              })();
            </script>

          <%# CAS 2 : l'image n'est pas encore prête — story_image_controller poll /status %>
          <% else %>
            <div class="story-illustration-wrapper"
                 data-controller="story-image"
                 data-story-image-status-url-value="<%= status_story_path(@story) %>"
                 data-story-image-alt-value="<%= t("story_show.illustration_alt", title: @story.title) %>"
                 <%# Message d'erreur passé au JS si l'image ne se charge pas %>
                 data-story-image-unavailable-value="<%= t("story_show.illustration_unavailable") %>">
              <div class="story-illustration-skeleton">
                <div class="story-illustration-skeleton-icon"><%= @story.world_emoji %></div>
                <p class="story-illustration-skeleton-text"><%= t("story_show.illustration_loading") %></p>
              </div>
            </div>
          <% end %>
        </div>
        <% else %>
          <%# Gratuit + histoire en texte seul → encart de conversion à la place de l'image %>
          <div class="story-illustration-section">
            <div class="story-upsell-card">
              <div class="story-upsell-card__icon">🎨</div>
              <p class="story-upsell-card__title"><%= t("story_show.upsell_title") %></p>
              <p class="story-upsell-card__text">
                <%= t("story_show.upsell_text") %>
              </p>
              <%= link_to t("story_show.upsell_btn"), subscription_path, class: "story-upsell-card__btn" %>
            </div>
          </div>
        <% end %>

        <%# ── Contenu de l'histoire ── %>
        <%# data-story-reader-target="text" : utilisé par story_choice_controller pour insérer la continuation %>
        <div class="story-content-wrapper"
             data-story-reader-target="text">
          <%# Le texte markdown est rendu via le helper render_story_markdown %>
          <%= render_story_markdown(@story.content) %>

          <%# Si un choix interactif est en attente, on insère le texte du choix ici %>
          <% if @story.interactive? && @pending_choice %>
            <div class="story-choice-voice-text">
              <p class="story-paragraph"><%= t("story_show.decide") %> <%= @pending_choice.question %></p>
              <p class="story-paragraph"><%= t("story_show.voice_option_a", text: @pending_choice.option_a) %></p>
              <p class="story-paragraph"><%= t("story_show.voice_option_b", text: @pending_choice.option_b) %></p>
            </div>
          <% end %>
        </div>

        <%# ── LECTEUR AUDIO — bouton flottant (FAB) avec anneau de progression ── %>
        <%# DA cosmique : glassmorphism sombre, accents dorés, icônes SVG %>
        <%# Au repos : bouton rond doré + anneau qui se remplit pendant la lecture. %>
        <%# Au clic : il se déplie en barre complète (play/pause + barre + timers). %>
        <%# Les styles .audio-* sont définis dans _stories.scss %>
        <%# Audio réservé au Premium (OU 1re histoire offerte) — le TTS coûte de %>
        <%# l'argent à chaque génération. Un compte Essentiel n'a PAS l'audio. %>
        <%# Pour les comptes sans audio : pastille d'upsell à la place %>
        <%# (la vraie garde est côté serveur dans StoriesController#audio — 403) %>
        <% if current_user.audio_for?(@story) %>
        <div class="audio-player"
             data-controller="story-reader"
             data-story-id="<%= @story.id %>">

          <%# Bulle de temps "0:00 / 3:20" — visible pendant la lecture, lecteur replié %>
          <span class="audio-time-bubble" data-story-reader-target="bubble">0:00 / --:--</span>

          <%# Bouton flottant rond + anneau SVG de progression (état replié) %>
          <div class="audio-fab-wrap">
            <svg class="audio-fab-ring" viewBox="0 0 60 60">
              <%# Cercle de fond (piste grise) %>
              <circle class="audio-fab-ring-track" cx="30" cy="30" r="26"></circle>
              <%# Cercle de progression (doré) — stroke-dashoffset piloté par le JS %>
              <circle class="audio-fab-ring-fill" cx="30" cy="30" r="26"
                      data-story-reader-target="ring"></circle>
            </svg>

            <%# Bouton central — déplie le lecteur ET lance la lecture %>
            <button class="audio-fab-btn"
                    data-story-reader-target="fab"
                    data-action="click->story-reader#expandAndPlay"
                    title="<%= t("story_show.audio_play") %>">
              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>
          </div>

          <%# Panneau déplié — barre de lecture complète %>
          <div class="audio-panel">

            <%# Bouton Play — cercle doré plein %>
            <button data-story-reader-target="playBtn"
                    data-action="click->story-reader#play"
                    class="audio-panel-play"
                    title="<%= t("story_show.audio_play") %>">
              <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </button>

            <%# Bouton Pause — même position, masqué par défaut %>
            <button data-story-reader-target="pauseBtn"
                    data-action="click->story-reader#pause"
                    class="audio-panel-play d-none"
                    title="<%= t("story_show.audio_pause") %>">
              <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
            </button>

            <%# Zone centrale : label + barre + timers %>
            <div class="audio-panel-mid">
              <div class="audio-panel-label"><%= t("story_show.audio_label") %></div>

              <%# Badge "En préparation" — chargement visuel de l'audio %>
              <%# story_reader_controller le cache dès que l'audio est prêt (/status). %>
              <%# Toujours présent dans le DOM (caché "d-none" si l'audio principal est %>
              <%# déjà prêt) pour pouvoir le RÉAFFICHER après un choix interactif, %>
              <%# pendant que l'audio de la suite se génère. %>
              <div class="audio-panel-prep <%= "d-none" if @story.audio_file.attached? %>"
                   data-story-reader-target="preparingBadge">
                <span class="audio-panel-prep-dots">
                  <span></span><span></span><span></span>
                </span>
                <span><%= t("story_show.audio_preparing") %></span>
              </div>

              <%# Barre de progression cliquable %>
              <div class="audio-panel-track"
                   data-story-reader-target="track"
                   data-action="click->story-reader#seek">
                <div class="audio-panel-fill" data-story-reader-target="progressBar"></div>
              </div>

              <%# Timers : temps écoulé (gauche) / durée totale (droite) %>
              <div class="audio-panel-times">
                <span data-story-reader-target="currentTime">0:00</span>
                <span data-story-reader-target="totalTime">--:--</span>
              </div>
            </div>

            <%# Bouton ✕ — replie le lecteur (la lecture continue en fond) %>
            <button class="audio-panel-close"
                    data-action="click->story-reader#collapse"
                    title="<%= t("story_show.audio_stop") %>">&times;</button>

          </div>
        </div>
        <% else %>
          <%# Compte gratuit — pastille discrète qui présente la lecture vocale Premium %>
          <div class="audio-upsell">
            <%= link_to subscription_path, style: "display: inline-flex; align-items: center; gap: 0.5rem; color: #f0c97a; text-decoration: none; font-size: 0.85rem;" do %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <%= t("story_show.audio_premium_only") %>
            <% end %>
          </div>
        <% end %>

        <%# ── Note douce après la 1re histoire offerte (gratuit) ── %>
        <%# Apparaît UNIQUEMENT pour la 1re histoire d'un compte gratuit (welcome_story?) :
            elle a eu l'expérience complète (image + audio + interactif), on rappelle
            en douceur que Premium la conserve pour toutes les histoires. Ton informatif,
            pas de pression — l'upsell "fort" se fait sur la 2e histoire (texte seul). %>
        <% if !current_user.premium? && current_user.welcome_story?(@story) %>
          <div class="story-premium-hint">
            <%= t("story_show.premium_hint_before") %>
            <%= link_to t("story_show.premium_hint_link"), subscription_path, class: "story-premium-hint__link" %> ✨
          </div>
        <% end %>

        <%# ── MODE INTERACTIF — affiche le choix si disponible ── %>
        <% if @story.interactive? && @pending_choice %>
          <%# data-controller="story-choice" gère le choix sans rechargement de page %>
          <%# data-story-choice-status-url-value : URL de polling jusqu'à fin de génération %>
          <div class="interactive-choice"
               data-controller="story-choice"
               data-story-choice-status-url-value="<%= status_story_path(@story) %>"
               <%# Textes du spinner pendant la génération de la suite (i18n) %>
               data-story-choice-loading-sr-value="<%= t("story_show.choice_loading_sr") %>"
               data-story-choice-loading-title-value="<%= t("story_show.choice_loading_title") %>"
               data-story-choice-loading-hint-value="<%= t("story_show.choice_loading_hint") %>">

            <div class="text-center mb-4">
              <span class="interactive-choice-icon">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </span>
              <h3 class="interactive-choice-title"><%= t("story_show.decide") %></h3>
              <p class="interactive-choice-question"><%= @pending_choice.question %></p>
            </div>

            <div class="row g-3">
              <%# Option A — formulaire intercepté par story-choice#submit (pas de rechargement) %>
              <div class="col-md-6">
                <%= form_tag choose_story_path(@story), method: :post,
                      data: { action: "submit->story-choice#submit" } do %>
                  <input type="hidden" name="chosen_option" value="a">
                  <button type="submit" class="choice-option-btn">
                    <div class="choice-option-label"><%= t("story_show.option_a_label") %></div>
                    <div class="choice-option-text"><%= @pending_choice.option_a %></div>
                  </button>
                <% end %>
              </div>

              <%# Option B — même principe %>
              <div class="col-md-6">
                <%= form_tag choose_story_path(@story), method: :post,
                      data: { action: "submit->story-choice#submit" } do %>
                  <input type="hidden" name="chosen_option" value="b">
                  <button type="submit" class="choice-option-btn">
                    <div class="choice-option-label"><%= t("story_show.option_b_label") %></div>
                    <div class="choice-option-text"><%= @pending_choice.option_b %></div>
                  </button>
                <% end %>
              </div>
            </div>

          </div>

        <%# Si les choix ont tous été faits — résumé des décisions prises + bouton timeline alternative %>
        <% elsif @story.interactive? && @story.story_choices.resolved.any? %>
          <div class="story-continuation mb-4">
            <% @story.story_choices.resolved.ordered.each do |choice| %>

              <%# Résumé du choix effectué %>
              <div class="choice-result">
                <div class="choice-result-question">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;color:#4caf7d"><polyline points="20 6 9 17 4 12"/></svg><%= choice.question %>
                </div>
                <div class="choice-result-answer">→ <%= choice.chosen_text %></div>
              </div>

              <%# Continuation de l'histoire avec le choix effectué %>
              <% if choice.context_chosen.present? %>
                <div class="story-content-wrapper mb-3">
                  <%# Même rendu que l'histoire initiale (<p class="story-paragraph">) %>
                  <%# render_story_markdown échappe le HTML en interne (protection XSS) %>
                  <%= render_story_markdown(choice.context_chosen) %>
                </div>
              <% end %>

              <%# ── TIMELINE ALTERNATIVE ── %>
              <%# Calcule le label de l'option non choisie pour le bouton %>
              <% alternative_label = choice.chosen_option == "a" ? choice.option_b : choice.option_a %>
              <%# data-controller="story-alternative" gère le chargement async %>
              <div class="alternative-section"
                   data-controller="story-alternative"
                   data-story-alternative-url-value="<%= explore_alternative_story_path(@story) %>"
                   data-story-alternative-choice-id-value="<%= choice.id %>"
                   data-story-alternative-alternative-label-value="<%= alternative_label %>"
                   <%# Chaînes i18n utilisées par le JS (erreurs, label de fermeture, préfixe) %>
                   data-story-alternative-ask-prefix-value="<%= t("story_show.alternative_ask_prefix") %>"
                   data-story-alternative-hide-label-value="<%= t("story_show.alternative_hide") %>"
                   data-story-alternative-error-prefix-value="<%= t("story_show.alternative_error_prefix") %>"
                   data-story-alternative-error-unknown-value="<%= t("story_show.alternative_error_unknown") %>"
                   data-story-alternative-network-error-value="<%= t("story_show.alternative_network_error") %>">

                <%# Bouton — clique pour voir l'autre chemin %>
                <button class="alternative-btn"
                        data-story-alternative-target="btn"
                        data-action="click->story-alternative#toggle"
                        aria-expanded="false">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M18 6H5a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h13l4-3.5L18 6Z"/><path d="M12 12v7"/><path d="M12 19H7"/></svg><%= t("story_show.alternative_ask_prefix") %> "<%= alternative_label %>" ?
                </button>

                <%# Panel caché — visible après le clic %>
                <div class="alternative-panel" data-story-alternative-target="panel">

                  <%# En-tête du panel — indique la timeline alternative %>
                  <div class="alternative-header">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M18 6H5a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h13l4-3.5L18 6Z"/><path d="M12 12v7"/><path d="M12 19H7"/></svg>
                    <strong><%= t("story_show.alternative_timeline") %></strong> · <%= t("story_show.alternative_if_chosen") %> "<%= alternative_label %>"
                  </div>

                  <%# Spinner de chargement — visible pendant la requête IA %>
                  <div class="alternative-spinner" data-story-alternative-target="spinner" style="display:none">
                    <div class="alternative-spinner-dot"></div>
                    <span><%= t("story_show.alternative_loading") %></span>
                  </div>

                  <%# Zone d'insertion du contenu HTML renvoyé par l'API %>
                  <div class="alternative-content story-paragraph" data-story-alternative-target="content"></div>

                </div>
              </div>

            <% end %>
          </div>
        <% end %>

        <%# ── PARTAGE — lien public en lecture seule (acquisition) ── %>
        <%# Affiché uniquement pour une histoire terminée. %>
        <%# share_url : URL publique signée (voir Story#share_token) %>
        <%# Le destinataire n'a PAS besoin de compte pour lire l'histoire. %>
        <% if @story.completed? %>
          <% share_url = shared_story_url(token: @story.share_token) %>
          <%# Texte pré-rempli du message WhatsApp (u() encode pour l'URL) %>
          <% whatsapp_text = t("story_show.whatsapp_text", name: @story.child.name, url: share_url) %>

          <div class="story-share"
               data-controller="share"
               data-share-url-value="<%= share_url %>"
               <%# Texte de confirmation "Lien copié !" passé au JS (i18n) %>
               data-share-copied-value="<%= t("story_show.link_copied") %>">
            <p class="story-share-label"><%= t("story_show.share_label") %></p>
            <div class="story-share-actions">
              <%# Bouton WhatsApp — simple lien wa.me, ouvre l'app/onglet de partage %>
              <a href="https://wa.me/?text=<%= u(whatsapp_text) %>"
                 target="_blank"
                 rel="noopener"
                 class="story-share-btn story-share-btn--whatsapp">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.683-.967zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
                WhatsApp
              </a>
              <%# Bouton Copier le lien — géré par share_controller %>
              <button type="button"
                      class="story-share-btn story-share-btn--copy"
                      data-share-target="button"
                      data-action="click->share#copy">
                <%= t("story_show.copy_link") %>
              </button>
            </div>
          </div>
        <% end %>

        <%# ── Navigation de fin ── %>
        <%# Ligne 1 : Continuer l'aventure + Sauvegarder côte à côte %>
        <%# Ligne 2 : Nouvelle histoire (pleine largeur) %>
        <%# Ligne 3 : Mes histoires (pleine largeur) %>
        <%# Ligne 4 : Recommencer — UNIQUEMENT si l'histoire est interactive (avec choix) %>
        <div class="story-nav-footer">

          <%# ── Ligne 1 : CTA principale + Sauvegarder ── %>
          <% if @story.completed? %>
            <div class="story-nav-footer-top">

              <%# Continuer l'aventure (ou lien épisode suivant si déjà créé) %>
              <% if @story.has_sequel? %>
                <%= link_to story_path(@story.next_sequel),
                      class: "story-btn-continue" do %>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="m9 18 6-6-6-6"/></svg><%= t("story_show.episode", number: @story.episode_number + 1) %>
                <% end %>
              <% else %>
                <%= button_to continue_story_path(@story), method: :post, class: "story-btn-continue",
                      data: { turbo_confirm: t("story_show.continue_confirm", number: @story.episode_number + 1) } do %>
                  <%# Étoile ✦ immobile, qui tourne uniquement au survol (cohérent avec le site) %>
                  <span class="spin-star--hover" style="margin-right:5px">✦</span><%= t("story_show.continue_adventure") %>
                <% end %>
              <% end %>

              <%# Sauvegarder côte à côte avec Continuer l'aventure %>
              <% if @story.saved? %>
                <span class="story-btn-success">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><polyline points="20 6 9 17 4 12"/></svg><%= t("story_show.saved") %>
                </span>
              <% else %>
                <%= button_to save_story_story_path(@story), method: :post, class: "story-btn-warning" do %>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg><%= t("story_show.save") %>
                <% end %>
              <% end %>

            </div>
          <% end %>

          <%# ── Ligne 2 : Nouvelle histoire ── %>
          <%= link_to new_story_path, class: "story-btn-primary" do %>
            <%# Étoile ✦ immobile, qui tourne uniquement au survol (cohérent avec le site) %>
            <%# "Nouvelle histoire" partagé avec la bibliothèque (library.new_story) %>
            <span class="spin-star--hover" style="margin-right:5px">✦</span><%= t("library.new_story") %>
          <% end %>

          <%# ── Ligne 3 : Mes histoires ── %>
          <%= link_to stories_path, class: "story-btn-secondary" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg><%= t("story_show.my_stories") %>
          <% end %>

          <%# ── Ligne 4 : Recommencer — seulement pour les histoires interactives avec choix ── %>
          <%# Inutile pour une histoire standard sans choix : l'utilisateur relit la même chose %>
          <% if @story.completed? && @story.interactive? %>
            <%= button_to replay_story_path(@story), method: :post, class: "story-btn-replay",
                  data: { turbo_confirm: t("story_show.replay_confirm") } do %>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg><%= t("story_show.replay") %>
            <% end %>
          <% end %>

        </div>


      <% end %>
    </div>
  </div>
</div>
