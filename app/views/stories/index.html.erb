<%# ============================================================ %>
<%# Bibliothèque personnelle — toutes les histoires de l'utilisateur %>
<%# DA cosmique : cartes dark #111527, accents dorés #f0c97a %>
<%# ============================================================ %>

<%# Styles inline — DA cosmique pour la bibliothèque %>
<style nonce="<%= content_security_policy_nonce %>">
  /* ── Page wrapper ── */
  .lib-page { padding: 2.5rem 0 4rem; }

  /* ── En-tête — titre + bouton CTA ── */
  .lib-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  /* Titre Cormorant Garamond italic, crème */
  .lib-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(2rem, 5vw, 3rem);
    color: #fdf6e3;
    font-weight: 300;
    margin: 0 0 0.2rem;
    line-height: 1.1;
  }

  /* Sous-titre — nombre d'histoires en text-dim */
  .lib-subtitle { color: #8a8578; font-size: 0.9rem; margin: 0; }

  /* ── Bouton CTA principal — pill doré ── */
  .lib-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.5rem;
    background: #f0c97a;
    color: #0b0e1a;
    border: none;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease, transform 0.15s ease;
  }
  .lib-btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    color: #0b0e1a;
    text-decoration: none;
  }

  /* ── Bouton secondaire — outline doré ── */
  .lib-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: transparent;
    color: #f0c97a;
    border: 1px solid rgba(240, 201, 122, 0.35);
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .lib-btn-secondary:hover {
    background: rgba(240, 201, 122, 0.08);
    border-color: rgba(240, 201, 122, 0.6);
    color: #f0c97a;
    text-decoration: none;
  }

  /* ── Bouton danger — outline rouge discret ── */
  .lib-btn-danger {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: transparent;
    color: rgba(220, 100, 100, 0.9);
    border: 1px solid rgba(220, 80, 80, 0.4);
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .lib-btn-danger:hover {
    background: rgba(220, 80, 80, 0.1);
    color: rgba(220, 100, 100, 1);
  }
  .lib-btn-danger[type="submit"] { appearance: none; -webkit-appearance: none; }

  /* ── Grille de cartes ── */
  .lib-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ── Carte d'une histoire ── */
  /* Fond deep, bordure dorée, coins arrondis, pas de shadow Bootstrap */
  .lib-card {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.25s ease, transform 0.2s ease;
  }
  .lib-card:hover {
    border-color: rgba(240, 201, 122, 0.35);
    transform: translateY(-3px);
  }

  /* Zone image de couverture */
  .lib-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  /* Fallback quand il n'y a pas d'image — fond légèrement plus sombre, emoji centré */
  .lib-card-img-fallback {
    width: 100%;
    height: 180px;
    background: #1a1f3c;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    text-decoration: none;
  }

  /* Corps de la carte */
  .lib-card-body {
    padding: 1rem 1.25rem 0.75rem;
    flex: 1;
  }

  /* Ligne de badges (univers + interactif) */
  .lib-badges { display: flex; gap: 0.4rem; margin-bottom: 0.6rem; flex-wrap: wrap; }

  /* Pill badge universt */
  .lib-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.65rem;
    background: rgba(240, 201, 122, 0.1);
    border: 1px solid rgba(240, 201, 122, 0.25);
    border-radius: 50px;
    color: #f0c97a;
    font-size: 0.72rem;
    font-weight: 500;
  }

  /* Badge "interactif" — accent bleu-violet discret */
  .lib-badge-interactive {
    background: rgba(100, 120, 240, 0.12);
    border-color: rgba(100, 120, 240, 0.25);
    color: rgba(160, 180, 255, 0.9);
  }

  /* Badge "Épisode X" — accent turquoise discret pour les sagas */
  .lib-badge-episode {
    background: rgba(80, 200, 200, 0.1);
    border-color: rgba(80, 200, 200, 0.25);
    color: rgba(120, 220, 220, 0.9);
  }

  /* Titre de l'histoire */
  .lib-card-title {
    font-weight: 600;
    color: #d4cfc4;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
    text-decoration: none;
  }
  .lib-card-title:hover { color: #f0c97a; text-decoration: none; }

  /* Méta (enfant + date) */
  .lib-card-meta { color: #8a8578; font-size: 0.8rem; margin: 0; }

  /* Pied de carte — boutons */
  .lib-card-footer {
    padding: 0.75rem 1.25rem 1.25rem;
    display: flex;
    gap: 0.5rem;
    border-top: 1px solid rgba(240, 201, 122, 0.06);
  }

  /* ── État vide ── */
  .lib-empty {
    text-align: center;
    padding: 5rem 1rem;
  }
  .lib-empty-emoji { font-size: 5rem; display: block; margin-bottom: 1.5rem; opacity: 0.7; }
  .lib-empty h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.8rem;
    color: #fdf6e3;
    margin-bottom: 0.75rem;
  }
  .lib-empty p { color: #8a8578; margin-bottom: 2rem; }

  /* ── Responsive mobile ── */
  @media (max-width: 600px) {
    /* Page — padding horizontal ajouté pour aérer du bord */
    .lib-page { padding: 1.5rem 0.75rem 3rem; }

    /* En-tête — titre + bouton s'empilent verticalement, marge basse réduite */
    .lib-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }

    /* Titre — réduit la taille min du clamp */
    .lib-title { font-size: clamp(1.6rem, 6vw, 3rem); }

    /* Sous-titre — ajoute un peu d'espace sous le titre */
    .lib-subtitle { margin-top: 0.2rem; }

    /* Bouton "Nouvelle histoire" — largeur auto, taille compacte */
    .lib-btn-primary {
      width: auto;
      padding: 0.5rem 1.1rem;
      font-size: 0.85rem;
    }

    /* Grille — 1 colonne pleine largeur */
    .lib-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    /* Image de couverture — hauteur augmentée pour mieux voir le personnage */
    /* object-position à 20% du haut pour cadrer sur le visage sans couper */
    .lib-card-img {
      height: 170px;
      object-position: center 20%;
    }
    .lib-card-img-fallback { height: 170px; }

    /* Pied de carte — boutons plus grands, faciles à tapper */
    .lib-card-footer {
      padding: 0.75rem 1rem 1rem;
      gap: 0.6rem;
    }

    /* Boutons "Lire" et "Supprimer" — partagent la largeur à égalité */
    .lib-btn-secondary,
    .lib-btn-danger {
      flex: 1;
      justify-content: center;
      padding: 0.6rem 0.5rem;
      font-size: 0.88rem;
    }
  }
</style>

<div class="container lib-page">

  <%# ── En-tête ── %>
  <div class="lib-header">
    <div>
      <%# Titre Cormorant Garamond italic %>
      <h1 class="lib-title">Ma bibliothèque</h1>
      <%# Sous-titre avec le nombre d'histoires %>
      <p class="lib-subtitle">
        <%= @stories.count %> histoire<%= "s" if @stories.count > 1 %> dans ta bibliothèque
      </p>
    </div>
    <%# CTA pill doré — créer une nouvelle histoire %>
    <%= link_to new_story_path, class: "lib-btn-primary" do %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>Nouvelle histoire
    <% end %>
  </div>

  <% if @stories.any? %>
    <%# Grille de cartes — responsive 3/2/1 colonnes %>
    <div class="lib-grid">
      <% @stories.each do |story| %>
        <div class="lib-card">

          <%# Image de couverture ou fallback emoji -%>
          <% if story.cover_image.attached? %>
            <%# Image réelle — cliquable vers la lecture %>
            <%= link_to story_path(story) do %>
              <%= image_tag story.cover_image,
                    class: "lib-card-img",
                    alt: story.title %>
            <% end %>
          <% else %>
            <%# Fallback — fond sombre avec l'emoji de l'univers %>
            <%= link_to story_path(story), class: "lib-card-img-fallback" do %>
              <span><%= story.world_emoji %></span>
            <% end %>
          <% end %>

          <%# Corps : badges, titre, méta %>
          <div class="lib-card-body">

            <%# Badges : univers + mode interactif + numéro d'épisode %>
            <div class="lib-badges">
              <span class="lib-badge"><%= story.world_emoji %> <%= story.world_label %></span>
              <% if story.interactive? %>
                <span class="lib-badge lib-badge-interactive">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:3px"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="8" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="14" r="1" fill="currentColor" stroke="none"/><circle cx="16" cy="12" r="1" fill="currentColor" stroke="none"/></svg>Interactif
                </span>
              <% end %>
              <%# Badge épisode — affiché si l'histoire fait partie d'une saga %>
              <% if story.sequel? || story.has_sequel? %>
                <span class="lib-badge lib-badge-episode">
                  Ép. <%= story.episode_number %>
                </span>
              <% end %>
            </div>

            <%# Titre cliquable %>
            <%= link_to story.title || "Histoire sans titre", story_path(story),
                  class: "lib-card-title" %>

            <%# Méta : enfant associé + date de création %>
            <p class="lib-card-meta">
              Pour <%= story.child.name %> · <%= story.created_at.strftime("%d/%m/%Y") %>
            </p>
          </div>

          <%# Pied : bouton Lire + Supprimer %>
          <div class="lib-card-footer">
            <%= link_to "Lire", story_path(story), class: "lib-btn-secondary" %>
            <%= button_to "Supprimer", story_path(story),
                  method: :delete,
                  class: "lib-btn-danger",
                  data: { turbo_confirm: "Supprimer cette histoire définitivement ?" } %>
          </div>

        </div>
      <% end %>
    </div>

  <% else %>
    <%# État vide — aucune histoire %>
    <div class="lib-empty">
      <span class="lib-empty-emoji">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </span>
      <h2>Ta bibliothèque est vide</h2>
      <p>Génère ta première histoire magique en quelques secondes !</p>
      <%= link_to new_story_path, class: "lib-btn-primary" do %>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>Créer une histoire
      <% end %>
    </div>
  <% end %>

</div>
