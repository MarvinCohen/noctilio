<%# ============================================================ %>
<%# Bibliothèque personnelle — toutes les histoires de l'utilisateur %>
<%# DA cosmique : cartes dark #111527, accents dorés #f0c97a %>
<%# ============================================================ %>


<div class="container lib-page">

  <%# ── En-tête ── %>
  <div class="lib-header">
    <div>
      <%# Titre Cormorant Garamond italic %>
      <h1 class="lib-title"><%= t("library.title") %></h1>
      <%# Sous-titre dynamique selon l'onglet actif — pluralisation via I18n %>
      <p class="lib-subtitle">
        <% if @tab == "all" %>
          <%= t("library.count_all", count: @all_count) %>
        <% else %>
          <%= t("library.count_saved", count: @saved_count) %>
        <% end %>
      </p>
    </div>
    <%# CTA pill doré — créer une nouvelle histoire %>
    <%= link_to new_story_path, class: "lib-btn-primary" do %>
      <%# Étoile ✦ immobile, qui tourne uniquement au survol (variante spin-star--hover) %>
      <span class="spin-star--hover" style="margin-right:5px">✦</span><%= t("library.new_story") %>
    <% end %>
  </div>

  <%# ── Onglets Bibliothèque / Toutes ── %>
  <%# tab=saved (défaut) : histoires explicitement sauvegardées %>
  <%# tab=all : toutes les histoires terminées %>
  <div class="lib-tabs">
    <%= link_to stories_path,
          class: "lib-tab #{"lib-tab--active" if @tab == "saved"}" do %>
      <%# Icône marque-page %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
      <%= t("library.tab_saved") %>
      <span class="lib-tab-count"><%= @saved_count %></span>
    <% end %>
    <%= link_to stories_path(tab: "all"),
          class: "lib-tab #{"lib-tab--active" if @tab == "all"}" do %>
      <%# Icône horloge %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <%= t("library.tab_all") %>
      <span class="lib-tab-count"><%= @all_count %></span>
    <% end %>
  </div>

  <%# ── Section histoires échouées — affichée uniquement si certaines ont planté ── %>
  <% if @failed_stories.any? %>
    <div class="lib-failed-section">

      <%# Titre de section avec icône d'alerte %>
      <h2 class="lib-failed-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;flex-shrink:0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%# Pluralisation gérée par I18n (clés one / other) %>
        <%= t("library.failed_count", count: @failed_stories.count) %>
      </h2>

      <%# Liste compacte des histoires échouées — une ligne par histoire %>
      <div class="lib-failed-list">
        <% @failed_stories.each do |story| %>
          <div class="lib-failed-row">

            <%# Emoji univers + nom de l'enfant + paramètres de l'histoire %>
            <div class="lib-failed-info">
              <span class="lib-failed-emoji"><%= story.world_emoji %></span>
              <div>
                <span class="lib-failed-child"><%= t("library.for_child", name: story.child.name) %></span>
                <span class="lib-failed-meta">
                  <%= story.world_label %> · <%= story.image_style&.capitalize || t("library.auto_style") %> · <%= story.duration_minutes %> min
                  · <%= story.created_at.strftime("%d/%m") %>
                </span>
              </div>
            </div>

            <%# Actions : Réessayer + Supprimer %>
            <div class="lib-failed-actions">
              <%# Réessayer — remet en pending et relance le job %>
              <%= button_to t("library.retry"), retry_story_path(story),
                    method: :post,
                    class: "lib-btn-retry" %>

              <%# Supprimer — efface définitivement cette tentative %>
              <%= button_to t("library.delete"), story_path(story),
                    method: :delete,
                    class: "lib-btn-danger lib-btn-danger--sm",
                    data: { turbo_confirm: t("library.delete_attempt_confirm") } %>
            </div>

          </div>
        <% end %>
      </div>

    </div>
  <% end %>

  <% if @stories.any? %>
    <%# Grille de cartes — responsive 3/2/1 colonnes %>
    <div class="lib-grid">
      <% @stories.each do |story| %>
        <div class="lib-card">

          <%# Image de couverture ou fallback emoji -%>
          <% if story.cover_image.attached? %>
            <%# Image réelle — cliquable vers la lecture %>
            <%= link_to story_path(story) do %>
              <%= image_tag story.cover_image,
                    class: "lib-card-img",
                    alt: story.title %>
            <% end %>
          <% else %>
            <%# Fallback — fond sombre avec l'emoji de l'univers %>
            <%= link_to story_path(story), class: "lib-card-img-fallback" do %>
              <span><%= story.world_emoji %></span>
            <% end %>
          <% end %>

          <%# Corps : badges, titre, méta %>
          <div class="lib-card-body">

            <%# Badges : univers + mode interactif + numéro d'épisode %>
            <div class="lib-badges">
              <span class="lib-badge"><%= story.world_emoji %> <%= story.world_label %></span>
              <% if story.interactive? %>
                <span class="lib-badge lib-badge-interactive">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:3px"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="8" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="14" r="1" fill="currentColor" stroke="none"/><circle cx="16" cy="12" r="1" fill="currentColor" stroke="none"/></svg><%= t("library.interactive") %>
                </span>
              <% end %>
              <%# Badge épisode — affiché si l'histoire fait partie d'une saga %>
              <% if story.sequel? || story.has_sequel? %>
                <span class="lib-badge lib-badge-episode">
                  <%= t("library.episode", number: story.episode_number) %>
                </span>
              <% end %>
            </div>

            <%# Titre cliquable %>
            <%= link_to story.title || t("library.untitled"), story_path(story),
                  class: "lib-card-title" %>

            <%# Méta : enfant associé + date de création %>
            <p class="lib-card-meta">
              <%= t("library.for_child", name: story.child.name) %> · <%= story.created_at.strftime("%d/%m/%Y") %>
            </p>
          </div>

          <%# Pied : bouton Lire + Supprimer %>
          <div class="lib-card-footer">
            <%= link_to t("library.read"), story_path(story), class: "lib-btn-secondary" %>
            <%= button_to t("library.delete"), story_path(story),
                  method: :delete,
                  class: "lib-btn-danger",
                  data: { turbo_confirm: t("library.delete_story_confirm") } %>
          </div>

        </div>
      <% end %>
    </div>

  <% else %>
    <%# État vide — aucune histoire %>
    <div class="lib-empty">
      <span class="lib-empty-emoji">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </span>
      <h2><%= t("library.empty_title") %></h2>
      <p><%= t("library.empty_desc") %></p>
      <%= link_to new_story_path, class: "lib-btn-primary" do %>
        <%# Étoile ✦ immobile, qui tourne uniquement au survol (variante spin-star--hover) %>
        <span class="spin-star--hover" style="margin-right:5px">✦</span><%= t("library.create_story") %>
      <% end %>
    </div>
  <% end %>

</div>
