<%# ============================================================ %>
<%# Landing page Noctilio — pré-inscription liste d'attente %>
<%# Utilise le layout "landing" (sans sidebar/navbar) %>
<%# Le formulaire POST vers /waitlist via fetch() + CSRF token %>
<%# ============================================================ %>

<%# Curseur doré personnalisé %>
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<%# Canvas étoiles animées %>
<canvas id="stars-canvas"></canvas>

<%# Canvas sillage étoile filante — trail doré qui suit le curseur %>
<canvas id="trail-canvas"></canvas>

<%# NAV %>
<nav>
  <div class="nav-logo">
    <%# Mascotte hibou — SVG pour la netteté à toutes les résolutions %>
    <%= image_tag "mascot.svg", class: "nav-mascot", alt: "Noctilio" %>
    Noctilio
  </div>
  <div class="nav-actions">
    <div class="nav-badge"><%= t("home.nav_badge") %></div>
  </div>
</nav>

<%# HERO %>
<section class="hero">
  <%# Lune réelle — canvas dessiné en JS selon la phase lunaire du jour %>
  <%# data-phase transmis depuis PagesController (@moon_phase) %>
  <canvas id="landing-moon-canvas"
          class="moon"
          data-phase="<%= @moon_phase %>"
          width="120" height="120"
          aria-label="Phase de la lune ce soir"></canvas>

  <%# eyebrow, titre et sous-titre du hero — traduits via home.<locale>.yml %>
  <p class="hero-eyebrow"><%= t("home.hero.eyebrow") %></p>

  <%# title_html contient <em>/<br> : la clé se termine par _html donc Rails la rend html_safe %>
  <h1 class="hero-title">
    <%= t("home.hero.title_html") %>
  </h1>

  <p class="hero-sub">
    <%= t("home.hero.subtitle") %>
  </p>

  <%# Formulaire d'inscription — soumis via fetch() vers POST /waitlist %>
  <div class="form-wrap">
    <div class="form-inner" id="formInner">
      <input
        class="form-input"
        type="email"
        id="emailInput"
        placeholder="<%= t("home.hero.email_placeholder") %>"
        autocomplete="email"
      >
      <%# onclick retiré — l'événement est branché via addEventListener dans le script (scoping JS) %>
      <button class="form-btn" id="submitBtn">
        <%= t("home.hero.cta") %>
      </button>
    </div>

    <%# Message d'erreur (format invalide ou email déjà inscrit) %>
    <p class="form-error" id="formError"></p>

    <%# Message de succès affiché après inscription réussie %>
    <div class="success-msg" id="successMsg">
      <%= t("home.hero.success") %>
    </div>

    <p class="form-note"><%= t("home.hero.note") %></p>
  </div>

  <%# Compteur — @waitlist_count est le vrai chiffre en base (controller) %>
  <%# On affiche au moins 247 pour que ça soit crédible dès le début %>
  <div class="counter-wrap">
    <div class="counter-avatars">
      <%# Lune %>
      <div class="avatar avatar-1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
      </div>
      <%# Étoile %>
      <div class="avatar avatar-2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
      </div>
      <%# Hibou %>
      <div class="avatar avatar-3">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8 2 5 5 5 9c0 2.5 1.2 4.7 3 6.1V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-1.9c1.8-1.4 3-3.6 3-6.1 0-4-3-7-7-7z"/><circle cx="9" cy="9" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="9" r="1" fill="currentColor" stroke="none"/><path d="M10 13h4"/></svg>
      </div>
      <%# Étincelle %>
      <div class="avatar avatar-4">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
      </div>
    </div>
    <p class="counter-text">
      <strong id="counter"><%= [@waitlist_count, 247].max %></strong>
      <%= t("home.hero.counter_suffix") %>
    </p>
  </div>
</section>

<div class="divider"></div>

<%# FEATURES %>
<section class="features">
  <div class="features-grid">
    <%# Feature 1 — Personnalisée : icône enfant + étincelles %>
    <div class="feature-card">
      <div class="feature-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
        </svg>
      </div>
      <div class="feature-text">
        <h3 class="feature-title"><%= t("home.features.personalised.title") %></h3>
        <p class="feature-desc"><%= t("home.features.personalised.desc") %></p>
      </div>
    </div>

    <%# Feature 2 — Racontée : icône micro %>
    <div class="feature-card">
      <div class="feature-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="2" width="6" height="11" rx="3"/>
          <path d="M5 10a7 7 0 0 0 14 0"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="9" y1="22" x2="15" y2="22"/>
        </svg>
      </div>
      <div class="feature-text">
        <h3 class="feature-title"><%= t("home.features.narrated.title") %></h3>
        <p class="feature-desc"><%= t("home.features.narrated.desc") %></p>
      </div>
    </div>

    <%# Feature 3 — En quelques secondes : icône éclair %>
    <div class="feature-card">
      <div class="feature-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      </div>
      <div class="feature-text">
        <h3 class="feature-title"><%= t("home.features.fast.title") %></h3>
        <p class="feature-desc"><%= t("home.features.fast.desc") %></p>
      </div>
    </div>
  </div>
</section>

<%# Trait vertical de séparation après les feature cards %>
<div class="divider"></div>

<%# ============================================================ %>
<%# Section "Comment ça marche" — 3 étapes claires %>
<%# Objectif SEO : augmenter le volume de texte utile et indexable %>
<%# pour les requêtes "histoires personnalisées enfants IA" %>
<%# ============================================================ %>
<section class="how-section">
  <div class="how-inner">

    <p class="how-eyebrow"><%= t("home.how.eyebrow") %></p>
    <h2 class="how-title"><%= t("home.how.title") %></h2>

    <div class="how-steps">

      <%# Étape 1 — Créer le profil de l'enfant %>
      <div class="how-step">
        <div class="how-num">1</div>
        <div>
          <h3 class="how-step-title"><%= t("home.how.step1_title") %></h3>
          <p class="how-step-desc">
            <%= t("home.how.step1_desc") %>
          </p>
        </div>
      </div>

      <%# Étape 2 — Génération par l'IA %>
      <div class="how-step">
        <div class="how-num">2</div>
        <div>
          <h3 class="how-step-title"><%= t("home.how.step2_title") %></h3>
          <p class="how-step-desc">
            <%= t("home.how.step2_desc") %>
          </p>
        </div>
      </div>

      <%# Étape 3 — Lecture ou écoute au coucher %>
      <div class="how-step">
        <div class="how-num">3</div>
        <div>
          <h3 class="how-step-title"><%= t("home.how.step3_title") %></h3>
          <p class="how-step-desc">
            <%= t("home.how.step3_desc") %>
          </p>
        </div>
      </div>

    </div>

    <%# Paragraphe de clôture — résumé SEO de la proposition de valeur %>
    <%# closing_html contient des <strong> : clé _html donc rendue html_safe %>
    <div class="how-closing">
      <%= t("home.how.closing_html") %>
    </div>

    <%# Lien vers le blog — maillage interne + invitation à en savoir plus %>
    <%# Permet à Google de découvrir le blog depuis la page d'autorité principale %>
    <div style="text-align: center; margin-top: 2rem;">
      <%= link_to blog_path,
            style: "font-size:0.85rem; color:rgba(240,201,122,0.7); text-decoration:none; letter-spacing:0.04em; border-bottom:1px solid rgba(240,201,122,0.3); padding-bottom:2px;" do %>
        <%= t("home.how.blog_link") %>
      <% end %>
    </div>

  </div>
</section>

<%# FOOTER — partial partagé avec le reste du site %>
<%= render 'shared/footer' %>

<script nonce="<%= content_security_policy_nonce %>">
  // Messages du formulaire traduits côté serveur (home.<locale>.yml) puis
  // sérialisés en JSON pour être lisibles depuis le JavaScript sans risque XSS.
  const I18N = <%= raw({
    invalid_email: t("home.form_js.invalid_email"),
    subscribed:    t("home.form_js.subscribed"),
    already:       t("home.form_js.already"),
    error:         t("home.form_js.error"),
    connection:    t("home.form_js.connection"),
    cta:           t("home.hero.cta")
  }.to_json) %>;

  // Encapsulé dans load pour garantir que tout le DOM est prêt
  window.addEventListener('load', function() {

  // ============================================================
  // Chaque module ci-dessous est isolé dans son PROPRE try/catch.
  // Si l'un plante (ex: Safari sur une API canvas), les autres continuent
  // de fonctionner. Avant, un seul try/catch global cassait TOUT au premier
  // plantage : curseur figé, étoiles invisibles, bouton waitlist inactif.
  // ============================================================

  // ── Module Lune — dessin de la phase lunaire sur canvas ──
  // data-phase est injecté par Rails depuis PagesController (@moon_phase)
  try {
    const landingMoon = document.getElementById('landing-moon-canvas');
    if (landingMoon) {
      const phase = parseFloat(landingMoon.dataset.phase || '0.5');
      drawMoonPhase(landingMoon, phase);
    }
  } catch (e) { console.error('Noctilio [lune]:', e); }

  // ── Module Curseur personnalisé — point doré + anneau avec délai ──
  try {
    const cursorEl = document.getElementById('cursor');
    const ringEl   = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (cursorEl && ringEl) {
      // On masque le curseur natif SEULEMENT maintenant que le curseur doré
      // est bien initialisé. Si ce module avait planté, .custom-cursor ne serait
      // jamais ajoutée → la souris native resterait visible (pas de "souris perdue").
      document.body.classList.add('custom-cursor');

      document.addEventListener('mousemove', e => {
        mx = e.clientX; my = e.clientY;
        cursorEl.style.left = mx + 'px';
        cursorEl.style.top  = my + 'px';
      });

      // L'anneau suit avec un léger retard (interpolation)
      function animateRing() {
        rx += (mx - rx) * 0.12;
        ry += (my - ry) * 0.12;
        ringEl.style.left = rx + 'px';
        ringEl.style.top  = ry + 'px';
        requestAnimationFrame(animateRing);
      }
      animateRing();

      // Agrandit le curseur sur les éléments interactifs
      document.querySelectorAll('button, a, input').forEach(el => {
        el.addEventListener('mouseenter', () => {
          cursorEl.style.width = '12px'; cursorEl.style.height = '12px';
          ringEl.style.width   = '48px'; ringEl.style.height   = '48px';
        });
        el.addEventListener('mouseleave', () => {
          cursorEl.style.width = '8px'; cursorEl.style.height = '8px';
          ringEl.style.width   = '32px'; ringEl.style.height   = '32px';
        });
      });
    }
  } catch (e) { console.error('Noctilio [curseur]:', e); }

  // ── Module Sillage — trail doré qui suit le curseur ──
  try {
  const trailCanvas = document.getElementById('trail-canvas');
  const trailCtx    = trailCanvas.getContext('2d');

  // Adapte le canvas à la taille de la fenêtre
  function resizeTrail() {
    trailCanvas.width  = window.innerWidth;
    trailCanvas.height = window.innerHeight;
  }
  resizeTrail();
  // Même logique : on ignore les resize causés par le chrome mobile (hauteur seule)
  let lastTrailWidth = window.innerWidth;
  let resizeTrailTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTrailTimer);
    resizeTrailTimer = setTimeout(() => {
      if (Math.abs(window.innerWidth - lastTrailWidth) > 10) {
        lastTrailWidth = window.innerWidth;
        resizeTrail();
      }
    }, 250);
  });

  // Tableau des particules du sillage — chaque entrée = une position passée du curseur
  let trailParticles = [];

  // À chaque mouvement de souris, on ajoute une particule avec position, taille et opacité initiale
  document.addEventListener('mousemove', e => {
    trailParticles.push({
      x:     e.clientX,
      y:     e.clientY,
      r:     Math.random() * 2 + 1,   // rayon aléatoire entre 1 et 3px
      alpha: 0.7                       // opacité de départ
    });
    // On garde au maximum 40 particules pour ne pas surcharger
    if (trailParticles.length > 40) trailParticles.shift();
  });

  // Dessine le sillage à chaque frame
  // Quand la souris s'arrête, chaque particule perd de l'opacité progressivement
  // jusqu'à disparaître complètement — le sillage s'efface naturellement
  function drawTrail() {
    trailCtx.clearRect(0, 0, trailCanvas.width, trailCanvas.height);

    // Diminue l'opacité de chaque particule à chaque frame (vitesse d'estompage)
    // 0.03 = disparition en ~23 frames (~380ms à 60fps) — ajuste pour accélérer/ralentir
    trailParticles.forEach(p => { p.alpha -= 0.03; });

    // Supprime les particules dont l'opacité est tombée à zéro ou en dessous
    trailParticles = trailParticles.filter(p => p.alpha > 0);

    trailParticles.forEach((p, i) => {
      // Plus la particule est ancienne (petit index), plus elle est petite
      const progress = i / Math.max(trailParticles.length, 1);
      const radius   = p.r * progress;

      trailCtx.beginPath();
      trailCtx.arc(p.x, p.y, radius, 0, Math.PI * 2);
      trailCtx.fillStyle = `rgba(240, 201, 122, ${p.alpha})`;
      trailCtx.fill();
    });
    requestAnimationFrame(drawTrail);
  }
  drawTrail();
  } catch (e) { console.error('Noctilio [sillage]:', e); }

  // ── Module Étoiles animées — canvas en arrière-plan ──
  try {
  const canvas = document.getElementById('stars-canvas');
  const ctx    = canvas.getContext('2d');
  let stars    = [];

  // Prend en compte le ratio pixel de l'écran (Retina = 2x)
  // Sans ça, les étoiles sont sub-pixel et invisibles sur Mac/iOS
  function resize() {
    const dpr     = window.devicePixelRatio || 1;
    canvas.width  = window.innerWidth  * dpr;
    canvas.height = window.innerHeight * dpr;
  }

  function createStars() {
    const dpr = window.devicePixelRatio || 1;
    stars = [];
    // 300 étoiles — rayon plus grand pour être visible sur Retina
    for (let i = 0; i < 300; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        r: (Math.random() * 1.5 + 0.8) * dpr,
        speed: Math.random() * 0.005 + 0.002,
        phase: Math.random() * Math.PI * 2
      });
    }
  }

  function drawStars(t) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach(s => {
      const a = 0.4 + 0.5 * Math.sin(s.phase + t * s.speed);
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(240, 201, 122, ${a})`;
      ctx.fill();
    });
    starsFrame = requestAnimationFrame(drawStars);
  }

  resize(); createStars();
  let starsFrame = requestAnimationFrame(drawStars);

  // Sur mobile, le resize se déclenche quand la barre d'adresse se cache pendant le scroll
  // On ignore les changements de hauteur seuls (typique du chrome mobile)
  // et on débounce pour ne pas recréer les étoiles à chaque pixel de scroll
  let lastStarWidth = window.innerWidth;
  let resizeStarsTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeStarsTimer);
    resizeStarsTimer = setTimeout(() => {
      // Ne recrée les étoiles que si la LARGEUR a changé (vrai resize ou rotation)
      if (Math.abs(window.innerWidth - lastStarWidth) > 10) {
        lastStarWidth = window.innerWidth;
        resize();
        createStars();
      }
    }, 250);
  });

  // Pause quand l'onglet est en arrière-plan — économise CPU/batterie sur mobile
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') {
      cancelAnimationFrame(starsFrame);
      starsFrame = null;
    } else if (!starsFrame) {
      starsFrame = requestAnimationFrame(drawStars);
    }
  });
  } catch (e) { console.error('Noctilio [étoiles]:', e); }

  // ── Module Formulaire — soumission fetch() vers POST /waitlist ──
  try {
  // Le token CSRF est requis par Rails pour toute requête POST non-Turbo
  function getCsrfToken() {
    return document.querySelector('meta[name="csrf-token"]')?.content;
  }

  async function handleSubmit() {
    const email   = document.getElementById('emailInput').value.trim();
    const btn     = document.getElementById('submitBtn');
    const errorEl = document.getElementById('formError');

    // Validation côté client — format email basique
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      showError(I18N.invalid_email);
      document.getElementById('emailInput').classList.add('invalid');
      setTimeout(() => document.getElementById('emailInput').classList.remove('invalid'), 400);
      return;
    }

    // Désactive le bouton pendant l'envoi
    btn.disabled = true;
    btn.textContent = '...';

    try {
      // POST vers /waitlist avec le token CSRF Rails
      // waitlist_path est sérialisé en JSON pour éviter les injections XSS
      // raw() empêche ERB d'échapper les guillemets en &quot; dans le script
      const response = await fetch(<%= raw(waitlist_path.to_json) %>, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken()
        },
        body: JSON.stringify({ email: email })
      });

      const data = await response.json();

      if (data.success) {
        // Succès : transforme le bouton en confirmation (reste désactivé)
        btn.disabled = true;
        btn.textContent = I18N.subscribed;
        document.getElementById('emailInput').disabled = true;
        errorEl.classList.remove('show');
        // Affiche aussi le message de bienvenue sous le formulaire
        document.getElementById('successMsg').classList.add('show');

        // Anime le compteur jusqu'au nouveau chiffre réel
        animateCounter(data.count);
      } else if (data.already_subscribed) {
        // Email déjà en base : transforme le bouton, sans le réactiver
        // (inutile de réessayer puisque l'email est déjà inscrit)
        btn.disabled = true;
        btn.textContent = I18N.already;
        document.getElementById('emailInput').disabled = true;
        errorEl.classList.remove('show');
      } else {
        // Autre erreur serveur (format, etc.) : message + bouton réactivé
        showError(data.error || I18N.error);
        btn.disabled = false;
        btn.textContent = I18N.cta;
      }
    } catch (err) {
      showError(I18N.connection);
      btn.disabled = false;
      btn.textContent = I18N.cta;
    }
  }

  // Affiche un message d'erreur sous le formulaire
  function showError(message) {
    const el = document.getElementById('formError');
    el.textContent = message;
    el.classList.add('show');
  }

  // Anime le compteur un par un jusqu'au chiffre cible
  function animateCounter(target) {
    const el = document.getElementById('counter');
    let current = parseInt(el.textContent);
    const step = () => {
      if (current < target) { current++; el.textContent = current; setTimeout(step, 80); }
    };
    setTimeout(step, 600);
  }

  // Soumission au clic sur le bouton — branché ici car handleSubmit() est dans cette closure
  const submitBtn = document.getElementById('submitBtn');
  if (submitBtn) submitBtn.addEventListener('click', handleSubmit);

  // Soumission au clavier (touche Entrée)
  const emailInput = document.getElementById('emailInput');
  if (emailInput) emailInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') handleSubmit();
  });
  } catch (e) { console.error('Noctilio [formulaire]:', e); }

  }); // fin window.load

// ============================================================
// drawMoonPhase — dessine la phase lunaire sur un canvas
// phase : 0.0 = nouvelle lune, 0.5 = pleine lune, 1.0 = nouvelle lune
// Vue depuis l'hémisphère nord (France) : croissant éclairé à droite en phase croissante
// ============================================================
function drawMoonPhase(canvas, phase) {
  const dpr  = window.devicePixelRatio || 1;
  const size = canvas.getBoundingClientRect().width || 120;

  // Adapte la résolution pour les écrans Retina (Mac → devicePixelRatio = 2)
  canvas.width  = size * dpr;
  canvas.height = size * dpr;
  canvas.style.width  = size + 'px';
  canvas.style.height = size + 'px';

  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr); // Toutes les coords en CSS pixels

  const r  = size / 2;
  const cx = r;
  const cy = r;

  // Palette — identique au dashboard
  const litColor  = '#fff9e6'; // Crème — face éclairée
  const darkColor = '#0b0e1a'; // Nuit profonde — face sombre

  // Fraction d'illumination visible : 0 = nouvelle lune, 1 = pleine lune
  const illum = (1 - Math.cos(2 * Math.PI * phase)) / 2;

  // ── 1. Disque sombre de base ────────────────────────────────────────
  ctx.beginPath();
  ctx.arc(cx, cy, r - 1, 0, 2 * Math.PI);
  ctx.fillStyle = darkColor;
  ctx.fill();

  // Nouvelle lune = disque noir — halo géré par CSS filter, pas de dessin ici
  if (phase < 0.01 || phase > 0.99) { return; }

  // ── 2. Zone éclairée ────────────────────────────────────────────────
  // Technique : demi-cercle (côté éclairé) + ellipse terminateur
  // Hémisphère nord (France) :
  //   Lune croissante  (0 → 0.5) : lumière à droite
  //   Lune décroissante (0.5 → 1) : lumière à gauche
  const isWaxing = phase < 0.5;

  ctx.save();
  ctx.beginPath();

  if (isWaxing) {
    // Demi-cercle droit (arc du bas vers le haut en passant par la droite)
    ctx.arc(cx, cy, r - 1, Math.PI / 2, -Math.PI / 2, false);
    // Terminateur : ellipse dont le rayon X varie de r (0°) à 0 (90°) à -r (180°)
    const tx = r * Math.cos(phase * 2 * Math.PI);
    if (tx >= 0) {
      // Croissant (0→0.25) : terminateur courbe vers la droite, réduit la zone éclairée
      ctx.ellipse(cx, cy, tx, r - 1, 0, Math.PI / 2, -Math.PI / 2, false);
    } else {
      // Gibbeuse croissante (0.25→0.5) : terminateur courbe vers la gauche, agrandit
      ctx.ellipse(cx, cy, Math.abs(tx), r - 1, 0, -Math.PI / 2, Math.PI / 2, false);
    }
  } else {
    // Demi-cercle gauche (arc du bas vers le haut en passant par la gauche)
    ctx.arc(cx, cy, r - 1, -Math.PI / 2, Math.PI / 2, false);
    const tx = r * Math.cos(phase * 2 * Math.PI);
    if (tx <= 0) {
      // Gibbeuse décroissante (0.5→0.75)
      ctx.ellipse(cx, cy, Math.abs(tx), r - 1, 0, Math.PI / 2, -Math.PI / 2, false);
    } else {
      // Croissant décroissant (0.75→1)
      ctx.ellipse(cx, cy, tx, r - 1, 0, -Math.PI / 2, Math.PI / 2, false);
    }
  }

  ctx.closePath();
  ctx.fillStyle = litColor;
  ctx.fill();
  ctx.restore();

  // ── 3. Texture de volume ─────────────────────────────────────────────
  // Gradient interne qui donne du relief à la face éclairée
  const volGrad = ctx.createRadialGradient(
    cx - r * 0.2, cy - r * 0.2, r * 0.05,
    cx, cy, r
  );
  volGrad.addColorStop(0, 'rgba(255,255,255,0.18)');
  volGrad.addColorStop(1, 'rgba(200,148,58,0.22)'); // Bord doré chaud

  ctx.save();
  ctx.globalCompositeOperation = 'source-atop'; // S'applique uniquement sur le dessin existant
  ctx.beginPath();
  ctx.arc(cx, cy, r - 1, 0, 2 * Math.PI);
  ctx.fillStyle = volGrad;
  ctx.fill();
  ctx.restore();

  // ── 4. Halo extérieur — appliqué via CSS filter (drop-shadow) ───────────
  // drop-shadow s'applique EN DEHORS du canvas → pas de rectangle visible aux coins
  const glowSize    = Math.round(illum * 20 + 6);                  // 6px (nouvelle) → 26px (pleine)
  const glowOpacity = (illum * 0.55).toFixed(2);                   // 0 → 0.55
  canvas.style.filter = `drop-shadow(0 0 ${glowSize}px rgba(240,201,122,${glowOpacity}))`;
}

</script>

