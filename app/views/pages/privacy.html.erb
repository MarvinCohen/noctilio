  .legal-page {
    min-height: 100vh;
    padding: 3rem 1.5rem;
    background: var(--bg-app, #0f1021);
  }
  .legal-container { max-width: 760px; margin: 0 auto; }
  .legal-header { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(240, 201, 122, 0.15); }
  .legal-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 300; font-style: italic; color: #f0c97a; margin: 0 0 0.5rem; }
  .legal-date { font-size: 0.82rem; color: rgba(138, 133, 120, 0.7); margin: 0; }
  .legal-section { margin-bottom: 2.5rem; }
  .legal-section h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 600; color: #d4cfc4; margin: 0 0 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid rgba(240, 201, 122, 0.1); }
  .legal-content p, .legal-content li { font-family: 'Lora', Georgia, serif; font-size: 0.95rem; color: #a8a29a; line-height: 1.85; margin-bottom: 0.75rem; }
  .legal-content ul { padding-left: 1.5rem; margin-bottom: 0.75rem; }
  .legal-content strong { color: #d4cfc4; font-weight: 600; }
  .legal-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(240, 201, 122, 0.1); }
  .legal-back-btn { font-size: 0.88rem; color: rgba(138, 133, 120, 0.7); text-decoration: none; }
  .legal-back-btn:hover { color: #f0c97a; }
  .legal-link { font-size: 0.88rem; color: rgba(240, 201, 122, 0.6); text-decoration: none; }
  .legal-link:hover { color: #f0c97a; }
</style>
