<%# ============================================================ %>
<%# À propos — page fondateur Noctilio %>
<%# Objectif SEO : signaux E-E-A-T (Experience, Expertise, %>
<%#   Authoritativeness, Trustworthiness) pour Google QRG %>
<%# Référencée dans author.url des articles de blog %>
<%# Layout : application (navbar visiteur + footer) %>
<%# ============================================================ %>

<%# SEO — titre, description et directive robots %>
<% content_for :title, t("about.meta_title") %>
<% content_for :description, t("about.meta_description") %>
<% content_for :robots, "index, follow" %>

<%# Schema.org Person — données structurées pour les AI Overviews et rich results %>
<%# @type Person : signal d'auteur humain réel derrière le contenu %>
<%# sameAs : lie ce profil aux présences sociales vérifiables (signal de confiance) %>
<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Marvin Cohen",
    "jobTitle": "<%= t('about.schema_job_title') %>",
    "description": "<%= t('about.schema_description') %>",
    "url": "<%= localized_url_for('/a-propos', I18n.locale) %>",
    "image": "https://www.noctilio-app.fr/og-image.jpg",
    "knowsAbout": [
      "Ruby on Rails",
      "Intelligence artificielle",
      "Llama 3.3",
      "Histoires pour enfants",
      "Développement web"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "Noctilio",
      "url": "https://www.noctilio-app.fr"
    },
    "sameAs": [
      "https://www.instagram.com/noctilioapp",
      "https://www.tiktok.com/@Noctili5",
      "https://www.facebook.com/profile.php?id=61575427511719"
    ]
  }
  </script>
<% end %>

<%# ────────────────────────────────────────────────────── %>
<%# Conteneur principal — même style que les pages légales %>
<%# ────────────────────────────────────────────────────── %>
<%# padding-left/right : marge latérale sur mobile et desktop %>
<div class="legal-page" style="padding-left: 1.5rem; padding-right: 1.5rem;">
  <div class="legal-container">

    <%# ── En-tête — nom + rôle ── %>
    <div class="legal-header">
      <h1 class="legal-title"><%= t("about.header_title") %></h1>
      <%# Sous-titre court — renforce immédiatement l'identité de l'auteur %>
      <p class="legal-date"><%= t("about.header_subtitle") %></p>
    </div>

    <div class="legal-content">

      <%# ── Section 1 : Qui je suis ── %>
      <%# Signal E-E-A-T "Experience" : parcours personnel concret %>
      <section class="legal-section">
        <h2><%= t("about.who_title") %></h2>
        <p><%= t("about.who_p1") %></p>
        <%# Clé _html : contient une balise <em> de confiance (marquée html_safe automatiquement) %>
        <p><%= t("about.who_p2_html") %></p>
      </section>

      <%# ── Section 2 : Pourquoi Noctilio ── %>
      <%# Signal E-E-A-T "Experience" : motivation authentique, contexte réel %>
      <section class="legal-section">
        <h2><%= t("about.why_title") %></h2>
        <p><%= t("about.why_p1") %></p>
        <p><%= t("about.why_p2") %></p>
        <%# Clé _html : contient une balise <em> de confiance (marquée html_safe automatiquement) %>
        <p><%= t("about.why_p3_html") %></p>
      </section>

      <%# ── Section 3 : La technologie ── %>
      <%# Signal E-E-A-T "Expertise" : transparence sur les outils utilisés %>
      <section class="legal-section">
        <h2><%= t("about.tech_title") %></h2>
        <p><%= t("about.tech_intro") %></p>
        <ul>
          <%# Chaque <li> utilise une clé _html : contient une balise <strong> de confiance %>
          <%# Ruby on Rails 8 avec Solid Queue pour les jobs en arrière-plan %>
          <li><%= t("about.tech_rails_html") %></li>
          <%# Llama 3.3 70B (via Groq) pour la génération de texte personnalisé %>
          <li><%= t("about.tech_gpt_html") %></li>
          <%# gpt-image-1 pour les illustrations %>
          <li><%= t("about.tech_image_html") %></li>
          <%# PostgreSQL + ActiveStorage pour les données et images %>
          <li><%= t("about.tech_db_html") %></li>
        </ul>
        <p><%= t("about.tech_privacy") %></p>
      </section>

      <%# ── Section 4 : Mes valeurs ── %>
      <%# Signal E-E-A-T "Trustworthiness" : engagement envers la sécurité des enfants %>
      <section class="legal-section">
        <h2><%= t("about.values_title") %></h2>
        <ul>
          <%# Chaque <li> utilise une clé _html : contient une balise <strong> de confiance %>
          <li><%= t("about.values_safety_html") %></li>
          <li><%= t("about.values_transparency_html") %></li>
          <li><%= t("about.values_privacy_html") %></li>
          <li><%= t("about.values_improvement_html") %></li>
        </ul>
      </section>

      <%# ── Section 5 : Contact ── %>
      <%# Signal E-E-A-T "Trustworthiness" : joignabilité réelle de l'auteur %>
      <section class="legal-section">
        <h2><%= t("about.contact_title") %></h2>
        <p><%= t("about.contact_p1") %></p>
        <%# Clé _html : contient l'email en <strong> (signal de confiance fort) %>
        <p><%= t("about.contact_p2_html") %></p>
        <%# Icônes réseaux sociaux — même SVG inline que le footer %>
        <div style="display: flex; gap: 1rem; margin-top: 0.75rem;">
          <a href="https://www.instagram.com/noctilioapp"
             target="_blank" rel="noopener noreferrer"
             aria-label="Noctilio sur Instagram"
             style="color: #f0c97a; display: flex; align-items: center; gap: 0.4rem; text-decoration: none;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
            Instagram
          </a>
          <a href="https://www.tiktok.com/@Noctili5"
             target="_blank" rel="noopener noreferrer"
             aria-label="Noctilio sur TikTok"
             style="color: #f0c97a; display: flex; align-items: center; gap: 0.4rem; text-decoration: none;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.95a8.2 8.2 0 0 0 4.78 1.52V7.03a4.85 4.85 0 0 1-1.01-.34z"/>
            </svg>
            TikTok
          </a>
        </div>
        <p style="margin-top: 1rem;"></p>
        <p><%= t("about.contact_response") %></p>
      </section>

      <%# ── CTA — si connecté : dashboard ; sinon : inscription ── %>
      <%# Évite l'erreur Devise "already_authenticated" pour les utilisateurs connectés %>
      <section class="legal-section" style="text-align: center; padding-top: 1rem;">
        <%= link_to user_signed_in? ? t("about.cta_logged_in") : t("about.cta_logged_out"),
              user_signed_in? ? new_story_path : new_user_registration_path,
              style: "display: inline-block; padding: 0.8rem 2rem; background: #f0c97a;
                      color: #0b0e1a; font-weight: 600; border-radius: 8px;
                      text-decoration: none; font-size: 1rem;" %>
      </section>

    </div>
  </div>
</div>

<%# ── CSS — identique aux pages légales (cgu, confidentialité, mentions) ── %>
<%# Sans ce bloc, la page À propos n'avait aucun style (classes .legal-* non définies) %>
<style>
  /* Conteneur pleine hauteur, fond sombre de l'app */
  .legal-page {
    min-height: 100vh;
    padding: 3rem 1.5rem;
    background: var(--bg-app, #0b0e1a);
  }
  .legal-container { max-width: 760px; margin: 0 auto; }

  /* En-tête centré avec séparateur doré */
  .legal-header { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(240, 201, 122, 0.15); }
  .legal-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 300; font-style: italic; color: #f0c97a; margin: 0 0 0.5rem; }
  .legal-date { font-size: 0.82rem; color: rgba(138, 133, 120, 0.7); margin: 0; }

  /* Sections — titres h2 en doré (cohérent avec les pages légales) */
  .legal-section { margin-bottom: 2.5rem; }
  .legal-section h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 600; color: #f0c97a; margin: 0 0 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid rgba(240, 201, 122, 0.1); }

  /* Corps de texte — police lisible, gris doux */
  .legal-content p, .legal-content li { font-family: 'Lora', Georgia, serif; font-size: 0.95rem; color: #a8a29a; line-height: 1.85; margin-bottom: 0.75rem; }
  .legal-content ul { padding-left: 1.5rem; margin-bottom: 0.75rem; }
  .legal-content strong { color: #d4cfc4; font-weight: 600; }
</style>
