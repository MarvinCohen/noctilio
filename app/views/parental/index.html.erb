<%# ============================================================ %>
<%# Dashboard parental — statistiques et suivi de lecture %>
<%# DA cosmique : fond sombre #111527, accents dorés #f0c97a %>
<%# ============================================================ %>

<style nonce="<%= content_security_policy_nonce %>">
  /* ── Page wrapper ── */
  .par-page { padding: 2.5rem 0 4rem; }

  /* ── En-tête de page ── */
  .par-page-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style:  italic;
    font-size:   clamp(1.8rem, 4vw, 2.8rem);
    color:       #fdf6e3;
    margin-bottom: 0.2rem;
    line-height:   1.1;
  }
  .par-page-subtitle { color: #8a8578; font-size: 0.95rem; }

  /* ── Cards stats ── */
  .par-stat-card {
    background:    #111527;
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    padding:       2rem 1.5rem;
    text-align:    center;
    height:        100%;
  }
  .par-stat-number {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style:  italic;
    font-size:   3.5rem;
    color:       #f0c97a;
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .par-stat-label { color: #8a8578; font-size: 0.88rem; }

  /* ── Section titre ── */
  .par-section-title {
    font-family:   'Cormorant Garamond', Georgia, serif;
    font-style:    italic;
    font-size:     1.5rem;
    color:         #fdf6e3;
    margin-bottom: 1rem;
  }

  /* ── Card générique sombre ── */
  .par-card {
    background:    #111527;
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    padding:       1.5rem;
    margin-bottom: 1.5rem;
  }

  /* ── Ligne enfant ── */
  .par-child-row {
    background:    rgba(240,201,122,0.05);
    border:        1px solid rgba(240,201,122,0.08);
    border-radius: 12px;
    padding:       0.75rem 1rem;
    display:       flex;
    align-items:   center;
    margin-bottom: 0.6rem;
    gap:           0.75rem;
  }
  .par-child-icon  { flex-shrink: 0; color: #f0c97a; }
  .par-child-name  { color: #fdf6e3; font-weight: 600; font-size: 0.95rem; }
  .par-child-meta  { color: #8a8578; font-size: 0.8rem; margin-top: 0.1rem; }

  /* Badge "Choix en attente" — orange doux pour alerter sans alarmer */
  .par-pending-badge {
    display:       inline-flex;
    align-items:   center;
    gap:           0.25rem;
    background:    rgba(255,160,60,0.12);
    color:         #ffaa3c;
    border:        1px solid rgba(255,160,60,0.25);
    border-radius: 50px;
    font-size:     0.68rem;
    font-weight:   600;
    padding:       0.15rem 0.55rem;
    white-space:   nowrap;
    margin-top:    0.25rem;
  }

  /* ── Bouton outline doré ── */
  .par-btn-outline {
    border:        1px solid rgba(240,201,122,0.35);
    color:         #f0c97a;
    background:    transparent;
    border-radius: 50px;
    font-size:     0.8rem;
    padding:       0.3rem 0.9rem;
    text-decoration: none;
    white-space:   nowrap;
    transition:    background 0.15s, border-color 0.15s;
  }
  .par-btn-outline:hover {
    background:    rgba(240,201,122,0.08);
    border-color:  rgba(240,201,122,0.6);
    color:         #f0c97a;
  }

  /* ── Lien vide ── */
  .par-empty-link { color: #f0c97a; text-decoration: none; }
  .par-empty-link:hover { text-decoration: underline; }
  .par-empty-text { color: #8a8578; text-align: center; padding: 1rem 0; }

  /* ── Bloc activité récente — ligne par histoire ── */
  .par-activity-row {
    display:       flex;
    align-items:   center;
    gap:           0.75rem;
    padding:       0.6rem 0;
    border-bottom: 1px solid rgba(240,201,122,0.06);
    text-decoration: none;
    transition:    background 0.15s;
  }
  .par-activity-row:last-child { border-bottom: none; padding-bottom: 0; }
  .par-activity-row:hover .par-activity-title { color: #f0c97a; }

  /* Vignette image de couverture — petite, ronde */
  .par-activity-thumb {
    width:         40px;
    height:        40px;
    border-radius: 8px;
    object-fit:    cover;
    flex-shrink:   0;
    background:    #1a1f3c;
    display:       flex;
    align-items:   center;
    justify-content: center;
    font-size:     1.3rem;
  }
  .par-activity-thumb img {
    width: 100%; height: 100%;
    object-fit: cover; border-radius: 8px;
  }
  .par-activity-title {
    color:       #d4cfc4;
    font-size:   0.88rem;
    font-weight: 600;
    transition:  color 0.15s;
    /* Tronque le titre sur une ligne */
    white-space:   nowrap;
    overflow:      hidden;
    text-overflow: ellipsis;
    max-width:     180px;
  }
  .par-activity-meta { color: #8a8578; font-size: 0.75rem; margin-top: 0.1rem; }

  /* ── Valeurs éducatives — pills colorées ── */
  .par-values-wrap { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .par-value-pill {
    display:       inline-flex;
    align-items:   center;
    gap:           0.3rem;
    background:    rgba(80,160,200,0.10);
    color:         rgba(140,210,255,0.85);
    border:        1px solid rgba(80,160,200,0.20);
    border-radius: 50px;
    font-size:     0.78rem;
    font-weight:   500;
    padding:       0.3rem 0.8rem;
  }
  /* Compteur dans la pill — fond légèrement plus sombre */
  .par-value-count {
    background:    rgba(80,160,200,0.15);
    border-radius: 50px;
    font-size:     0.7rem;
    font-weight:   700;
    padding:       0.05rem 0.35rem;
    color:         rgba(140,210,255,0.9);
  }

  /* ── Abonnement ── */
  .par-badge-premium {
    display:       inline-flex;
    align-items:   center;
    gap:           0.3rem;
    background:    rgba(240,201,122,0.15);
    color:         #f0c97a;
    border:        1px solid rgba(240,201,122,0.30);
    border-radius: 50px;
    font-size:     0.85rem;
    font-weight:   600;
    padding:       0.35rem 1rem;
  }
  .par-badge-free {
    display:       inline-flex;
    align-items:   center;
    background:    rgba(138,133,120,0.15);
    color:         #8a8578;
    border:        1px solid rgba(138,133,120,0.2);
    border-radius: 50px;
    font-size:     0.85rem;
    padding:       0.35rem 1rem;
  }
  .par-quota-text { color: #d4cfc4; font-size: 0.9rem; margin: 0.6rem 0 0.3rem; }
  .par-btn-primary {
    display:       inline-block;
    background:    #f0c97a;
    color:         #0b0e1a;
    border-radius: 50px;
    font-weight:   700;
    font-size:     0.88rem;
    padding:       0.5rem 1.4rem;
    text-decoration: none;
    border:        none;
    transition:    opacity 0.15s;
    margin-top:    0.75rem;
  }
  .par-btn-primary:hover { opacity: 0.88; color: #0b0e1a; }
  .par-quota-bar {
    background:    rgba(240,201,122,0.10);
    border-radius: 50px;
    height:        5px;
    overflow:      hidden;
    margin-bottom: 0.6rem;
  }
  .par-quota-fill {
    height:        100%;
    background:    #f0c97a;
    border-radius: 50px;
  }

  /* ── Grille d'activité 30 jours (style GitHub contributions) ── */
  .par-chart-card {
    background:    #111527;
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    padding:       1.5rem 1.75rem 1.5rem;
    margin-bottom: 2rem;
  }
  .par-chart-header {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
    margin-bottom:   1.25rem;
  }
  .par-chart-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style:  italic;
    font-size:   1.3rem;
    color:       #fdf6e3;
    margin:      0;
  }
  .par-chart-total { color: #8a8578; font-size: 0.82rem; }

  /* Grille 30 carrés — 10 colonnes × 3 lignes */
  /* On affiche 30 jours en lisant de gauche à droite, du plus ancien au plus récent */
  .par-grid-30 {
    display:               grid;
    grid-template-columns: repeat(10, 1fr);
    grid-template-rows:    repeat(3, 1fr);
    gap:                   5px;
  }

  /* Un carré = 1 jour */
  .par-grid-day {
    aspect-ratio:  1;
    border-radius: 4px;
    background:    rgba(240,201,122,0.08);
    position:      relative;
    cursor:        default;
    transition:    background 0.15s, transform 0.15s;
    display:       flex;
    flex-direction: column;
    align-items:   center;
    justify-content: center;
    gap:           1px;
    overflow:      hidden;
  }
  .par-grid-day:hover { transform: scale(1.12); z-index: 2; }

  /* Numéro du jour — gros, lisible */
  .par-grid-day-num {
    font-size:   0.65rem;
    font-weight: 700;
    line-height: 1;
    color:       rgba(253,246,227,0.35); /* Discret sur case vide */
  }
  /* Nom du jour — très petit, en dessous */
  .par-grid-day-name {
    font-size:  0.5rem;
    line-height: 1;
    color:      rgba(253,246,227,0.25);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  /* Sur case active — texte plus lisible, foncé sur fond doré */
  .par-grid-day--1 .par-grid-day-num,
  .par-grid-day--2 .par-grid-day-num { color: rgba(11,14,26,0.7); }
  .par-grid-day--3 .par-grid-day-num  { color: rgba(11,14,26,0.85); }
  .par-grid-day--1 .par-grid-day-name,
  .par-grid-day--2 .par-grid-day-name { color: rgba(11,14,26,0.5); }
  .par-grid-day--3 .par-grid-day-name  { color: rgba(11,14,26,0.6); }
  /* Aujourd'hui — texte blanc vif pour ressortir */
  .par-grid-day--today .par-grid-day-num  { color: #fdf6e3; }
  .par-grid-day--today .par-grid-day-name { color: rgba(253,246,227,0.7); }

  /* Actif — 1 histoire : doré à 40% */
  .par-grid-day--1 { background: rgba(240,201,122,0.40); }
  /* Actif — 2 histoires : doré à 70% */
  .par-grid-day--2 { background: rgba(240,201,122,0.70); }
  /* Actif — 3+ histoires : doré plein */
  .par-grid-day--3 { background: #f0c97a; }

  /* Aujourd'hui — contour doré pour le distinguer */
  .par-grid-day--today {
    outline:        2px solid rgba(240,201,122,0.8);
    outline-offset: 1px;
  }

  /* Légende sous la grille */
  .par-grid-legend {
    display:     flex;
    align-items: center;
    gap:         0.4rem;
    margin-top:  0.9rem;
    font-size:   0.7rem;
    color:       #8a8578;
  }
  .par-grid-legend-swatch {
    width:         10px;
    height:        10px;
    border-radius: 2px;
    flex-shrink:   0;
  }

  /* ── Séparateur ── */
  .par-divider {
    border: none;
    border-top: 1px solid rgba(240,201,122,0.08);
    margin: 2rem 0;
  }

  /* ── Responsive mobile ── */
  @media (max-width: 600px) {
    .par-page        { padding: 1.5rem 0 3rem; }
    .par-page-title  { font-size: clamp(1.5rem, 6vw, 2.8rem); }
    .par-stat-number { font-size: 2.8rem; }
    .par-stat-card   { padding: 1.5rem 1rem; }
    .par-child-row   { padding: 0.6rem 0.75rem; }
    .par-activity-title { max-width: 130px; }
  }
</style>

<div class="container par-page">

  <%# ============================================================ %>
  <%# EN-TÊTE %>
  <%# ============================================================ %>
  <div class="mb-4">
    <h1 class="par-page-title">Tableau de Bord Parental</h1>
    <p class="par-page-subtitle">Suivi des lectures et de l'activité de vos enfants</p>
  </div>

  <%# ============================================================ %>
  <%# STATS GLOBALES — 3 grandes cartes %>
  <%# ============================================================ %>
  <div class="row g-3 mb-4">

    <div class="col-md-4">
      <div class="par-stat-card">
        <div class="par-stat-number"><%= @total_reading_minutes %></div>
        <div class="par-stat-label">minutes de lecture totales</div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="par-stat-card">
        <div class="par-stat-number"><%= current_user.stories.completed.count %></div>
        <div class="par-stat-label">histoires créées</div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="par-stat-card">
        <div class="par-stat-number"><%= @children.count %></div>
        <div class="par-stat-label">profils enfants</div>
      </div>
    </div>

  </div>

  <%# ============================================================ %>
  <%# GRILLE D'ACTIVITÉ — 30 derniers jours, style GitHub contributions %>
  <%# Chaque carré = 1 jour, intensité dorée selon le nombre d'histoires %>
  <%# ============================================================ %>
  <div class="par-chart-card">
    <div class="par-chart-header">
      <h2 class="par-chart-title">Activité du mois</h2>
      <% total_month = @weekly_stories.values.sum %>
      <span class="par-chart-total">
        <%= total_month %> histoire<%= "s" if total_month != 1 %> ces 30 derniers jours
      </span>
    </div>

    <%# Grille 10 × 3 = 30 cases, du jour J-29 au jour J %>
    <div class="par-grid-30">
      <% today          = Date.today %>
      <% day_names_short = %w[Dim Lun Mar Mer Jeu Ven Sam] %>

      <% 29.downto(0).each do |days_ago| %>
        <% date      = today - days_ago %>
        <% count     = @weekly_stories[date].to_i %>
        <% is_today  = date == today %>
        <% intensity       = count == 0 ? 0 : [count, 3].min %>
        <% intensity_class = "par-grid-day--#{intensity}" %>
        <% today_class     = is_today ? "par-grid-day--today" : "" %>

        <div class="par-grid-day <%= intensity_class %> <%= today_class %>"
             title="<%= date.strftime('%d/%m/%Y') %> — <%= count %> histoire<%= 's' if count != 1 %>">
          <%# Numéro du jour — ex: "13" %>
          <span class="par-grid-day-num"><%= date.day %></span>
          <%# Nom abrégé — ex: "Lun" %>
          <span class="par-grid-day-name"><%= day_names_short[date.wday] %></span>
        </div>
      <% end %>
    </div>

    <%# Légende — explique les niveaux d'intensité %>
    <div class="par-grid-legend">
      <span>Moins</span>
      <%# 4 swatches : vide → plein %>
      <div class="par-grid-legend-swatch" style="background: rgba(240,201,122,0.08)"></div>
      <div class="par-grid-legend-swatch" style="background: rgba(240,201,122,0.40)"></div>
      <div class="par-grid-legend-swatch" style="background: rgba(240,201,122,0.70)"></div>
      <div class="par-grid-legend-swatch" style="background: #f0c97a"></div>
      <span>Plus</span>
    </div>
  </div>

  <hr class="par-divider">

  <%# ============================================================ %>
  <%# COLONNES — 3 colonnes égales %>
  <%# Héros | Activité récente | Valeurs + Abonnement %>
  <%# ============================================================ %>
  <div class="row g-4">

    <%# ── Colonne 1 : profils enfants ── %>
    <div class="col-lg-4">
      <div class="par-card">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="par-section-title mb-0">Mes Héros</h2>
          <%= link_to "+ Ajouter", new_child_path, class: "par-btn-outline" %>
        </div>

        <% if @children.any? %>
          <% @children.each do |child| %>
            <div class="par-child-row">

              <%# Icône enfant — silhouette SVG, mèche si fille %>
              <div class="par-child-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="7" r="4"/>
                  <path d="M4 20c0-3.5 3.1-6 8-6s8 2.5 8 6"/>
                  <% if child.gender == "girl" %>
                    <path d="M9 7c0-1.1.9-2 2-2 1.5 0 2.5 1 2 3"/>
                  <% end %>
                </svg>
              </div>

              <%# Infos de l'enfant %>
              <div class="flex-grow-1 min-width-0">
                <div class="par-child-name"><%= child.name %></div>
                <div class="par-child-meta">
                  <%# Age + nombre d'histoires %>
                  <%= child.age %> ans ·
                  <%= child.stories.completed.count %> histoire<%= "s" if child.stories.completed.count != 1 %>
                  <%# Date de la dernière histoire si elle existe %>
                  <% last = @last_story_by_child[child.id] %>
                  <% if last %>
                    · dernière le <%= last.created_at.strftime("%d/%m") %>
                  <% end %>
                </div>
                <%# Badge d'alerte si un choix interactif est en attente pour cet enfant %>
                <% if @children_with_pending.include?(child.id) %>
                  <span class="par-pending-badge">
                    <%# Icône point d'exclamation en SVG %>
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Choix en attente
                  </span>
                <% end %>
              </div>

              <%# Lien vers la fiche enfant %>
              <%= link_to "Voir →", child_path(child), class: "par-btn-outline" %>
            </div>
          <% end %>
        <% else %>
          <p class="par-empty-text">
            <%= link_to "Créer le premier profil →", new_child_path, class: "par-empty-link" %>
          </p>
        <% end %>

      </div>
    </div>

    <%# ── Colonne 2 : activité récente ── %>
    <div class="col-lg-4">

      <%# Activité récente — 5 dernières histoires -%>
      <div class="par-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="par-section-title mb-0">Activité récente</h2>
          <%# Lien vers la bibliothèque complète %>
          <%= link_to "Tout voir →", stories_path, class: "par-btn-outline" %>
        </div>

        <% if @recent_stories.any? %>
          <% @recent_stories.each do |story| %>
            <%# Toute la ligne est cliquable — mène à l'histoire %>
            <%= link_to story_path(story), class: "par-activity-row" do %>

              <%# Vignette : image ActiveStorage, URL externe ou emoji de l'univers %>
              <div class="par-activity-thumb">
                <% if story.cover_image.attached? %>
                  <%= image_tag story.cover_image, alt: story.title %>
                <% elsif story.cover_image_url.present? %>
                  <%= image_tag story.cover_image_url, alt: story.title %>
                <% else %>
                  <%= story.world_emoji %>
                <% end %>
              </div>

              <%# Titre + enfant + date %>
              <div class="flex-grow-1 min-width-0">
                <div class="par-activity-title"><%= story.title %></div>
                <div class="par-activity-meta">
                  Pour <%= story.child.name %> · <%= story.created_at.strftime("%d/%m/%Y") %>
                </div>
              </div>

            <% end %>
          <% end %>
        <% else %>
          <p class="par-empty-text">Aucune histoire pour l'instant.</p>
        <% end %>

      </div>

    </div>

    <%# ── Colonne 3 : valeurs explorées + abonnement ── %>
    <div class="col-lg-4">

      <%# Valeurs éducatives explorées — affiché si au moins une valeur existe -%>
      <% if @educational_values.any? %>
        <div class="par-card">
          <h2 class="par-section-title">Valeurs explorées</h2>

          <%# Table de correspondance valeur → emoji + libellé français %>
          <% value_labels = {
              "courage"    => { emoji: "🦁", label: "Courage" },
              "sharing"    => { emoji: "🤝", label: "Partage" },
              "kindness"   => { emoji: "💛", label: "Gentillesse" },
              "confidence" => { emoji: "⭐", label: "Confiance en soi" }
             } %>

          <div class="par-values-wrap">
            <% @educational_values.each do |value, count| %>
              <% info = value_labels.fetch(value, { emoji: "✨", label: value.to_s.capitalize }) %>
              <%# Pill bleue avec emoji + libellé + compteur d'occurrences %>
              <span class="par-value-pill">
                <%= info[:emoji] %> <%= info[:label] %>
                <span class="par-value-count"><%= count %>×</span>
              </span>
            <% end %>
          </div>

        </div>
      <% end %>

      <%# Statut abonnement -%>
      <div class="par-card">
        <h2 class="par-section-title">Mon Abonnement</h2>

        <% if current_user.premium? %>
          <div class="d-flex align-items-center gap-3">
            <span class="par-badge-premium">✦ Premium</span>
            <span style="color: #8a8578; font-size: 0.9rem;">Histoires illimitées</span>
          </div>

        <% else %>
          <div>
            <span class="par-badge-free">Gratuit</span>
            <p class="par-quota-text">
              <%= @stories_this_month %>/3 histoires ce mois-ci
            </p>
            <div class="par-quota-bar">
              <div class="par-quota-fill"
                   style="width: <%= (@stories_this_month / 3.0 * 100).round %>%"></div>
            </div>
            <%= link_to "Passer en Premium →", subscription_path, class: "par-btn-primary" %>
          </div>
        <% end %>

      </div>

    </div>
  </div>

</div>
