<%# ============================================================ %>
<%# Dashboard parental — statistiques et suivi de lecture %>
<%# DA cosmique : fond sombre #111527, accents dorés #f0c97a %>
<%# Style inline temporaire — à externaliser dans parental.scss %>
<%# ============================================================ %>

<%# ---------------------------------------------------------------- %>
<%# Styles inline — DA cosmique (temporaire, à externaliser) %>
<%# ---------------------------------------------------------------- %>
<style nonce="<%= content_security_policy_nonce %>">
  /* ── Page wrapper ── */
  .par-page { padding: 2.5rem 0 4rem; }

  /* ── En-tête de page ── */
  /* Titre Cormorant Garamond italic, crème — identique au reste de la DA */
  .par-page-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style:  italic;
    font-size:   clamp(1.8rem, 4vw, 2.8rem);
    color:       #fdf6e3; /* Cream */
    margin-bottom: 0.2rem;
    line-height:   1.1;
  }
  .par-page-subtitle { color: #8a8578; font-size: 0.95rem; }

  /* ── Cards stats (grandes, chiffre en Cormorant doré) ── */
  /* Trois cartes côte à côte : minutes, histoires, enfants */
  .par-stat-card {
    background:    #111527; /* Deep */
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    padding:       2rem 1.5rem;
    text-align:    center;
    height:        100%;
  }
  /* Chiffre principal — Cormorant Garamond italic, doré, très grand */
  .par-stat-number {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style:  italic;
    font-size:   3.5rem;
    color:       #f0c97a; /* Gold */
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  /* Label sous le chiffre — discret */
  .par-stat-label { color: #8a8578; font-size: 0.88rem; }

  /* ── Section titre ── */
  .par-section-title {
    font-family:   'Cormorant Garamond', Georgia, serif;
    font-style:    italic;
    font-size:     1.5rem;
    color:         #fdf6e3;
    margin-bottom: 1rem;
  }

  /* ── Card générique sombre ── */
  /* Conteneur réutilisable pour les blocs : enfants, thèmes, abonnement */
  .par-card {
    background:    #111527;
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    padding:       1.5rem;
    margin-bottom: 1.5rem;
  }

  /* ── Ligne enfant — mini-carte pill dans la liste ── */
  /* Fond légèrement plus clair que la carte parente pour créer de la profondeur */
  .par-child-row {
    background:    rgba(240,201,122,0.05); /* Mist */
    border:        1px solid rgba(240,201,122,0.08);
    border-radius: 12px;
    padding:       0.75rem 1rem;
    display:       flex;
    align-items:   center;
    margin-bottom: 0.6rem;
    gap:           0.75rem;
  }
  .par-child-emoji  { font-size: 1.8rem; flex-shrink: 0; }
  .par-child-name   { color: #fdf6e3; font-weight: 600; font-size: 0.95rem; }
  .par-child-meta   { color: #8a8578; font-size: 0.8rem; }

  /* Bouton secondaire — contour doré, fond transparent, pill */
  .par-btn-outline {
    border:        1px solid rgba(240,201,122,0.35);
    color:         #f0c97a;
    background:    transparent;
    border-radius: 50px;
    font-size:     0.8rem;
    padding:       0.3rem 0.9rem;
    text-decoration: none;
    white-space:   nowrap;
    transition:    background 0.15s, border-color 0.15s;
  }
  .par-btn-outline:hover {
    background:    rgba(240,201,122,0.08);
    border-color:  rgba(240,201,122,0.6);
    color:         #f0c97a;
  }

  /* ── Lien "Créer le premier profil" ── */
  .par-empty-link { color: #f0c97a; text-decoration: none; }
  .par-empty-link:hover { text-decoration: underline; }
  .par-empty-text { color: #8a8578; text-align: center; padding: 1rem 0; }

  /* ── Progress bars univers ── */
  /* Fond mist, remplissage doré — identique aux autres barres de la DA */
  .par-theme-row {
    display:       flex;
    align-items:   center;
    gap:           0.6rem;
    margin-bottom: 0.75rem;
  }
  .par-theme-emoji { font-size: 1.3rem; flex-shrink: 0; }
  .par-theme-bar-wrap {
    flex-grow:     1;
    background:    rgba(240,201,122,0.10); /* Mist */
    border-radius: 50px;
    height:        7px;
    overflow:      hidden;
  }
  .par-theme-bar-fill {
    height:        100%;
    background:    #f0c97a; /* Gold */
    border-radius: 50px;
    transition:    width 0.6s ease;
  }
  .par-theme-count { color: #8a8578; font-size: 0.8rem; flex-shrink: 0; min-width: 1.5rem; text-align: right; }

  /* ── Abonnement ── */
  /* Pill premium doré / pill gratuit discret */
  .par-badge-premium {
    display:       inline-flex;
    align-items:   center;
    gap:           0.3rem;
    background:    rgba(240,201,122,0.15);
    color:         #f0c97a;
    border:        1px solid rgba(240,201,122,0.30);
    border-radius: 50px;
    font-size:     0.85rem;
    font-weight:   600;
    padding:       0.35rem 1rem;
  }
  .par-badge-free {
    display:       inline-flex;
    align-items:   center;
    background:    rgba(138,133,120,0.15);
    color:         #8a8578;
    border:        1px solid rgba(138,133,120,0.2);
    border-radius: 50px;
    font-size:     0.85rem;
    padding:       0.35rem 1rem;
  }
  /* Label quota histoires */
  .par-quota-text { color: #d4cfc4; font-size: 0.9rem; margin: 0.6rem 0 0.3rem; }
  /* Bouton CTA primaire — fond doré, texte sombre, pill */
  .par-btn-primary {
    display:       inline-block;
    background:    #f0c97a;
    color:         #0b0e1a;
    border-radius: 50px;
    font-weight:   700;
    font-size:     0.88rem;
    padding:       0.5rem 1.4rem;
    text-decoration: none;
    border:        none;
    transition:    opacity 0.15s;
    margin-top:    0.75rem;
  }
  .par-btn-primary:hover { opacity: 0.88; color: #0b0e1a; }

  /* Progress bar quota — plus fine, même style */
  .par-quota-bar {
    background:    rgba(240,201,122,0.10);
    border-radius: 50px;
    height:        5px;
    overflow:      hidden;
    margin-bottom: 0.6rem;
  }
  .par-quota-fill {
    height:        100%;
    background:    #f0c97a;
    border-radius: 50px;
  }

  /* ── Séparateur ── */
  .par-divider {
    border: none;
    border-top: 1px solid rgba(240,201,122,0.08);
    margin: 2rem 0;
  }
</style>

<div class="container par-page">

  <%# ============================================================ %>
  <%# EN-TÊTE — titre et sous-titre %>
  <%# ============================================================ %>
  <div class="mb-4">
    <%# Titre Cormorant Garamond italic, crème %>
    <h1 class="par-page-title">Tableau de Bord Parental</h1>
    <p class="par-page-subtitle">Suivi des lectures et de l'activité de vos enfants</p>
  </div>

  <%# ============================================================ %>
  <%# STATS GLOBALES — 3 grandes cartes : minutes / histoires / enfants %>
  <%# Chiffre en Cormorant doré, label en text-dim %>
  <%# ============================================================ %>
  <div class="row g-3 mb-4">

    <%# Stat 1 : minutes de lecture totales %>
    <div class="col-md-4">
      <div class="par-stat-card">
        <div class="par-stat-number"><%= @total_reading_minutes %></div>
        <div class="par-stat-label">minutes de lecture totales</div>
      </div>
    </div>

    <%# Stat 2 : nombre d'histoires complétées — requête depuis le current_user %>
    <div class="col-md-4">
      <div class="par-stat-card">
        <div class="par-stat-number"><%= current_user.stories.completed.count %></div>
        <div class="par-stat-label">histoires créées</div>
      </div>
    </div>

    <%# Stat 3 : nombre de profils enfants %>
    <div class="col-md-4">
      <div class="par-stat-card">
        <div class="par-stat-number"><%= @children.count %></div>
        <div class="par-stat-label">profils enfants</div>
      </div>
    </div>

  </div>

  <hr class="par-divider">

  <%# ============================================================ %>
  <%# COLONNES — enfants (gauche) + thèmes & abonnement (droite) %>
  <%# ============================================================ %>
  <div class="row g-4">

    <%# ── Colonne gauche : profils enfants ── %>
    <div class="col-lg-6">
      <div class="par-card">

        <%# En-tête du bloc : titre + bouton Ajouter %>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="par-section-title mb-0">Mes Héros</h2>
          <%# Lien secondaire — contour doré, pill %>
          <%= link_to "+ Ajouter", new_child_path, class: "par-btn-outline" %>
        </div>

        <% if @children.any? %>
          <%# Itère sur chaque enfant pour afficher une mini-carte pill %>
          <% @children.each do |child| %>
            <div class="par-child-row">
              <%# Avatar SVG — silhouette enfant, mèche pour les filles %>
              <div class="par-child-emoji">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="7" r="4"/>
                  <path d="M4 20c0-3.5 3.1-6 8-6s8 2.5 8 6"/>
                  <% if child.gender == "girl" %>
                    <path d="M9 7c0-1.1.9-2 2-2 1.5 0 2.5 1 2 3"/>
                  <% end %>
                </svg>
              </div>

              <%# Nom et stats de l'enfant %>
              <div class="flex-grow-1">
                <div class="par-child-name"><%= child.name %></div>
                <div class="par-child-meta">
                  <%= child.age %> ans ·
                  <%= child.stories.completed.count %> histoire<%= "s" if child.stories.completed.count != 1 %>
                </div>
              </div>

              <%# Lien "Voir" — bouton secondaire pill %>
              <%= link_to "Voir →", child_path(child), class: "par-btn-outline" %>
            </div>
          <% end %>
        <% else %>
          <%# Message vide si aucun enfant n'a encore été créé %>
          <p class="par-empty-text">
            <%= link_to "Créer le premier profil →", new_child_path, class: "par-empty-link" %>
          </p>
        <% end %>

      </div>
    </div>

    <%# ── Colonne droite : thèmes favoris + statut abonnement ── %>
    <div class="col-lg-6">

      <%# Univers favoris — barre de progression par thème %>
      <%# Affiché uniquement si au moins un thème a été utilisé %>
      <% if @favorite_themes.any? %>
        <div class="par-card">
          <h2 class="par-section-title">Univers Favoris</h2>

          <% @favorite_themes.each do |theme, count| %>
            <%# Table de correspondance thème → emoji %>
            <% emoji = { "space" => "🚀", "dinos" => "🦕", "princesses" => "👸",
                         "pirates" => "🏴‍☠️", "animals" => "🦁" }.fetch(theme, "✨") %>

            <div class="par-theme-row">
              <%# Emoji du thème %>
              <span class="par-theme-emoji"><%= emoji %></span>

              <%# Barre de progression — largeur max 100%, 20% par histoire (5 histoires = 100%) %>
              <div class="par-theme-bar-wrap">
                <div class="par-theme-bar-fill" style="width: <%= [count * 20, 100].min %>%"></div>
              </div>

              <%# Compteur numérique à droite de la barre %>
              <span class="par-theme-count"><%= count %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Statut abonnement — Premium ou Gratuit avec quota %>
      <div class="par-card">
        <h2 class="par-section-title">Mon Abonnement</h2>

        <% if current_user.premium? %>
          <%# Utilisateur premium : badge doré + texte illimité %>
          <div class="d-flex align-items-center gap-3">
            <span class="par-badge-premium">✦ Premium</span>
            <span style="color: #8a8578; font-size: 0.9rem;">Histoires illimitées</span>
          </div>

        <% else %>
          <%# Utilisateur gratuit : quota + barre de progression + CTA %>
          <div>
            <%# Badge "Gratuit" discret %>
            <span class="par-badge-free">Gratuit</span>

            <%# Quota : nombre d'histoires créées ce mois sur 3 %>
            <p class="par-quota-text">
              <%= @stories_this_month %>/3 histoires ce mois-ci
            </p>

            <%# Barre de progression du quota — se remplit au fil des créations %>
            <div class="par-quota-bar">
              <div class="par-quota-fill"
                   style="width: <%= (@stories_this_month / 3.0 * 100).round %>%"></div>
            </div>

            <%# CTA vers la page abonnement %>
            <%= link_to "Passer en Premium →", subscription_path, class: "par-btn-primary" %>
          </div>
        <% end %>

      </div>

    </div>
  </div>

</div>
