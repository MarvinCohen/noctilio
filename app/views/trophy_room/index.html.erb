<%# ============================================================ %>
<%# Salle des Trophées — badges, XP et galerie d'illustrations %>
<%# DA cosmique : fond sombre #111527, accents dorés #f0c97a %>
<%# Style inline temporaire — à externaliser dans trophy_room.scss %>
<%# ============================================================ %>

<%# ---------------------------------------------------------------- %>
<%# Styles inline — DA cosmique (temporaire, à externaliser) %>
<%# ---------------------------------------------------------------- %>
<style nonce="<%= content_security_policy_nonce %>">
  /* ── Tokens de couleur ── */
  /* Ces variables reproduisent les tokens de la DA cosmique */
  .tr-page          { padding: 2.5rem 0 4rem; }

  /* ── Hero XP — redesign ── */
  /* Carte principale : fond sombre avec glow radial doré derrière l'orbe de niveau */
  .tr-hero-card {
    position:      relative;
    background:    #0d1023;
    border:        1px solid rgba(240,201,122,0.22);
    border-radius: 20px;
    padding:       1.75rem 1.75rem 1.5rem;
    margin-bottom: 2.5rem;
    overflow:      hidden;
  }
  /* Halo doré en haut à droite — derrière l'orbe de niveau */
  .tr-hero-card::before {
    content:          '';
    position:         absolute;
    top:              -60px;
    right:            -60px;
    width:            220px;
    height:           220px;
    background:       radial-gradient(circle, rgba(240,201,122,0.18) 0%, transparent 68%);
    pointer-events:   none;
  }
  /* Ligne de brillance en haut de la carte */
  .tr-hero-card::after {
    content:    '';
    position:   absolute;
    top:        0;
    left:       10%;
    right:      10%;
    height:     1px;
    background: linear-gradient(90deg, transparent, rgba(240,201,122,0.45), transparent);
  }

  /* ── Label chapeau — "SALLE DES TROPHÉES" en petites caps ── */
  .tr-hero-label {
    font-size:      0.68rem;
    font-weight:    700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color:          rgba(240,201,122,0.60);
    margin-bottom:  0.4rem;
  }
  /* Titre principal — Cormorant Garamond italic, large */
  .tr-page-title {
    font-family:   'Cormorant Garamond', Georgia, serif;
    font-style:    italic;
    font-size:     clamp(1.9rem, 5vw, 3rem);
    color:         #fdf6e3;
    line-height:   1.05;
    margin-bottom: 0.2rem;
  }
  .tr-page-subtitle {
    color:         rgba(138,133,120,0.85);
    font-size:     0.88rem;
    margin-bottom: 0;
  }

  /* ── Orbe de niveau — cercle doré avec glow ── */
  /* L'élément hero visuel à droite — communique le niveau d'un coup d'œil */
  .tr-level-orb {
    width:           82px;
    height:          82px;
    border-radius:   50%;
    border:          2px solid rgba(240,201,122,0.75);
    background:      linear-gradient(145deg, rgba(240,201,122,0.14) 0%, rgba(240,201,122,0.04) 100%);
    box-shadow:      0 0 28px rgba(240,201,122,0.22), inset 0 1px 0 rgba(255,255,255,0.06);
    /* Centrage strict : flex colonne + centrage sur les deux axes + texte centré */
    display:         flex;
    flex-direction:  column;
    align-items:     center;
    justify-content: center;
    text-align:      center;
    flex-shrink:     0;
    /* Évite que le flex parent étire ou déforme le cercle */
    align-self:      center;
  }
  /* Chiffre du niveau — Cormorant Garamond, doré, très grand */
  .tr-level-number {
    display:     block;           /* block pour que text-align: center s'applique */
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size:   2.4rem;
    font-weight: 700;
    color:       #f0c97a;
    line-height: 1;
    width:       100%;
    text-align:  center;
  }
  /* Libellé "NIVEAU" sous le chiffre */
  .tr-level-caption {
    display:        block;        /* block pour centrage cohérent */
    width:          100%;
    text-align:     center;
    font-size:      0.5rem;
    font-weight:    800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color:          rgba(240,201,122,0.65);
    margin-top:     0.1rem;
    line-height:    1;
  }

  /* ── Bande de stats XP ── */
  /* Séparateur fin entre infos et barre de progression */
  .tr-hero-divider {
    border:     none;
    border-top: 1px solid rgba(240,201,122,0.08);
    margin:     1.1rem 0 1rem;
  }
  /* Valeur XP — Cormorant Garamond, très grand, doré */
  .tr-xp-value {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style:  italic;
    font-size:   2rem;
    color:       #f0c97a;
    line-height: 1;
    font-weight: 600;
  }
  .tr-xp-label {
    color:     rgba(138,133,120,0.85);
    font-size: 0.8rem;
    margin-top: 0.1rem;
  }

  /* Barre de progression XP — plus épaisse et plus impactante */
  .tr-progress {
    background:    rgba(240,201,122,0.10);
    border-radius: 50px;
    height:        10px;
    overflow:      hidden;
    margin:        0.5rem 0 0.35rem;
  }
  .tr-progress-fill {
    height:     100%;
    background: linear-gradient(90deg, #c8a04a, #f0c97a, #fde9a2);
    border-radius: 50px;
    transition:    width 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 0 8px rgba(240,201,122,0.45);
  }
  .tr-progress-label {
    color:     rgba(138,133,120,0.85);
    font-size: 0.78rem;
  }

  /* ── Section titre ── */
  .tr-section-title {
    font-family:   'Cormorant Garamond', Georgia, serif;
    font-style:    italic;
    font-size:     1.6rem;
    color:         #fdf6e3;
    margin-bottom: 1.25rem;
  }

  /* ── Grille de badges ── */
  /* Chaque badge est une carte dark avec ou sans glow selon statut */
  .tr-badge-card {
    background:    #111527;
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    padding:       1.5rem 1rem;
    text-align:    center;
    height:        100%;
    transition:    border-color 0.2s, box-shadow 0.2s;
  }
  /* Carte badge obtenu — glow doré subtil */
  .tr-badge-card--earned {
    border-color: rgba(240,201,122,0.40);
    box-shadow:   0 0 20px rgba(240,201,122,0.12);
  }
  /* Carte badge non obtenu — désaturée, opacité réduite */
  .tr-badge-card--locked {
    opacity: 0.40;
  }
  /* Emoji du badge — grand */
  .tr-badge-icon   { font-size: 2.8rem; display: block; margin-bottom: 0.6rem; }
  .tr-badge-name   { color: #fdf6e3; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem; }
  .tr-badge-desc   { color: #8a8578; font-size: 0.75rem; line-height: 1.4; }
  /* Tag "Obtenu" vert crème et "À débloquer" discret */
  .tr-badge-tag {
    display:       inline-block;
    font-size:     0.72rem;
    border-radius: 50px;
    padding:       0.2rem 0.7rem;
    margin-top:    0.6rem;
    font-weight:   600;
  }
  .tr-badge-tag--earned   { background: rgba(80,200,120,0.18); color: #5cc87a; }
  .tr-badge-tag--locked   { background: rgba(138,133,120,0.15); color: #8a8578; }
  .tr-badge-date { color: #8a8578; font-size: 0.7rem; display: block; margin-top: 0.3rem; }

  /* ── Version compacte mobile — réduit la hauteur des cartes ── */
  /* Sur mobile (< 600px) : 3 colonnes, cartes réduites, description masquée */
  @media (max-width: 600px) {
    /* Carte — padding minimal pour gagner de la hauteur */
    .tr-badge-card {
      padding:       0.75rem 0.4rem;
      border-radius: 12px;
    }
    /* Emoji — taille réduite */
    .tr-badge-icon {
      font-size:     2rem;
      margin-bottom: 0.3rem;
    }
    /* Nom du badge — légèrement plus petit */
    .tr-badge-name {
      font-size:     0.78rem;
      margin-bottom: 0.2rem;
    }
    /* Description masquée sur mobile — trop verbeuse, ralentit la lecture */
    .tr-badge-desc  { display: none; }
    /* Tag réduit */
    .tr-badge-tag   { font-size: 0.65rem; padding: 0.15rem 0.5rem; margin-top: 0.4rem; }
    /* Date masquée sur mobile — surcharge visuelle inutile */
    .tr-badge-date  { display: none; }
  }

  /* ── Galerie d'illustrations ── */
  /* Cartes dark, image avec border-radius en haut */
  .tr-gallery-card {
    background:    #111527;
    border:        1px solid rgba(240,201,122,0.15);
    border-radius: 16px;
    overflow:      hidden;
    text-decoration: none;
    display:       block;
    transition:    border-color 0.2s, transform 0.2s;
  }
  .tr-gallery-card:hover {
    border-color: rgba(240,201,122,0.40);
    transform:    translateY(-3px);
  }
  .tr-gallery-img {
    width:       100%;
    height:      180px;
    object-fit:  cover;
    display:     block;
  }
  .tr-gallery-body { padding: 0.75rem 1rem; }
  .tr-gallery-title { color: #fdf6e3; font-size: 0.88rem; font-weight: 600; }
  .tr-gallery-meta  { color: #8a8578; font-size: 0.75rem; margin-top: 0.2rem; }

  /* ── Badge caché (état initial "Voir plus") ── */
  /* Utilisé par badge_reveal_controller.js pour masquer les badges au-delà de la limite */
  .tr-badge-hidden { display: none; }

  /* ── Bouton "Voir plus de trophées" ── */
  .tr-reveal-btn {
    display:       inline-flex;
    align-items:   center;
    gap:           0.5rem;
    background:    transparent;
    border:        1px solid rgba(240,201,122,0.35);
    color:         #f0c97a;
    border-radius: 50px;
    font-size:     0.9rem;
    font-weight:   600;
    padding:       0.55rem 1.5rem;
    cursor:        pointer;
    transition:    background 0.2s, border-color 0.2s;
    margin-top:    1.25rem;
  }
  .tr-reveal-btn:hover {
    background:    rgba(240,201,122,0.10);
    border-color:  rgba(240,201,122,0.65);
  }

  /* ── Message vide ── */
  .tr-empty { color: #8a8578; text-align: center; padding: 2rem 0; font-size: 0.95rem; }

  /* ── Séparateur ── */
  .tr-divider {
    border: none;
    border-top: 1px solid rgba(240,201,122,0.08);
    margin: 2.5rem 0;
  }

  /* ── Responsive mobile ── */
  @media (max-width: 600px) {
    /* Page — moins de padding vertical */
    .tr-page { padding: 1.5rem 0 3rem; }

    /* Titre — réduit la taille min du clamp */
    .tr-page-title { font-size: clamp(1.6rem, 6vw, 3.2rem); }

    /* Hero card — moins de padding, orbe un peu plus petite */
    .tr-hero-card { padding: 1.25rem 1.1rem; }
    .tr-level-orb { width: 70px; height: 70px; }
    .tr-level-number { font-size: 2rem; }
    .tr-xp-value { font-size: 1.6rem; }

    /* Galerie — images un peu moins hautes */
    .tr-gallery-img { height: 140px; }
  }
</style>

<div class="container tr-page">

  <%# ============================================================ %>
  <%# HERO — niveau + barre de progression XP %>
  <%# ============================================================ %>
  <div class="tr-hero-card">

    <%# ── Ligne 1 : titre à gauche, orbe de niveau à droite ── %>
    <div class="d-flex align-items-center justify-content-between gap-3">

      <%# Bloc texte gauche %>
      <div>
        <%# Label chapeau en petites caps dorées %>
        <div class="tr-hero-label">✦ Salle des Trophées</div>
        <%# Titre éditorial en Cormorant Garamond italic %>
        <h1 class="tr-page-title">Tes Trophées</h1>
        <p class="tr-page-subtitle">Tes exploits, tes rêves, ton univers</p>
      </div>

      <%# Orbe de niveau — cercle doré avec glow, chiffre centré %>
      <%# C'est l'élément hero visuel — communique le niveau d'un coup d'œil %>
      <div class="tr-level-orb flex-shrink-0">
        <span class="tr-level-number"><%= @level %></span>
        <span class="tr-level-caption">Niveau</span>
      </div>

    </div>

    <%# ── Séparateur ── %>
    <hr class="tr-hero-divider">

    <%# ── Ligne 2 : XP total à gauche, barre de progression à droite ── %>
    <div class="d-flex align-items-end gap-4">

      <%# XP accumulés — Cormorant doré, affiché en grand %>
      <div class="flex-shrink-0">
        <div class="tr-xp-value"><%= number_with_delimiter(@xp_points, delimiter: "\u202f") %></div>
        <div class="tr-xp-label">XP accumulés</div>
      </div>

      <%# Barre de progression vers le prochain niveau (prend le reste de la largeur) %>
      <div class="flex-grow-1">
        <div class="tr-progress">
          <div class="tr-progress-fill" style="width: <%= @level_progress %>%"></div>
        </div>
        <span class="tr-progress-label"><%= @level_progress %>% vers le niveau <%= @level + 1 %></span>
      </div>

    </div>

  </div>

  <hr class="tr-divider">

  <%# ============================================================ %>
  <%# BADGES MAGIQUES — grille 4 colonnes %>
  <%# Obtenu = carte lumineuse avec glow, À débloquer = opacity 0.4 %>
  <%# ============================================================ %>
  <%# data-controller branche le Stimulus BadgeRevealController sur ce bloc %>
  <%# data-badge-reveal-limit-value définit combien de badges sont visibles au départ %>
  <div class="mb-5"
       data-controller="badge-reveal"
       data-badge-reveal-limit-value="8">

    <h2 class="tr-section-title">✦ Badges Magiques</h2>

    <div class="row g-3">
      <% @all_badges.each do |badge| %>
        <%# Vérifie si ce badge est dans la liste des badges obtenus %>
        <% earned = @earned_badge_ids.include?(badge.id) %>

        <%# data-badge-reveal-target="item" — permet au controller de masquer/révéler ce badge %>
        <%# col-4 = 3 colonnes mobile, col-md-3 = 4 colonnes desktop %>
        <div class="col-4 col-md-3" data-badge-reveal-target="item">
          <%# Classe différente selon le statut : glow si obtenu, désaturé si verrouillé %>
          <div class="tr-badge-card <%= earned ? 'tr-badge-card--earned' : 'tr-badge-card--locked' %>">

            <%# Emoji du badge — affiché en grand dans les deux cas %>
            <span class="tr-badge-icon"><%= badge.icon %></span>

            <%# Nom du badge %>
            <div class="tr-badge-name"><%= badge.name %></div>

            <%# Description du badge — condition à remplir %>
            <div class="tr-badge-desc"><%= badge.description %></div>

            <% if earned %>
              <%# Retrouve le UserBadge pour afficher la date d'obtention %>
              <% user_badge = @earned_user_badges.find { |ub| ub.badge_id == badge.id } %>
              <%# Tag vert "Obtenu" %>
              <span class="tr-badge-tag tr-badge-tag--earned">✓ Obtenu</span>
              <%# Date en petit, discrète %>
              <span class="tr-badge-date">le <%= user_badge.earned_at.strftime("%d/%m/%Y") %></span>
            <% else %>
              <%# Tag gris "À débloquer" %>
              <span class="tr-badge-tag tr-badge-tag--locked">À débloquer</span>
            <% end %>

          </div>
        </div>
      <% end %>

      <%# Message affiché si aucun badge n'est encore défini en base %>
      <% if @all_badges.empty? %>
        <div class="col-12 tr-empty">
          Les badges seront bientôt disponibles !
        </div>
      <% end %>
    </div>

    <%# Boutons centrés sous la grille — un seul visible à la fois %>
    <div class="text-center">
      <%# "Voir plus" — visible au chargement, masqué après dépliement %>
      <button class="tr-reveal-btn"
              data-badge-reveal-target="btnMore"
              data-action="click->badge-reveal#reveal">
        Voir les autres trophées ✦
      </button>

      <%# "Voir moins" — masqué au chargement, visible après dépliement %>
      <%# Au clic : replie les badges ET remonte au titre de la section %>
      <button class="tr-reveal-btn"
              data-badge-reveal-target="btnLess"
              data-action="click->badge-reveal#collapse">
        ↑ Voir moins
      </button>
    </div>

  </div>

  <hr class="tr-divider">

  <%# ============================================================ %>
  <%# GALERIE DE RÊVES — illustrations générées pour les histoires %>
  <%# Cartes dark cliquables, image en haut avec border-radius %>
  <%# Affichée uniquement si au moins une histoire a une illustration %>
  <%# ============================================================ %>
  <% if @illustrated_stories.any? %>
    <div class="mb-5">
      <h2 class="tr-section-title">✦ Galerie de Rêves</h2>
      <p class="tr-page-subtitle mb-4">Les illustrations générées pour tes histoires</p>

      <div class="row g-3">
        <% @illustrated_stories.each do |story| %>
          <div class="col-6 col-md-4">
            <%# Lien vers la page de l'histoire — toute la carte est cliquable %>
            <%= link_to story_path(story), class: "tr-gallery-card" do %>

              <%# Image de couverture — priorité à ActiveStorage, fallback sur cover_image_url %>
              <% if story.cover_image.attached? %>
                <%= image_tag story.cover_image,
                      class: "tr-gallery-img",
                      alt: story.title %>
              <% elsif story.cover_image_url.present? %>
                <%= image_tag story.cover_image_url,
                      class: "tr-gallery-img",
                      alt: story.title %>
              <% end %>

              <%# Corps de la carte : titre tronqué + enfant associé %>
              <div class="tr-gallery-body">
                <div class="tr-gallery-title text-truncate"><%= story.title %></div>
                <div class="tr-gallery-meta">Pour <%= story.child.name %></div>
              </div>

            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
