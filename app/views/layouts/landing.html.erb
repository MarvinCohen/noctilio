<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title><%= content_for(:title) || "Noctilio — Des histoires magiques pour ton enfant" %></title>

    <%# Polices Google — design élégant de la landing page %>
    <%# preconnect : établit la connexion DNS/TLS avec Google Fonts avant que le HTML soit parsé %>
    <%# display=swap : texte visible immédiatement avec la police système (évite FOIT) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <%# media="print" : charge les polices de façon non-bloquante (technique web.dev/defer-non-critical-css) %>
    <%# La bascule vers media="all" se fait via le <script> nonce ci-dessous %>
    <%# (l'attribut onload inline est interdit par la CSP — un nonce ne s'applique pas aux gestionnaires inline) %>
    <link id="async-fonts"
          rel="stylesheet"
          media="print"
          href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap"/>
    <%# Bascule la feuille de polices de media="print" à "all" une fois chargée %>
    <%# Équivalent JS de l'attribut onload, autorisé par la CSP grâce au nonce %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var link = document.getElementById('async-fonts');
        if (!link) return;
        // Applique tout de suite si déjà en cache (l'event load ne se déclenche pas dans ce cas)
        if (link.sheet) { link.media = 'all'; }
        // Sinon, applique dès que la feuille est téléchargée
        else { link.addEventListener('load', function() { link.media = 'all'; }); }
      })();
    </script>
    <%# Fallback <noscript> pour les navigateurs sans JS — charge normalement %>
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
    </noscript>

    <%# ── Balises SEO de base ── %>
    <%# description : résumé affiché par Google sous le titre dans les résultats de recherche %>
    <%# Dynamique : si une vue fournit content_for(:description), elle est utilisée ici %>
    <%# Sinon : description par défaut de la landing page %>
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Noctilio génère des histoires personnalisées pour ton enfant en quelques secondes — avec son prénom, ses personnages et son univers préféré. Propulsé par l'IA." %>">

    <%# Canonical — indique à Google l'URL de référence (évite www vs non-www, http vs https) %>
    <link rel="canonical" href="https://www.noctilio-app.fr<%= request.path %>">

    <%# hreflang — indique à Google que le site est en français pour les utilisateurs fr %>
    <%# x-default : URL par défaut si aucune langue ne correspond au navigateur de l'utilisateur %>
    <link rel="alternate" hreflang="fr" href="https://www.noctilio-app.fr<%= request.path %>">
    <link rel="alternate" hreflang="x-default" href="https://www.noctilio-app.fr<%= request.path %>">

    <%# theme-color — colore la barre du navigateur sur mobile (Chrome Android, Safari iOS) %>
    <%# Renforce l'identité visuelle de Noctilio (fond nuit profonde) %>
    <meta name="theme-color" content="#0b0e1a">

    <%# Robots — par défaut on autorise l'indexation des pages publiques du layout landing %>
    <%# MAIS une vue peut forcer noindex via content_for(:robots) — ex : les histoires %>
    <%# partagées (contenu privé d'utilisateur) ne doivent PAS être indexées par Google %>
    <meta name="robots" content="<%= content_for?(:robots) ? yield(:robots) : "index, follow" %>">

    <%# Sitemap — indique à Google où trouver le plan du site %>
    <link rel="sitemap" type="application/xml" href="https://www.noctilio-app.fr/sitemap.xml">

    <%# ── Open Graph (Facebook, WhatsApp, LinkedIn, iMessage…) ── %>
    <%# Ces balises définissent l'aperçu affiché quand quelqu'un partage le lien %>
    <%# og:type : "article" pour les articles de blog, "website" pour les autres pages %>
    <meta property="og:type"        content="<%= content_for?(:og_type) ? yield(:og_type) : "website" %>">
    <%# og:url dynamique — utilise request.original_url pour correspondre exactement à la page %>
    <meta property="og:url"         content="<%= request.original_url %>">
    <%# og:title dynamique — reprend le titre SEO de la vue si défini, sinon valeur par défaut %>
    <meta property="og:title"       content="<%= content_for?(:title) ? yield(:title) : "Noctilio — Des histoires magiques pour ton enfant" %>">
    <%# og:description dynamique — reprend la description SEO de la vue si définie %>
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : "Chaque soir, une histoire unique générée en quelques secondes avec le prénom, les personnages et l'univers préférés de ton enfant." %>">
    <%# og:image : image dédiée 1536×1024px générée pour les aperçus de partage social %>
    <%# Servie depuis public/ — URL absolue obligatoire pour Facebook, WhatsApp, LinkedIn %>
    <%# Une vue peut surcharger via content_for(:og_image) — ex : une histoire partagée %>
    <%# affiche sa propre illustration dans l'aperçu WhatsApp (bien plus engageant) %>
    <meta property="og:image"       content="<%= content_for?(:og_image) ? yield(:og_image) : "https://www.noctilio-app.fr/og-image.jpg" %>">
    <meta property="og:image:width"  content="1536">
    <meta property="og:image:height" content="1024">
    <meta property="og:image:alt"    content="<%= content_for?(:title) ? yield(:title) : "Noctilio — Des histoires magiques pour ton enfant" %>">
    <meta property="og:locale"       content="fr_FR">
    <meta property="og:site_name"    content="Noctilio">

    <%# ── Twitter Card (X) ── %>
    <%# summary_large_image : affiche une grande image dans le tweet %>
    <meta name="twitter:card"        content="summary_large_image">
    <%# Reprend les mêmes valeurs dynamiques que og: pour cohérence %>
    <meta name="twitter:title"       content="<%= content_for?(:title) ? yield(:title) : "Noctilio — Des histoires magiques pour ton enfant" %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : "Chaque soir, une histoire unique générée en quelques secondes avec le prénom, les personnages et l'univers préférés de ton enfant." %>">
    <meta name="twitter:image"       content="https://www.noctilio-app.fr/og-image.jpg">
    <meta name="twitter:image:alt"   content="<%= content_for?(:title) ? yield(:title) : "Noctilio — histoires personnalisées pour enfants" %>">

    <%# CSRF meta tags — nécessaires pour les requêtes fetch() vers l'API Rails %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Script analytics Umami — rendu seulement en prod (visiteurs anonymes trackés) %>
    <%= render "shared/analytics" %>

    <%# Favicon — mascotte hibou Noctilio %>
    <%= favicon_link_tag image_path('mascot.svg'), type: 'image/svg+xml' %>
    <%= favicon_link_tag image_path('mascot.png'), type: 'image/png', sizes: '32x32' %>

    <%# CSS dédié à la landing page — standalone, sans Bootstrap %>
    <%# Compilé depuis app/assets/stylesheets/landing.scss par Propshaft %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>

    <%= yield :head %>
  </head>
  <body>
    <%# Pas de sidebar, pas de navbar — la landing page est totalement autonome %>
    <%= yield %>
  </body>
</html>
