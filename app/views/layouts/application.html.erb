<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Noctilio" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Noctilio">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <%# --- Layout avec sidebar (utilisateurs connectés) --- %>
      <%# Structure deux colonnes : sidebar fixe à gauche + contenu principal scrollable %>
      <div class="app-layout">
        <%= render "shared/sidebar" %>
        <main class="app-main">
          <%= render "shared/flashes" %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <%# --- Layout classique avec navbar (visiteurs non connectés) --- %>
      <%# La navbar s'affiche en haut, le contenu prend toute la largeur %>
      <%= render "shared/navbar" %>
      <%= render "shared/flashes" %>
      <%= yield %>
    <% end %>
  </body>
</html>
