<!DOCTYPE html>
<%# lang dynamique : reflète la langue affichée (fr, en, es, de, it, pt) %>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="UTF-8">
    <title><%= content_for(:title) || "Noctilio — Histoires magiques pour enfants" %></title>

    <%# Robots — par défaut noindex pour les pages app (derrière authentification) %>
    <%# Les pages légales publiques surchargent ce comportement via content_for(:robots) %>
    <meta name="robots" content="<%= content_for?(:robots) ? yield(:robots) : "noindex, nofollow" %>">

    <%# Description — surchargeable page par page via content_for(:description) %>
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Noctilio — Des histoires personnalisées générées par IA pour ton enfant." %>">

    <%# Canonical + hreflang — UNIQUEMENT pour les pages publiques indexées %>
    <%# (légales, à-propos, blog). Une page publique signale son indexation via %>
    <%# content_for(:robots, "index, follow"). Les pages app privées (noindex) %>
    <%# n'ont pas besoin de hreflang ni de canonical multilingue. %>
    <% if content_for?(:robots) && yield(:robots).to_s.include?("index") %>
      <%= render "shared/hreflang" %>
    <% else %>
      <%# Page privée : canonical simple de sécurité (si jamais indexée par erreur) %>
      <link rel="canonical" href="https://www.noctilio-app.fr<%= request.path %>">
    <% end %>

    <%# viewport-fit=cover : indispensable pour que les env(safe-area-inset-*) %>
    <%# fonctionnent sur iPhone à encoche (sinon la bottom-nav chevauche la barre home) %>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover">
    <%# theme-color — colore la barre du navigateur sur mobile avec le fond nuit de Noctilio %>
    <meta name="theme-color" content="#0b0e1a">
    <%# view-transition — active les transitions de page Turbo (fondu doux entre pages). %>
    <%# Turbo 8 enveloppe alors le rendu dans document.startViewTransition() ; %>
    <%# l'animation est personnalisée dans components/_transitions.scss. %>
    <meta name="view-transition" content="same-origin">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%# Barre d'état iOS en mode app installée — "black" garde une barre sombre %>
    <%# cohérente avec le fond nuit Noctilio (pas de bandeau blanc). %>
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <%# Titre affiché sous l'icône iOS quand l'app est ajoutée à l'écran d'accueil %>
    <meta name="apple-mobile-web-app-title" content="Noctilio">
    <meta name="application-name" content="Noctilio">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Script analytics Umami — rendu seulement en prod et pour les non-admins %>
    <%= render "shared/analytics" %>

    <%# Événement de funnel posé par un controller via flash[:umami_event]
        (signup, story_created, subscription_activated). Rend vide si analytics
        coupé ou événement absent/inconnu — voir AnalyticsHelper#umami_event_tag. %>
    <%= umami_event_tag(flash[:umami_event]) %>

    <%= yield :head %>

    <%# ---------------------------------------------------------------- %>
    <%# PWA Manifest — déclare l'app comme installable sur mobile/desktop %>
    <%# Permet l'icône sur l'écran d'accueil + mode plein écran standalone %>
    <%# La route /manifest est définie dans config/routes.rb %>
    <%# ---------------------------------------------------------------- %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Favicon — mascotte hibou Noctilio %>
    <%= favicon_link_tag image_path('mascot.svg'), type: 'image/svg+xml' %>
    <%= favicon_link_tag image_path('mascot.png'), type: 'image/png', sizes: '32x32' %>
    <%# Icône d'accueil iOS — version dédiée 180×180 (servie depuis public/) %>
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

    <%# ---------------------------------------------------------------- %>
    <%# Google Fonts — SOURCE UNIQUE de chargement des polices de l'app (déduplique %>
    <%# l'ancien doublon avec le @import du SCSS, désormais supprimé). %>
    <%# Familles : Cormorant Garamond (titres), DM Sans (corps), Lora (texte des %>
    <%# histoires), Plus Jakarta Sans (UI Bootstrap), Cinzel Decorative (titre histoire). %>
    <%# Kalam (jamais utilisée) a été retirée. %>
    <%# preconnect réduit la latence de connexion initiale à Google Fonts %>
    <%# ---------------------------------------------------------------- %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <%# Chargement non-bloquant des polices — media="print" puis swap vers "all" via le <script> nonce ci-dessous %>
    <%# Évite que Google Fonts bloque le rendu du HTML (render-blocking resource) %>
    <%# L'attribut onload inline est interdit par la CSP — un nonce ne s'applique pas aux gestionnaires inline %>
    <link id="async-fonts"
          rel="stylesheet"
          media="print"
          href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Lora:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Cinzel+Decorative:wght@400;700&display=swap"/>
    <%# Bascule la feuille de polices de media="print" à "all" une fois chargée %>
    <%# Équivalent JS de l'attribut onload, autorisé par la CSP grâce au nonce %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var link = document.getElementById('async-fonts');
        if (!link) return;
        // Applique tout de suite si déjà en cache (l'event load ne se déclenche pas dans ce cas)
        if (link.sheet) { link.media = 'all'; }
        // Sinon, applique dès que la feuille est téléchargée
        else { link.addEventListener('load', function() { link.media = 'all'; }); }
      })();
    </script>
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Lora:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Cinzel+Decorative:wght@400;700&display=swap" rel="stylesheet"/>
    </noscript>

    <%# ---------------------------------------------------------------- %>
    <%# Style inline minimal — impose le fond sombre sur TOUT le body %>
    <%# !important nécessaire pour passer au-dessus de Bootstrap %>
    <%# Ce style s'applique avant le chargement du CSS complet (pas de FOUC) %>
    <%# ---------------------------------------------------------------- %>
    <style>
      /* Fond nuit profonde sur html ET body — évite le flash blanc pendant la navigation Turbo */
      /* html est nécessaire car Turbo affiche l'élément html une fraction de seconde avant body */
      html, body { background: #0b0e1a !important; color: #d4cfc4 !important; overflow-x: hidden; }
    </style>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%# ---------------------------------------------------------------- %>
    <%# Splash screen PWA — visible uniquement en mode app installée %>
    <%# (display-mode: standalone). En navigateur classique il reste caché. %>
    <%# Le JS plus bas le fait disparaître en fondu une fois la page chargée. %>
    <%# ---------------------------------------------------------------- %>
    <div class="pwa-splash" id="pwa-splash" aria-hidden="true">
      <%= image_tag "mascot.svg", alt: "", class: "pwa-splash-owl", width: 96, height: 96 %>
      <p class="pwa-splash-word">Noctilio</p>
    </div>

    <%# ---------------------------------------------------------------- %>
    <%# Canvas étoiles — fixé derrière tout le contenu sur toutes les pages %>
    <%# Le JS en bas de page dessine 250 étoiles dorées scintillantes %>
    <%# z-index: -1 garantit qu'il reste derrière tout le contenu %>
    <%# ---------------------------------------------------------------- %>
    <canvas id="global-stars-canvas" aria-hidden="true" style="
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    "></canvas>

    <% if user_signed_in? %>
      <%# --- Layout avec sidebar (utilisateurs connectés) --- %>
      <%# Structure deux colonnes : sidebar fixe à gauche + contenu principal scrollable %>
      <div class="app-layout">
        <%= render "shared/sidebar" %>
        <main class="app-main">
          <%= render "shared/flashes" %>
          <%# Notification + confettis des badges fraîchement gagnés (si présents) %>
          <%= render "shared/badge_notifications" %>
          <%# full_bleed : le dashboard gère son propre fond, pas de wrapper supplémentaire %>
          <%# Les autres pages (formulaires, lecture) sont enveloppées dans .page-card %>
          <%# .page-card est transparent — le fond sombre #0b0e1a vient du body %>
          <% if content_for?(:full_bleed) %>
            <%= yield %>
          <% else %>
            <div class="page-card">
              <%= yield %>
            </div>
          <% end %>
          <%# Footer global — affiché en bas de toutes les pages connectées %>
          <%= render "shared/footer" %>
        </main>
        <%# Bottom tab bar — navigation type app native, visible mobile uniquement %>
        <%= render "shared/bottom_nav" %>
      </div>
    <% else %>
      <%# --- Layout classique avec navbar (visiteurs non connectés) --- %>
      <%# La navbar s'affiche en haut, le contenu prend toute la largeur %>
      <%= render "shared/navbar" %>
      <%= render "shared/flashes" %>
      <%= yield %>
      <%# Footer global — affiché en bas de la landing page aussi %>
      <%= render "shared/footer" %>
    <% end %>
    <%# ---------------------------------------------------------------- %>
    <%# Script étoiles — dessine et anime le ciel étoilé global %>
    <%# Identique au dashboard mais dans le layout pour couvrir toutes les pages %>
    <%# ---------------------------------------------------------------- %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        // Attendre que le DOM soit prêt avant de chercher le canvas
        document.addEventListener('DOMContentLoaded', function() {
          initGlobalStars();
        });

        // Relancer les étoiles à chaque navigation Turbo (SPA-like)
        // sans Turbo, DOMContentLoaded suffit
        document.addEventListener('turbo:load', function() {
          // Annule l'animation précédente si elle tourne encore
          if (window._globalStarsFrame) cancelAnimationFrame(window._globalStarsFrame);
          initGlobalStars();
        });

        // ============================================================
        // initGlobalStars — initialise le canvas et lance l'animation
        // ============================================================
        function initGlobalStars() {
          const canvas = document.getElementById('global-stars-canvas');
          if (!canvas) return;

          const ctx  = canvas.getContext('2d');
          let stars  = [];

          // ── Redimensionne le canvas en tenant compte du ratio Retina ──
          // Sans ça, les étoiles sont floues sur les écrans HiDPI (Mac, iPhone)
          function resizeStars() {
            const dpr      = window.devicePixelRatio || 1;
            canvas.width   = window.innerWidth  * dpr;
            canvas.height  = window.innerHeight * dpr;
          }

          // ── Crée 250 étoiles avec position, taille et phase aléatoires ──
          function createStars() {
            const dpr = window.devicePixelRatio || 1;
            stars = [];
            for (let i = 0; i < 250; i++) {
              stars.push({
                x:     Math.random() * canvas.width,   // Position X aléatoire
                y:     Math.random() * canvas.height,  // Position Y aléatoire
                r:     (Math.random() * 1.4 + 0.6) * dpr, // Rayon entre 0.6 et 2px
                speed: Math.random() * 0.005 + 0.002,  // Vitesse de scintillement
                phase: Math.random() * Math.PI * 2     // Phase de départ aléatoire (sin)
              });
            }
          }

          // ── Dessine toutes les étoiles avec un scintillement sinusoïdal ──
          // t : timestamp fourni par requestAnimationFrame (ms depuis le chargement)
          function drawStars(t) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            stars.forEach(function(s) {
              // Alpha oscille entre 0.2 et 0.7 selon la phase et le temps
              const alpha = 0.2 + 0.5 * Math.sin(s.phase + t * s.speed);
              ctx.beginPath();
              ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
              ctx.fillStyle = 'rgba(240, 201, 122, ' + alpha.toFixed(3) + ')'; // Or Noctilio
              ctx.fill();
            });
            // Stocke l'ID pour pouvoir annuler l'animation au prochain turbo:load
            window._globalStarsFrame = requestAnimationFrame(drawStars);
          }

          // ── Lance l'animation ──
          resizeStars();
          createStars();
          window._globalStarsFrame = requestAnimationFrame(drawStars);

          // ── Resize — ignore les changements de hauteur seuls (scroll mobile) ──
          // Ne recrée les étoiles que si la LARGEUR change (vrai resize ou rotation)
          let lastW = window.innerWidth;
          let rTimer;
          window.addEventListener('resize', function() {
            clearTimeout(rTimer);
            rTimer = setTimeout(function() {
              if (Math.abs(window.innerWidth - lastW) > 10) {
                lastW = window.innerWidth;
                resizeStars();
                createStars();
              }
            }, 250);
          });

          // ── Pause quand l'onglet est invisible — économise CPU/batterie sur mobile ──
          // document.visibilityState === 'hidden' → l'onglet est en arrière-plan ou l'écran éteint
          // On annule requestAnimationFrame et on le relance quand l'onglet redevient visible
          document.addEventListener('visibilitychange', function() {
            if (document.visibilityState === 'hidden') {
              // Onglet masqué → stop l'animation pour économiser les ressources
              if (window._globalStarsFrame) {
                cancelAnimationFrame(window._globalStarsFrame);
                window._globalStarsFrame = null;
              }
            } else {
              // Onglet redevenu visible → relance l'animation là où on en était
              if (!window._globalStarsFrame) {
                window._globalStarsFrame = requestAnimationFrame(drawStars);
              }
            }
          });
        }
      })();
    </script>

    <%# ---------------------------------------------------------------- %>
    <%# Splash screen PWA — fondu de sortie au lancement (mode app installée) %>
    <%# On ne l'affiche qu'en mode standalone : en navigateur web, on retire %>
    <%# l'élément tout de suite pour ne pas masquer le contenu. %>
    <%# ---------------------------------------------------------------- %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var splash = document.getElementById('pwa-splash');
        if (!splash) return;

        // Détecte le mode "app installée" (lancée depuis l'icône d'accueil).
        // matchMedia(display-mode: standalone) couvre Android/Chrome ;
        // navigator.standalone couvre iOS Safari ajouté à l'écran d'accueil.
        var isStandalone =
          window.matchMedia('(display-mode: standalone)').matches ||
          window.navigator.standalone === true;

        // En navigateur classique : on supprime le splash immédiatement.
        if (!isStandalone) {
          splash.remove();
          return;
        }

        // Turbo remplace le <body> à chaque navigation et ré-exécute les <script>
        // du body : le splash serait donc réinjecté et rejoué à chaque page.
        // On pose un drapeau global (persiste sur window tant que l'app n'est pas
        // rechargée à froid) pour n'animer le splash qu'au tout premier lancement.
        if (window.__noctiSplashShown) {
          // Lancement déjà fait → c'est une simple navigation interne : on retire
          // le splash tout de suite, sans fondu, pour ne pas masquer la page.
          splash.remove();
          return;
        }

        // Premier lancement de l'app : on mémorise et on joue le fondu de sortie.
        window.__noctiSplashShown = true;

        // On laisse le splash visible ~0,9s puis on déclenche le fondu de sortie.
        // Exécution directe (pas d'écouteur "load") : le script tourne déjà en bas
        // du body, donc le DOM est prêt, et "load" ne se redéclenche pas sous Turbo.
        setTimeout(function() {
          splash.classList.add('pwa-splash--hidden'); // déclenche le fondu CSS
          // Retire l'élément du DOM une fois le fondu terminé (0,5s)
          setTimeout(function() { splash.remove(); }, 500);
        }, 900);
      })();
    </script>

    <%# ---------------------------------------------------------------- %>
    <%# Enregistrement du Service Worker PWA %>
    <%# Le service worker tourne en arrière-plan et gère le cache offline %>
    <%# Il s'enregistre une seule fois et met à jour automatiquement %>
    <%# nonce= obligatoire pour respecter la Content Security Policy (CSP) %>
    <%# ---------------------------------------------------------------- %>
    <script nonce="<%= content_security_policy_nonce %>">
      // On vérifie que le navigateur supporte les Service Workers
      // (tous les navigateurs modernes le supportent, sauf IE11)
      if ("serviceWorker" in navigator) {
        // On attend que la page soit complètement chargée
        // pour ne pas ralentir le chargement initial
        window.addEventListener("load", function() {
          navigator.serviceWorker
            .register("<%= pwa_service_worker_path %>", {
              // scope : le service worker contrôle tout le site "/"
              scope: "/"
            })
            .then(function(registration) {
              // Enregistrement réussi — le SW est actif en arrière-plan
              console.log("[PWA] Service worker enregistré :", registration.scope);
            })
            .catch(function(error) {
              // Échec silencieux — l'app continue de fonctionner normalement
              console.warn("[PWA] Échec enregistrement service worker :", error);
            });
        });
      }
    </script>

  </body>
</html>
