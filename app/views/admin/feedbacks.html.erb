<%# ============================================================ %>
<%# Page admin — liste des retours utilisateurs laissés via /avis %>
<%# Accessible uniquement par un compte admin (require_admin!) %>
<%# DA cosmique : table dark, accents dorés (même style que waitlist) %>
<%# ============================================================ %>

<style nonce="<%= content_security_policy_nonce %>">
  /* ── Wrapper de page ── */
  .admin-page { padding: 2.5rem 0 4rem; }

  /* ── En-tête ── */
  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .admin-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 2.2rem;
    font-weight: 300;
    color: #fdf6e3;
    margin: 0 0 0.2rem;
    line-height: 1.1;
  }
  .admin-subtitle { color: #8a8578; font-size: 0.9rem; margin: 0; }

  /* Badge compteur — fond doré, texte sombre */
  .admin-count-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1.2rem;
    background: #f0c97a;
    color: #0b0e1a;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  /* ── Carte table ── */
  .admin-card {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 16px;
    overflow: hidden;
  }
  .admin-table { width: 100%; border-collapse: collapse; margin: 0; }
  .admin-table thead tr { background: #1a1f3c; }
  .admin-table thead th {
    color: #f0c97a;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.85rem 1.25rem;
    border: none;
  }
  .admin-table tbody tr:nth-child(odd)  { background: #111527; }
  .admin-table tbody tr:nth-child(even) { background: #0d1020; }
  .admin-table tbody tr:hover           { background: rgba(240, 201, 122, 0.04); }
  .admin-table tbody td {
    padding: 0.75rem 1.25rem;
    border: none;
    border-bottom: 1px solid rgba(240, 201, 122, 0.06);
    vertical-align: top;
  }

  /* Cellule message — large, texte clair, retours à la ligne conservés */
  .admin-td-message { color: #fdf6e3; font-size: 0.9rem; white-space: pre-wrap; max-width: 420px; }
  /* Colonnes secondaires — text dim */
  .admin-td-date, .admin-td-meta { color: #8a8578; font-size: 0.85rem; white-space: nowrap; }
  .admin-email-link { color: rgba(240, 201, 122, 0.8); text-decoration: none; font-size: 0.85rem; }
  .admin-email-link:hover { color: #f0c97a; text-decoration: underline; }

  /* ── Pastille de catégorie ── */
  .admin-cat {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  /* Couleur selon le type : bug = rouge, suggestion = doré, autre = bleu */
  .admin-cat-bug        { background: rgba(220, 90, 90, 0.15); color: #f3b6b6; }
  .admin-cat-suggestion { background: rgba(240, 201, 122, 0.15); color: #f0c97a; }
  .admin-cat-autre      { background: rgba(120, 160, 230, 0.15); color: #aac4f5; }

  /* ── Message vide ── */
  .admin-empty { text-align: center; padding: 3rem 1rem; color: #8a8578; }
</style>

<div class="container admin-page">

  <%# ── En-tête ── %>
  <div class="admin-header">
    <div>
      <h1 class="admin-title">Retours utilisateurs</h1>
      <p class="admin-subtitle">Avis laissés depuis la page /avis</p>
    </div>
    <%# Badge avec le nombre total de retours %>
    <span class="admin-count-badge">
      <%= @total %> retour<%= "s" if @total > 1 %>
    </span>
  </div>

  <% if @feedbacks.any? %>

    <%# ── Table des retours ── %>
    <div class="admin-card">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Type</th>
            <th>Message</th>
            <th>Auteur</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% @feedbacks.each do |feedback| %>
            <tr>
              <%# Catégorie avec pastille colorée selon le type %>
              <td>
                <span class="admin-cat admin-cat-<%= feedback.category %>">
                  <%= feedback.category %>
                </span>
              </td>

              <%# Message complet — pré-formaté pour garder les retours à la ligne %>
              <td class="admin-td-message"><%= feedback.message %></td>

              <%# Auteur : email cliquable si fourni, sinon "anonyme".
                  feedback.user préchargé via includes(:user) → pas de N+1 %>
              <td class="admin-td-meta">
                <% if feedback.email.present? %>
                  <a href="mailto:<%= feedback.email %>" class="admin-email-link">
                    <%= feedback.email %>
                  </a>
                <% elsif feedback.user %>
                  <%= feedback.user.full_name %>
                <% else %>
                  Anonyme
                <% end %>
              </td>

              <%# Date formatée en français %>
              <td class="admin-td-date">
                <%= feedback.created_at.strftime("%d/%m/%Y à %H:%M") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  <% else %>
    <%# Aucun retour pour l'instant %>
    <div class="admin-empty">
      Aucun retour pour l'instant.
    </div>
  <% end %>

</div>
