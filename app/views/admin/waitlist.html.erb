<%# ============================================================ %>
<%# Page admin — liste des emails inscrits sur la waitlist %>
<%# Accessible uniquement par marvincohen95@gmail.com %>
<%# ============================================================ %>

<div class="container py-5">

  <%# En-tête avec titre et compteur total %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h1 class="mb-1">Liste d'attente</h1>
      <p class="text-muted mb-0">Emails inscrits depuis la landing page</p>
    </div>
    <%# Badge avec le nombre total d'inscrits %>
    <span class="badge bg-primary fs-5 px-3 py-2">
      <%= @total %> inscrits
    </span>
  </div>

  <%# Tableau des inscrits %>
  <% if @entries.any? %>
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th class="ps-4">#</th>
              <th>Email</th>
              <th>Date d'inscription</th>
              <th>Il y a</th>
            </tr>
          </thead>
          <tbody>
            <%# Affiche chaque inscrit avec son numéro, email et date %>
            <% @entries.each_with_index do |entry, index| %>
              <tr>
                <%# Numéro dans l'ordre inverse (le plus récent = 1) %>
                <td class="ps-4 text-muted"><%= index + 1 %></td>

                <%# Email cliquable pour ouvrir le client mail %>
                <td>
                  <a href="mailto:<%= entry.email %>" class="text-decoration-none">
                    <%= entry.email %>
                  </a>
                </td>

                <%# Date complète formatée en français %>
                <td class="text-muted">
                  <%= entry.created_at.strftime("%d/%m/%Y à %H:%M") %>
                </td>

                <%# Temps relatif (ex: "il y a 2 jours") %>
                <td class="text-muted">
                  <%= time_ago_in_words(entry.created_at) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Bouton pour copier tous les emails (utile pour un envoi en masse) %>
    <div class="mt-3 text-end">
      <button
        class="btn btn-outline-secondary btn-sm"
        onclick="copyEmails()"
        id="copyBtn">
        Copier tous les emails
      </button>
    </div>

    <%# Données cachées pour le bouton copier — liste séparée par des virgules %>
    <div id="emailList" class="d-none">
      <%= @entries.map(&:email).join(", ") %>
    </div>

    <script>
      // Copie tous les emails dans le presse-papier
      function copyEmails() {
        const emails = document.getElementById('emailList').textContent.trim();
        navigator.clipboard.writeText(emails).then(() => {
          const btn = document.getElementById('copyBtn');
          btn.textContent = 'Copié !';
          btn.classList.replace('btn-outline-secondary', 'btn-success');
          // Remet le bouton à son état initial après 2 secondes
          setTimeout(() => {
            btn.textContent = 'Copier tous les emails';
            btn.classList.replace('btn-success', 'btn-outline-secondary');
          }, 2000);
        });
      }
    </script>

  <% else %>
    <%# Message affiché si aucun inscrit pour l'instant %>
    <div class="alert alert-info">
      Aucun email inscrit pour l'instant.
    </div>
  <% end %>

</div>
