<%# ============================================================ %>
<%# Page abonnement Premium %>
<%# Affiche : état premium si déjà abonné, sinon le CTA Stripe %>
<%# ============================================================ %>

<style nonce="<%= content_security_policy_nonce %>">
  /* ── Wrapper de page ── */
  .sub-page { padding: 3rem 0 5rem; }

  /* ── Hero — titre + prix ── */
  .sub-hero { text-align: center; margin-bottom: 3rem; }
  .sub-hero-icon { font-size: 4rem; display: block; margin-bottom: 1.5rem; }
  /* Titre Cormorant Garamond italic, crème */
  .sub-hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: #fdf6e3;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }
  .sub-hero-subtitle { color: #8a8578; font-size: 1rem; margin-bottom: 2.5rem; }

  /* Carte centrale — fond deep, bordure dorée lumineuse */
  .sub-card {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.3);
    border-radius: 24px;
    padding: 2.5rem;
    max-width: 480px;
    margin: 0 auto;
    box-shadow: 0 0 60px rgba(240, 201, 122, 0.06);
  }

  /* Prix mis en valeur */
  .sub-price {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(240, 201, 122, 0.1);
  }
  /* Montant — Cormorant Garamond très grand, doré */
  .sub-price-amount {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 4.5rem;
    color: #f0c97a;
    line-height: 1;
    font-weight: 300;
  }
  .sub-price-period { color: #8a8578; font-size: 0.9rem; margin-top: 0.3rem; }

  /* Liste des features */
  .sub-features { list-style: none; padding: 0; margin: 0 0 2rem; }
  .sub-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(240, 201, 122, 0.05);
    color: #d4cfc4;
    font-size: 0.95rem;
  }
  .sub-feature-item:last-child { border-bottom: none; }
  /* Symbole ✦ doré devant chaque feature */
  .sub-feature-icon { color: #f0c97a; font-size: 0.8rem; flex-shrink: 0; margin-top: 3px; }
  .sub-feature-label strong { color: #fdf6e3; }

  /* Bouton CTA principal — doré, pill */
  .sub-btn-cta {
    display: block;
    width: 100%;
    padding: 0.85rem;
    background: #f0c97a;
    color: #0b0e1a;
    border: none;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    margin-bottom: 1rem;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .sub-btn-cta:hover { background: #f5d898; color: #0b0e1a; text-decoration: none; transform: translateY(-1px); }
  .sub-btn-cta:active { transform: translateY(0); }

  /* Badge "Premium actif" — vert doux */
  .sub-badge-active {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(80, 200, 120, 0.15);
    color: #50c878;
    border: 1px solid rgba(80, 200, 120, 0.3);
    border-radius: 50px;
    padding: 0.4rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  /* Bouton annulation — discret, texte seulement */
  .sub-btn-cancel {
    display: block;
    width: 100%;
    padding: 0.6rem;
    background: transparent;
    color: #8a8578;
    border: 1px solid rgba(138, 133, 120, 0.3);
    border-radius: 50px;
    font-size: 0.85rem;
    cursor: pointer;
    text-align: center;
    margin-top: 1rem;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .sub-btn-cancel:hover { color: #fdf6e3; border-color: rgba(138, 133, 120, 0.6); }

  /* Jauge histoires gratuites */
  .sub-quota {
    background: rgba(240, 201, 122, 0.05);
    border: 1px solid rgba(240, 201, 122, 0.1);
    border-radius: 12px;
    padding: 1rem 1.2rem;
    margin-bottom: 1.5rem;
  }
  .sub-quota-label { color: #8a8578; font-size: 0.82rem; margin-bottom: 0.5rem; }
  .sub-quota-bar {
    background: rgba(255,255,255,0.07);
    border-radius: 50px;
    height: 6px;
    overflow: hidden;
  }
  .sub-quota-fill {
    height: 100%;
    background: #f0c97a;
    border-radius: 50px;
    transition: width 0.3s ease;
  }
  .sub-quota-count { color: #d4cfc4; font-size: 0.82rem; margin-top: 0.4rem; text-align: right; }

  /* Note sous le bouton */
  .sub-note { text-align: center; color: #8a8578; font-size: 0.82rem; }

  /* ── Grille des 3 paliers (Gratuit / Essentiel / Premium) ── */
  /* Affichée aux comptes gratuits pour comparer et choisir une offre. */
  .sub-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 920px;
    margin: 0 auto;
    align-items: stretch; /* toutes les cartes à la même hauteur */
  }
  /* Carte d'un palier — flex column pour coller le bouton en bas */
  .sub-tier {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 20px;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  /* Palier MIS EN AVANT (Essentiel) — bordure dorée + halo + léger zoom */
  .sub-tier--featured {
    border-color: rgba(240, 201, 122, 0.5);
    box-shadow: 0 0 50px rgba(240, 201, 122, 0.1);
    transform: scale(1.03);
  }
  /* Pastille "Le plus populaire" posée sur le bord haut de la carte Essentiel */
  .sub-tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #f0c97a;
    color: #0b0e1a;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.3rem 0.85rem;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  /* Nom du palier */
  .sub-tier-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.5rem;
    color: #fdf6e3;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  /* Prix du palier */
  .sub-tier-price { text-align: center; margin-bottom: 1.25rem; }
  .sub-tier-price-amount {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 2.8rem;
    color: #f0c97a;
    line-height: 1;
  }
  .sub-tier-price-period { color: #8a8578; font-size: 0.8rem; }
  /* Liste des features du palier — flex-grow pousse le bouton en bas */
  .sub-tier-features { list-style: none; padding: 0; margin: 0 0 1.5rem; flex-grow: 1; }
  .sub-tier-feature {
    display: flex;
    gap: 0.5rem;
    padding: 0.4rem 0;
    color: #d4cfc4;
    font-size: 0.88rem;
  }
  .sub-tier-feature-icon { color: #f0c97a; flex-shrink: 0; }
  /* Feature ABSENTE du palier — grisée avec un tiret */
  .sub-tier-feature--off { color: rgba(138, 133, 120, 0.55); }
  .sub-tier-feature--off .sub-tier-feature-icon { color: rgba(138, 133, 120, 0.4); }
  /* Bouton CTA dans une carte de palier — collé en bas */
  .sub-tier .sub-btn-cta { margin-top: auto; margin-bottom: 0; }
  /* Bouton CTA secondaire (Premium) — contour doré, moins appuyé que l'Essentiel plein */
  .sub-btn-cta-outline {
    display: block;
    width: 100%;
    padding: 0.85rem;
    background: transparent;
    color: #f0c97a;
    border: 1px solid rgba(240, 201, 122, 0.5);
    border-radius: 50px;
    font-weight: 700;
    font-size: 1rem;
    text-align: center;
    text-decoration: none;
    margin-top: auto;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .sub-btn-cta-outline:hover { background: rgba(240, 201, 122, 0.1); color: #f0c97a; text-decoration: none; }
  /* Encart "Ton offre actuelle" (carte Gratuit, à la place du bouton) */
  .sub-tier-current {
    text-align: center;
    color: #8a8578;
    font-size: 0.85rem;
    padding: 0.85rem;
    border: 1px solid rgba(138, 133, 120, 0.25);
    border-radius: 50px;
    margin-top: auto;
  }

  /* ── Tableau comparatif Gratuit vs Premium ── */
  .sub-compare { max-width: 640px; margin: 3.5rem auto 0; }
  /* Titre de section — même style éditorial que le hero */
  .sub-section-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.8rem;
    font-weight: 300;
    color: #fdf6e3;
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .sub-compare-table {
    width: 100%;
    border-collapse: collapse;
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 16px;
    overflow: hidden;
  }
  .sub-compare-table th,
  .sub-compare-table td {
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid rgba(240, 201, 122, 0.08);
    font-size: 0.92rem;
  }
  /* 1re colonne (nom de la feature) alignée à gauche, les autres centrées */
  .sub-compare-table th:first-child,
  .sub-compare-table td:first-child { text-align: left; color: #d4cfc4; }
  .sub-compare-table th:not(:first-child),
  .sub-compare-table td:not(:first-child) { text-align: center; }
  /* En-têtes de colonnes — Gratuit gris, Premium doré */
  .sub-compare-table thead th { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .sub-col-free      { color: #8a8578; }
  .sub-col-essentiel { color: #f0c97a; }
  .sub-col-premium   { color: #f0c97a; }
  /* Valeurs — check doré pour inclus, tiret gris pour absent */
  .sub-check { color: #f0c97a; }
  .sub-dash  { color: rgba(138, 133, 120, 0.5); }
  .sub-compare-table tbody tr:last-child td { border-bottom: none; }

  /* ── Mini FAQ — details/summary natifs ── */
  .sub-faq { max-width: 640px; margin: 3.5rem auto 0; }
  .sub-faq-item {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.12);
    border-radius: 12px;
    margin-bottom: 0.75rem;
    padding: 0;
  }
  /* summary = la question cliquable */
  .sub-faq-item summary {
    cursor: pointer;
    padding: 1rem 1.2rem;
    color: #d4cfc4;
    font-weight: 600;
    font-size: 0.92rem;
    list-style: none; /* Masque la flèche par défaut du navigateur */
  }
  /* Masque aussi la flèche sous WebKit (Safari/Chrome) */
  .sub-faq-item summary::-webkit-details-marker { display: none; }
  /* Petite étoile dorée qui pivote quand la question est ouverte */
  .sub-faq-item summary::before { content: "✦ "; color: #f0c97a; font-size: 0.75rem; }
  .sub-faq-answer {
    padding: 0 1.2rem 1rem;
    color: #8a8578;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  /* Lien retour */
  .sub-back-link {
    display: block;
    text-align: center;
    margin-top: 2rem;
    color: rgba(240, 201, 122, 0.6);
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 0.15s ease;
  }
  .sub-back-link:hover { color: #f0c97a; text-decoration: none; }

  /* ── Responsive mobile (≤ 576px, cible iPhone SE 375px) ── */
  /* La page n'avait aucun breakpoint : sur petit écran la carte et le tableau */
  /* comparatif étaient trop serrés. On réduit paddings et tailles de police. */
  /* Les 3 cartes de palier s'empilent dès qu'on passe sous 768px (tablette/mobile) */
  @media (max-width: 768px) {
    .sub-tiers { grid-template-columns: 1fr; max-width: 420px; }
    .sub-tier--featured { transform: none; } /* pas de zoom une fois empilé */
  }

  @media (max-width: 576px) {
    .sub-page { padding: 2rem 0 4rem; }
    .sub-hero { margin-bottom: 2rem; }
    .sub-hero-icon { font-size: 3rem; margin-bottom: 1rem; }

    /* Carte — moins de padding et coins un peu moins arrondis */
    .sub-card { padding: 1.5rem; border-radius: 18px; }

    /* Prix — réduit pour ne pas déborder sur petit écran */
    .sub-price-amount { font-size: 3.5rem; }

    /* Titres de section (comparatif, FAQ) — un cran plus petits */
    .sub-section-title { font-size: 1.5rem; }

    /* Tableau comparatif — cellules plus compactes pour tenir sur 3 colonnes */
    .sub-compare-table th,
    .sub-compare-table td { padding: 0.6rem 0.5rem; font-size: 0.82rem; }
    .sub-compare-table thead th { font-size: 0.75rem; }
  }
</style>

<div class="container sub-page">

  <%# ── Hero — icône + titre ── %>
  <div class="sub-hero">
    <span class="sub-hero-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
    </span>
    <h1 class="sub-hero-title"><%= t("subscription.title") %></h1>
    <% if @subscribed %>
      <p class="sub-hero-subtitle"><%= t("subscription.subtitle_active") %></p>
    <% else %>
      <p class="sub-hero-subtitle"><%= t("subscription.subtitle_free") %></p>
    <% end %>
  </div>

  <%# ============================================================ %>
  <%# CAS 1 — l'utilisateur a déjà un palier payant : carte de GESTION %>
  <%# ============================================================ %>
  <% if @subscribed %>
    <div class="sub-card">

      <%# Badge d'état — distingue "abonnement actif" d'une résiliation programmée %>
      <%# on_grace_period? : abonnement résilié mais encore valable jusqu'à l'échéance %>
      <div class="text-center mb-3">
        <% if @subscription&.on_grace_period? %>
          <%# Résiliation programmée : accès maintenu jusqu'à la date de fin (badge doré) %>
          <span class="sub-badge-active" style="background: rgba(240, 201, 122, 0.12); color: #f0c97a; border-color: rgba(240, 201, 122, 0.45);">
            <%= t("subscription.cancel_scheduled") %>
          </span>
        <% else %>
          <%# Abonnement pleinement actif — libellé selon le palier réel (badge vert) %>
          <span class="sub-badge-active">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <%= @tier == :premium ? t("subscription.premium_active") : t("subscription.essentiel_active") %>
          </span>
        <% end %>
      </div>

      <%# Liste des avantages inclus — dépend du palier (Premium a tout, Essentiel a moins) %>
      <ul class="sub-features">
        <% if @tier == :premium %>
          <%# Premium : toutes les fonctionnalités %>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_unlimited") %></span></li>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_illustrations") %></span></li>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_audio") %></span></li>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_interactive") %></span></li>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_dashboard") %></span></li>
        <% else %>
          <%# Essentiel : histoires illimitées + illustrations (pas d'audio ni interactif) %>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_unlimited") %></span></li>
          <li class="sub-feature-item"><span class="sub-feature-icon">✦</span><span class="sub-feature-label"><%= t("subscription.card_illustrations") %></span></li>
        <% end %>
      </ul>

      <% if @subscription&.on_grace_period? %>
        <%# Résiliation déjà programmée : rappel de la date de fin + proposition de réactiver %>
        <p class="sub-note" style="text-align: center;">
          <%= t("subscription.grace_until_html", date: @subscription.ends_at.strftime("%d/%m/%Y")) %>
        </p>
        <%= button_to t("subscription.reactivate"),
              subscription_resume_path,
              method: :post,
              class: "sub-btn-cta" %>
      <% else %>
        <%# Abonnement actif : bouton de résiliation discret en bas de carte %>
        <%= button_to t("subscription.cancel"),
              subscription_cancel_path,
              method: :post,
              class: "sub-btn-cancel",
              data: { confirm: t("subscription.cancel_confirm") } %>
      <% end %>

    </div>

  <%# ============================================================ %>
  <%# CAS 2 — compte gratuit : grille des 3 paliers (Essentiel en avant) %>
  <%# ============================================================ %>
  <% else %>
    <div class="sub-tiers">

      <%# ── Carte 1 : Gratuit (palier actuel de l'utilisateur) ── %>
      <div class="sub-tier">
        <div class="sub-tier-name"><%= t("subscription.tier_free_name") %></div>
        <div class="sub-tier-price">
          <div class="sub-tier-price-amount"><%= t("subscription.price_free") %></div>
          <div class="sub-tier-price-period"><%= t("subscription.price_free_period") %></div>
        </div>
        <ul class="sub-tier-features">
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_stories_limited") %></li>
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_text_only") %></li>
          <li class="sub-tier-feature sub-tier-feature--off"><span class="sub-tier-feature-icon">—</span><%= t("subscription.card_illustrations") %></li>
          <li class="sub-tier-feature sub-tier-feature--off"><span class="sub-tier-feature-icon">—</span><%= t("subscription.card_audio") %></li>
        </ul>
        <%# Jauge du quota hebdo — montre où en est l'utilisateur (max 3/semaine) %>
        <div class="sub-quota">
          <div class="sub-quota-label"><%= t("subscription.quota_label") %></div>
          <div class="sub-quota-bar">
            <% pct = [(@stories_this_week.to_f / 3 * 100).round, 100].min %>
            <div class="sub-quota-fill" style="width: <%= pct %>%"></div>
          </div>
          <div class="sub-quota-count"><%= t("subscription.quota_count", count: @stories_this_week) %></div>
        </div>
        <%# Pas de bouton : c'est déjà l'offre en cours de l'utilisateur %>
        <div class="sub-tier-current"><%= t("subscription.current_plan") %></div>
      </div>

      <%# ── Carte 2 : Essentiel — MISE EN AVANT (le plus populaire) ── %>
      <div class="sub-tier sub-tier--featured">
        <span class="sub-tier-badge"><%= t("subscription.popular_badge") %></span>
        <div class="sub-tier-name"><%= t("subscription.tier_essentiel_name") %></div>
        <div class="sub-tier-price">
          <div class="sub-tier-price-amount"><%= t("subscription.price_essentiel") %></div>
          <div class="sub-tier-price-period"><%= t("subscription.price_period") %></div>
        </div>
        <ul class="sub-tier-features">
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_unlimited") %></li>
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_illustrations") %></li>
          <li class="sub-tier-feature sub-tier-feature--off"><span class="sub-tier-feature-icon">—</span><%= t("subscription.card_audio") %></li>
          <li class="sub-tier-feature sub-tier-feature--off"><span class="sub-tier-feature-icon">—</span><%= t("subscription.card_interactive") %></li>
        </ul>
        <%# Bouton CTA — checkout Stripe avec le plan "essentiel".
            data-turbo:false obligatoire : le checkout redirige vers Stripe (domaine externe),
            Turbo (fetch) ne sait pas suivre une redirection cross-origin. %>
        <%= button_to t("subscription.subscribe_essentiel"),
              subscription_checkout_path(plan: "essentiel"),
              method: :post,
              form: { data: { turbo: false } },
              class: "sub-btn-cta" %>
      </div>

      <%# ── Carte 3 : Premium (tout inclus) ── %>
      <div class="sub-tier">
        <div class="sub-tier-name"><%= t("subscription.tier_premium_name") %></div>
        <div class="sub-tier-price">
          <div class="sub-tier-price-amount"><%= t("subscription.price_premium") %></div>
          <div class="sub-tier-price-period"><%= t("subscription.price_period") %></div>
        </div>
        <ul class="sub-tier-features">
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_unlimited") %></li>
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_illustrations") %></li>
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_audio") %></li>
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_interactive") %></li>
          <li class="sub-tier-feature"><span class="sub-tier-feature-icon">✦</span><%= t("subscription.card_dashboard") %></li>
        </ul>
        <%# Bouton CTA secondaire (contour) — checkout Stripe avec le plan "premium" %>
        <%= button_to t("subscription.subscribe_premium"),
              subscription_checkout_path(plan: "premium"),
              method: :post,
              form: { data: { turbo: false } },
              class: "sub-btn-cta-outline" %>
      </div>

    </div>

    <p class="sub-note" style="margin-top: 1.5rem;"><%= t("subscription.secure_note") %></p>

  <% end %>

  <%# ── Tableau comparatif Gratuit vs Premium ── %>
  <%# Visible par tous : aide les gratuits à se décider, rappelle aux premium ce qu'ils ont %>
  <div class="sub-compare">
    <h2 class="sub-section-title"><%= t("subscription.compare_title") %></h2>
    <table class="sub-compare-table">
      <thead>
        <tr>
          <th><%= t("subscription.col_feature") %></th>
          <th class="sub-col-free"><%= t("subscription.col_free") %></th>
          <th class="sub-col-essentiel"><%= t("subscription.col_essentiel") %></th>
          <th class="sub-col-premium"><%= t("subscription.col_premium") %></th>
        </tr>
      </thead>
      <tbody>
        <%# Histoires : 3/sem en gratuit, illimité dès Essentiel %>
        <tr>
          <td><%= t("subscription.row_stories") %></td>
          <td class="sub-col-free">3</td>
          <td class="sub-check"><%= t("subscription.unlimited") %></td>
          <td class="sub-check"><%= t("subscription.unlimited") %></td>
        </tr>
        <%# Profils enfants : illimités dans tous les paliers %>
        <tr>
          <td><%= t("subscription.row_profiles") %></td>
          <td class="sub-check">✓</td>
          <td class="sub-check">✓</td>
          <td class="sub-check">✓</td>
        </tr>
        <%# Illustrations IA : débloquées dès Essentiel %>
        <tr>
          <td><%= t("subscription.row_illustrations") %></td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
          <td class="sub-check">✓</td>
        </tr>
        <%# Mode interactif : Premium uniquement %>
        <tr>
          <td><%= t("subscription.row_interactive") %></td>
          <td class="sub-dash">—</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <%# Lecture audio : Premium uniquement %>
        <tr>
          <td><%= t("subscription.row_audio") %></td>
          <td class="sub-dash">—</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <%# Dashboard parental avancé : Premium uniquement %>
        <tr>
          <td><%= t("subscription.row_dashboard") %></td>
          <td class="sub-dash">—</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <%# Nouveaux univers : Premium uniquement %>
        <tr>
          <td><%= t("subscription.row_new_worlds") %></td>
          <td class="sub-dash">—</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
      </tbody>
    </table>
  </div>

  <%# ── Mini FAQ — questions fréquentes sur la facturation ── %>
  <%# details/summary natifs : accordéon sans JavaScript %>
  <div class="sub-faq">
    <h2 class="sub-section-title"><%= t("subscription.faq_title") %></h2>

    <details class="sub-faq-item">
      <summary><%= t("subscription.faq_q1") %></summary>
      <div class="sub-faq-answer">
        <%= t("subscription.faq_a1") %>
      </div>
    </details>

    <details class="sub-faq-item">
      <summary><%= t("subscription.faq_q2") %></summary>
      <div class="sub-faq-answer">
        <%= t("subscription.faq_a2") %>
      </div>
    </details>

    <details class="sub-faq-item">
      <summary><%= t("subscription.faq_q3") %></summary>
      <div class="sub-faq-answer">
