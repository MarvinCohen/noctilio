<%# ============================================================ %>
<%# Page abonnement Premium %>
<%# Affiche : état premium si déjà abonné, sinon le CTA Stripe %>
<%# ============================================================ %>

<style nonce="<%= content_security_policy_nonce %>">
  /* ── Wrapper de page ── */
  .sub-page { padding: 3rem 0 5rem; }

  /* ── Hero — titre + prix ── */
  .sub-hero { text-align: center; margin-bottom: 3rem; }
  .sub-hero-icon { font-size: 4rem; display: block; margin-bottom: 1.5rem; }
  /* Titre Cormorant Garamond italic, crème */
  .sub-hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: #fdf6e3;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }
  .sub-hero-subtitle { color: #8a8578; font-size: 1rem; margin-bottom: 2.5rem; }

  /* Carte centrale — fond deep, bordure dorée lumineuse */
  .sub-card {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.3);
    border-radius: 24px;
    padding: 2.5rem;
    max-width: 480px;
    margin: 0 auto;
    box-shadow: 0 0 60px rgba(240, 201, 122, 0.06);
  }

  /* Prix mis en valeur */
  .sub-price {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(240, 201, 122, 0.1);
  }
  /* Montant — Cormorant Garamond très grand, doré */
  .sub-price-amount {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 4.5rem;
    color: #f0c97a;
    line-height: 1;
    font-weight: 300;
  }
  .sub-price-period { color: #8a8578; font-size: 0.9rem; margin-top: 0.3rem; }

  /* Liste des features */
  .sub-features { list-style: none; padding: 0; margin: 0 0 2rem; }
  .sub-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(240, 201, 122, 0.05);
    color: #d4cfc4;
    font-size: 0.95rem;
  }
  .sub-feature-item:last-child { border-bottom: none; }
  /* Symbole ✦ doré devant chaque feature */
  .sub-feature-icon { color: #f0c97a; font-size: 0.8rem; flex-shrink: 0; margin-top: 3px; }
  .sub-feature-label strong { color: #fdf6e3; }

  /* Bouton CTA principal — doré, pill */
  .sub-btn-cta {
    display: block;
    width: 100%;
    padding: 0.85rem;
    background: #f0c97a;
    color: #0b0e1a;
    border: none;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    margin-bottom: 1rem;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .sub-btn-cta:hover { background: #f5d898; color: #0b0e1a; text-decoration: none; transform: translateY(-1px); }
  .sub-btn-cta:active { transform: translateY(0); }

  /* Badge "Premium actif" — vert doux */
  .sub-badge-active {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(80, 200, 120, 0.15);
    color: #50c878;
    border: 1px solid rgba(80, 200, 120, 0.3);
    border-radius: 50px;
    padding: 0.4rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  /* Bouton annulation — discret, texte seulement */
  .sub-btn-cancel {
    display: block;
    width: 100%;
    padding: 0.6rem;
    background: transparent;
    color: #8a8578;
    border: 1px solid rgba(138, 133, 120, 0.3);
    border-radius: 50px;
    font-size: 0.85rem;
    cursor: pointer;
    text-align: center;
    margin-top: 1rem;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .sub-btn-cancel:hover { color: #fdf6e3; border-color: rgba(138, 133, 120, 0.6); }

  /* Jauge histoires gratuites */
  .sub-quota {
    background: rgba(240, 201, 122, 0.05);
    border: 1px solid rgba(240, 201, 122, 0.1);
    border-radius: 12px;
    padding: 1rem 1.2rem;
    margin-bottom: 1.5rem;
  }
  .sub-quota-label { color: #8a8578; font-size: 0.82rem; margin-bottom: 0.5rem; }
  .sub-quota-bar {
    background: rgba(255,255,255,0.07);
    border-radius: 50px;
    height: 6px;
    overflow: hidden;
  }
  .sub-quota-fill {
    height: 100%;
    background: #f0c97a;
    border-radius: 50px;
    transition: width 0.3s ease;
  }
  .sub-quota-count { color: #d4cfc4; font-size: 0.82rem; margin-top: 0.4rem; text-align: right; }

  /* Note sous le bouton */
  .sub-note { text-align: center; color: #8a8578; font-size: 0.82rem; }

  /* ── Tableau comparatif Gratuit vs Premium ── */
  .sub-compare { max-width: 640px; margin: 3.5rem auto 0; }
  /* Titre de section — même style éditorial que le hero */
  .sub-section-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.8rem;
    font-weight: 300;
    color: #fdf6e3;
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .sub-compare-table {
    width: 100%;
    border-collapse: collapse;
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 16px;
    overflow: hidden;
  }
  .sub-compare-table th,
  .sub-compare-table td {
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid rgba(240, 201, 122, 0.08);
    font-size: 0.92rem;
  }
  /* 1re colonne (nom de la feature) alignée à gauche, les autres centrées */
  .sub-compare-table th:first-child,
  .sub-compare-table td:first-child { text-align: left; color: #d4cfc4; }
  .sub-compare-table th:not(:first-child),
  .sub-compare-table td:not(:first-child) { text-align: center; }
  /* En-têtes de colonnes — Gratuit gris, Premium doré */
  .sub-compare-table thead th { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .sub-col-free    { color: #8a8578; }
  .sub-col-premium { color: #f0c97a; }
  /* Valeurs — check doré pour inclus, tiret gris pour absent */
  .sub-check { color: #f0c97a; }
  .sub-dash  { color: rgba(138, 133, 120, 0.5); }
  .sub-compare-table tbody tr:last-child td { border-bottom: none; }

  /* ── Mini FAQ — details/summary natifs ── */
  .sub-faq { max-width: 640px; margin: 3.5rem auto 0; }
  .sub-faq-item {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.12);
    border-radius: 12px;
    margin-bottom: 0.75rem;
    padding: 0;
  }
  /* summary = la question cliquable */
  .sub-faq-item summary {
    cursor: pointer;
    padding: 1rem 1.2rem;
    color: #d4cfc4;
    font-weight: 600;
    font-size: 0.92rem;
    list-style: none; /* Masque la flèche par défaut du navigateur */
  }
  /* Masque aussi la flèche sous WebKit (Safari/Chrome) */
  .sub-faq-item summary::-webkit-details-marker { display: none; }
  /* Petite étoile dorée qui pivote quand la question est ouverte */
  .sub-faq-item summary::before { content: "✦ "; color: #f0c97a; font-size: 0.75rem; }
  .sub-faq-answer {
    padding: 0 1.2rem 1rem;
    color: #8a8578;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  /* Lien retour */
  .sub-back-link {
    display: block;
    text-align: center;
    margin-top: 2rem;
    color: rgba(240, 201, 122, 0.6);
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 0.15s ease;
  }
  .sub-back-link:hover { color: #f0c97a; text-decoration: none; }

  /* ── Responsive mobile (≤ 576px, cible iPhone SE 375px) ── */
  /* La page n'avait aucun breakpoint : sur petit écran la carte et le tableau */
  /* comparatif étaient trop serrés. On réduit paddings et tailles de police. */
  @media (max-width: 576px) {
    .sub-page { padding: 2rem 0 4rem; }
    .sub-hero { margin-bottom: 2rem; }
    .sub-hero-icon { font-size: 3rem; margin-bottom: 1rem; }

    /* Carte — moins de padding et coins un peu moins arrondis */
    .sub-card { padding: 1.5rem; border-radius: 18px; }

    /* Prix — réduit pour ne pas déborder sur petit écran */
    .sub-price-amount { font-size: 3.5rem; }

    /* Titres de section (comparatif, FAQ) — un cran plus petits */
    .sub-section-title { font-size: 1.5rem; }

    /* Tableau comparatif — cellules plus compactes pour tenir sur 3 colonnes */
    .sub-compare-table th,
    .sub-compare-table td { padding: 0.6rem 0.5rem; font-size: 0.82rem; }
    .sub-compare-table thead th { font-size: 0.75rem; }
  }
</style>

<div class="container sub-page">

  <%# ── Hero — icône + titre ── %>
  <div class="sub-hero">
    <span class="sub-hero-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
    </span>
    <h1 class="sub-hero-title">Abonnement Premium</h1>
    <% if @is_premium %>
      <p class="sub-hero-subtitle">Tu bénéficies de toutes les fonctionnalités premium.</p>
    <% else %>
      <p class="sub-hero-subtitle">Histoires illimitées, mode interactif et bien plus.</p>
    <% end %>
  </div>

  <%# ── Carte principale ── %>
  <div class="sub-card">

    <%# ── Cas 1 : l'utilisateur est déjà premium ── %>
    <% if @is_premium %>

      <%# Badge d'état — distingue "Premium actif" d'une résiliation programmée %>
      <%# on_grace_period? : abonnement résilié mais encore valable jusqu'à l'échéance %>
      <div class="text-center mb-3">
        <% if @subscription&.on_grace_period? %>
          <%# Résiliation programmée : on reste premium jusqu'à la date de fin (badge doré) %>
          <span class="sub-badge-active" style="background: rgba(240, 201, 122, 0.12); color: #f0c97a; border-color: rgba(240, 201, 122, 0.45);">
            Résiliation programmée
          </span>
        <% else %>
          <%# Abonnement pleinement actif (badge vert) %>
          <span class="sub-badge-active">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Premium actif
          </span>
        <% end %>
      </div>

      <%# Liste des avantages inclus %>
      <ul class="sub-features">
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Histoires <strong>illimitées</strong></span>
        </li>
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Mode <strong>interactif</strong> : l'enfant fait des choix</span>
        </li>
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Dashboard parental <strong>avancé</strong></span>
        </li>
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Accès <strong>prioritaire</strong> aux nouveaux univers</span>
        </li>
      </ul>

      <% if @subscription&.on_grace_period? %>
        <%# Résiliation déjà programmée : on rappelle la date de fin d'accès %>
        <%# et on propose de FAIRE MARCHE ARRIÈRE (réactiver) plutôt que de re-résilier. %>
        <p class="sub-note" style="text-align: center;">
          Ton accès Premium reste actif jusqu'au
          <strong><%= @subscription.ends_at.strftime("%d/%m/%Y") %></strong>.
        </p>
        <%= button_to "Réactiver mon abonnement",
              subscription_resume_path,
              method: :post,
              class: "sub-btn-cta" %>
      <% else %>
        <%# Abonnement actif : bouton de résiliation discret en bas de carte %>
        <%= button_to "Résilier l'abonnement",
              subscription_cancel_path,
              method: :post,
              class: "sub-btn-cancel",
              data: { confirm: "Ton accès premium sera maintenu jusqu'à la fin de la période en cours. Confirmes-tu ?" } %>
      <% end %>

    <%# ── Cas 2 : utilisateur gratuit — afficher le CTA ── %>
    <% else %>

      <%# Prix — 9,99€/mois %>
      <div class="sub-price">
        <div class="sub-price-amount">9,99€</div>
        <div class="sub-price-period">par mois · sans engagement</div>
      </div>

      <%# Jauge histoires gratuites (max 3/semaine) %>
      <div class="sub-quota">
        <div class="sub-quota-label">Histoires gratuites cette semaine</div>
        <div class="sub-quota-bar">
          <%# Calcul du pourcentage utilisé sur 3 histoires max %>
          <% pct = [(@stories_this_week.to_f / 3 * 100).round, 100].min %>
          <div class="sub-quota-fill" style="width: <%= pct %>%"></div>
        </div>
        <div class="sub-quota-count"><%= @stories_this_week %> / 3 utilisées</div>
      </div>

      <%# Liste des features incluses en premium %>
      <ul class="sub-features">
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Histoires <strong>illimitées</strong></span>
        </li>
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Mode <strong>interactif</strong> : l'enfant fait des choix</span>
        </li>
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Dashboard parental <strong>avancé</strong></span>
        </li>
        <li class="sub-feature-item">
          <span class="sub-feature-icon">✦</span>
          <span class="sub-feature-label">Accès <strong>prioritaire</strong> aux nouveaux univers</span>
        </li>
      </ul>

      <%# Bouton CTA — soumet le formulaire de checkout Stripe %>
      <%# button_to génère un formulaire POST directement %>
      <%# data-turbo: false → désactive Turbo sur CE formulaire. %>
      <%# Indispensable : le checkout redirige vers un domaine EXTERNE (Stripe). %>
      <%# Turbo soumet en fetch() et ne sait pas suivre une redirection cross-origin %>
      <%# → sans ça, le clic ne fait "rien". On force donc une soumission navigateur classique. %>
      <%= button_to "S'abonner — 9,99€/mois",
            subscription_checkout_path,
            method: :post,
            form: { data: { turbo: false } },
            class: "sub-btn-cta" %>

      <p class="sub-note">Paiement sécurisé par Stripe · Résiliable à tout moment</p>

    <% end %>

  </div>

  <%# ── Tableau comparatif Gratuit vs Premium ── %>
  <%# Visible par tous : aide les gratuits à se décider, rappelle aux premium ce qu'ils ont %>
  <div class="sub-compare">
    <h2 class="sub-section-title">Gratuit ou Premium ?</h2>
    <table class="sub-compare-table">
      <thead>
        <tr>
          <th>Fonctionnalité</th>
          <th class="sub-col-free">Gratuit</th>
          <th class="sub-col-premium">Premium</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Histoires par semaine</td>
          <td class="sub-col-free">3</td>
          <td class="sub-check">Illimitées</td>
        </tr>
        <tr>
          <td>Profils enfants personnalisés</td>
          <td class="sub-check">✓</td>
          <td class="sub-check">✓</td>
        </tr>
        <tr>
          <td>Illustrations générées par IA</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <tr>
          <td>Mode interactif : l'enfant fait des choix</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <tr>
          <td>Lecture vocale des histoires</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <tr>
          <td>Dashboard parental avancé</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
        <tr>
          <td>Nouveaux univers en avant-première</td>
          <td class="sub-dash">—</td>
          <td class="sub-check">✓</td>
        </tr>
      </tbody>
    </table>
  </div>

  <%# ── Mini FAQ — questions fréquentes sur la facturation ── %>
  <%# details/summary natifs : accordéon sans JavaScript %>
  <div class="sub-faq">
    <h2 class="sub-section-title">Questions fréquentes</h2>

    <details class="sub-faq-item">
      <summary>Comment fonctionne la facturation ?</summary>
      <div class="sub-faq-answer">
        L'abonnement coûte 9,99€ par mois, prélevé automatiquement chaque mois
        à la date anniversaire de ton inscription. Le paiement est géré par
        Stripe — nous ne stockons jamais tes coordonnées bancaires.
      </div>
    </details>

    <details class="sub-faq-item">
      <summary>Puis-je annuler à tout moment ?</summary>
      <div class="sub-faq-answer">
        Oui, en un clic depuis cette page, sans justification ni frais.
        Ton accès Premium reste actif jusqu'à la fin de la période déjà payée,
        puis ton compte repasse automatiquement en formule gratuite.
      </div>
    </details>

    <details class="sub-faq-item">
      <summary>Que deviennent mes histoires si j'annule ?</summary>
      <div class="sub-faq-answer">
        Toutes tes histoires restent dans ta bibliothèque et restent lisibles,
        y compris les histoires interactives déjà créées. Seules les nouvelles
        créations repassent aux limites de la formule gratuite.
      </div>
    </details>

    <details class="sub-faq-item">
      <summary>Quels moyens de paiement acceptez-vous ?</summary>
      <div class="sub-faq-answer">
        Toutes les cartes bancaires (Visa, Mastercard, American Express) via
        Stripe, la même plateforme de paiement sécurisée que des millions de
        sites dans le monde.
      </div>
    </details>
  </div>

  <%# Lien retour %>
  <%= link_to "← Retour au dashboard", dashboard_path, class: "sub-back-link" %>

</div>
