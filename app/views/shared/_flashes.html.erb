<%# ============================================================ %>
<%# Flash messages — toasts positionnés en bas à droite %>
<%# Les classes Bootstrap alert-info / alert-warning sont stylées %>
<%# par _alert.scss dans la DA cosmique (fond sombre, bordure colorée) %>
<%# ============================================================ %>

<%# Notice — confirmation (connexion réussie, création OK, etc.) %>
<%# alert-info → bordure dorée dans la DA cosmique %>
<% if notice %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    <%= notice %>
    <%# Bouton de fermeture Bootstrap — coloré en doré via _alert.scss %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
  </div>
<% end %>

<%# Alert — avertissement ou erreur (mauvais mot de passe, quota, etc.) %>
<%# alert-warning → bordure rouge dans la DA cosmique %>
<% if alert %>
  <div class="alert alert-warning alert-dismissible fade show" role="alert">
    <%= alert %>
    <%# Bouton de fermeture Bootstrap — coloré en rouge via _alert.scss %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
  </div>
<% end %>
