<%# ============================================================ %>
<%# Bottom tab bar — navigation type app native (mobile uniquement) %>
<%# ============================================================ %>
<%# Visible seulement sur mobile (≤768px, géré en CSS dans _bottom_nav.scss). %>
<%# 5 onglets : Accueil, Histoires, Créer (central surélevé), Trophées, Profil. %>
<%# Rend Trophées et Espace parent accessibles d'un pouce (avant : cachés dans %>
<%# le dropdown de l'avatar sur mobile). %>
<%#                                                                              %>
<%# L'onglet actif est détecté via controller_name (plus robuste que %>
<%# current_page?, qui ne matche pas les pages de détail comme /stories/:id). %>
<%# ============================================================ %>

<nav class="bottom-nav" aria-label="<%= t('nav.mobile_aria') %>">

  <%# --- Onglet Accueil (dashboard) --- %>
  <%= link_to dashboard_path, class: "bottom-nav-item #{'active' if controller_name == 'dashboard'}" do %>
    <%# Icône maison %>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9.5L12 3l9 6.5"/>
      <path d="M5 10v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V10"/>
      <path d="M9 21v-6h6v6"/>
    </svg>
    <span class="bottom-nav-label"><%= t("nav.home") %></span>
  <% end %>

  <%# --- Onglet Histoires (bibliothèque) --- %>
  <%= link_to stories_path, class: "bottom-nav-item #{'active' if controller_name == 'stories' && action_name != 'new'}" do %>
    <%# Icône livre %>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
    </svg>
    <span class="bottom-nav-label"><%= t("nav.stories") %></span>
  <% end %>

  <%# --- Onglet central Créer — surélevé, pastille dorée (geste principal) --- %>
  <%= link_to new_story_path, class: "bottom-nav-create #{'active' if action_name == 'new'}", "aria-label": t("nav.create") do %>
    <%# Étoile ✦ signature Noctilio %>
    <span class="bottom-nav-create-star">✦</span>
  <% end %>

  <%# --- Onglet Trophées --- %>
  <%= link_to trophy_room_path, class: "bottom-nav-item #{'active' if controller_name == 'trophy_room'}" do %>
    <%# Icône trophée %>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9H4a2 2 0 0 1-2-2V5h4"/>
      <path d="M18 9h2a2 2 0 0 0 2-2V5h-4"/>
      <path d="M6 2h12v7a6 6 0 0 1-12 0V2z"/>
      <path d="M12 15v4"/>
      <path d="M8 19h8"/>
      <line x1="8" y1="22" x2="16" y2="22"/>
    </svg>
    <span class="bottom-nav-label"><%= t("nav.trophies") %></span>
  <% end %>

  <%# --- Onglet Espace parent (suivi de lecture + gestion des enfants) --- %>
  <%# Remplace l'ancien onglet "Profil" : le suivi parental est l'écran le plus %>
  <%# utile au pouce. Mon compte reste accessible via l'avatar du top nav. %>
  <%= link_to parental_path, class: "bottom-nav-item #{'active' if controller_name == 'parental'}" do %>
    <%# Icône utilisateurs (deux personnes) — évoque le suivi familial %>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
    <span class="bottom-nav-label"><%= t("nav.parental_short") %></span>
  <% end %>

</nav>
