<%# ============================================================ %>
<%# Sidebar — navigation verticale pour les utilisateurs connectés %>
<%# Affichée à gauche sur toutes les pages authentifiées %>
<%# ============================================================ %>

<aside class="app-sidebar">

  <%# --- Logo et nom de l'app --- %>
  <div class="sidebar-brand">
    <%= link_to root_path, class: "sidebar-logo-link" do %>
      <%# Icône lune — identité visuelle Noctilio %>
      <div class="sidebar-logo-icon">🌙</div>
      <div class="sidebar-logo-text">
        <span class="sidebar-logo-name">Noctilio</span>
        <%# Sous-titre dynamique selon le nombre d'histoires ce mois %>
        <span class="sidebar-logo-sub">
          <%= current_user.stories_this_month %> histoire<%= current_user.stories_this_month > 1 ? "s" : "" %> ce mois
        </span>
      </div>
    <% end %>
  </div>

  <%# --- Navigation principale --- %>
  <%# current_page? permet de détecter la page active et d'appliquer la classe "active" %>
  <nav class="sidebar-nav">

    <%# Accueil / Dashboard %>
    <% active = current_page?(dashboard_path) %>
    <%= link_to dashboard_path, class: "sidebar-nav-item #{active ? 'active' : ''}" do %>
      <span class="sidebar-nav-icon">
        <%# Icône maison SVG inline pour ne pas dépendre d'une librairie externe %>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </span>
      <span class="sidebar-nav-label">Accueil</span>
    <% end %>

    <%# Mes histoires / Bibliothèque %>
    <% active = current_page?(stories_path) %>
    <%= link_to stories_path, class: "sidebar-nav-item #{active ? 'active' : ''}" do %>
      <span class="sidebar-nav-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </span>
      <span class="sidebar-nav-label">Mes histoires</span>
    <% end %>

    <%# Créer une nouvelle histoire %>
    <% active = current_page?(new_story_path) %>
    <%= link_to new_story_path, class: "sidebar-nav-item #{active ? 'active' : ''}" do %>
      <span class="sidebar-nav-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="16"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
        </svg>
      </span>
      <span class="sidebar-nav-label">Créer</span>
    <% end %>

    <%# Salle des trophées %>
    <% active = current_page?(trophy_room_path) %>
    <%= link_to trophy_room_path, class: "sidebar-nav-item #{active ? 'active' : ''}" do %>
      <span class="sidebar-nav-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="8 6 2 12 8 18"/>
          <path d="M2 12h13"/>
          <path d="M15 6h7l-2 6-5 4 5 4-7-3"/>
        </svg>
      </span>
      <span class="sidebar-nav-label">Trophées</span>
    <% end %>

    <%# Dashboard parental %>
    <% active = current_page?(parental_path) %>
    <%= link_to parental_path, class: "sidebar-nav-item #{active ? 'active' : ''}" do %>
      <span class="sidebar-nav-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </span>
      <span class="sidebar-nav-label">Dashboard parental</span>
    <% end %>

  </nav>

  <%# --- Pied de sidebar : infos utilisateur + déconnexion --- %>
  <div class="sidebar-footer">

    <%# Badge Premium si l'utilisateur est abonné %>
    <% if current_user.premium? %>
      <div class="sidebar-premium-badge">✨ Premium</div>
    <% end %>

    <%# Bouton CTA "Créer une histoire" en bas de sidebar %>
    <%= link_to new_story_path, class: "sidebar-cta-btn" do %>
      <span>✦</span> Créer une histoire
    <% end %>

    <%# Profil utilisateur avec accès déconnexion %>
    <div class="sidebar-user">
      <%# Avatar initiales %>
      <div class="sidebar-user-avatar">
        <%= current_user.first_name[0].upcase %><%= current_user.last_name[0].upcase %>
      </div>
      <div class="sidebar-user-info">
        <span class="sidebar-user-name"><%= current_user.first_name %></span>
        <%# XP points pour gamification %>
        <span class="sidebar-user-xp"><%= current_user.xp_points %> XP</span>
      </div>
      <%# Lien déconnexion (icône) %>
      <%= link_to destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "sidebar-logout-btn",
            title: "Se déconnecter" do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      <% end %>
    </div>

  </div>

</aside>
