<%# ============================================================ %>
<%# Top Nav — barre de navigation transparente style landing page %>
<%# Remplace l'ancienne sidebar verticale %>
<%# Structure : [Logo] [Nav links] [User + CTA] %>
<%# ============================================================ %>

<aside class="app-sidebar">

  <%# --- Logo à gauche --- %>
  <%= link_to root_path, class: "sidebar-brand" do %>
    <%# Mascotte hibou — remplace l'icône lune %>
    <%= image_tag "mascot.png",
          alt:   "Noctilio",
          width: 80,
          height: 80,
          style: "object-fit: contain; flex-shrink: 0;" %>
    <span class="sidebar-logo-name">Noctilio</span>
  <% end %>

  <%# --- Liens de navigation au centre --- %>
  <nav class="sidebar-nav">


    <% active = current_page?(stories_path) %>
    <%= link_to stories_path, class: "sidebar-nav-item #{active ? 'active' : ''}" do %>
      <%# Icône livre %>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
      <span class="sidebar-nav-label"><%= t("nav.stories") %></span>
    <% end %>

    <%# sidebar-nav-item--secondary : caché sur mobile (≤480px), accessible via dropdown avatar %>
    <% active = current_page?(trophy_room_path) %>
    <%= link_to trophy_room_path, class: "sidebar-nav-item sidebar-nav-item--secondary #{active ? 'active' : ''}" do %>
      <%# Icône trophée — coupe + poignées + socle %>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9H4a2 2 0 0 1-2-2V5h4"/>
        <path d="M18 9h2a2 2 0 0 0 2-2V5h-4"/>
        <path d="M6 2h12v7a6 6 0 0 1-12 0V2z"/>
        <path d="M12 15v4"/>
        <path d="M8 19h8"/>
        <line x1="8" y1="22" x2="16" y2="22"/>
      </svg>
      <span class="sidebar-nav-label"><%= t("nav.trophies") %></span>
    <% end %>

    <% active = current_page?(parental_path) %>
    <%= link_to parental_path, class: "sidebar-nav-item sidebar-nav-item--secondary #{active ? 'active' : ''}" do %>
      <%# Icône utilisateurs %>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span class="sidebar-nav-label"><%= t("nav.parental") %></span>
    <% end %>

  </nav>

  <%# --- Zone droite : XP + utilisateur + CTA --- %>
  <div class="sidebar-footer">

    <%# ---------------------------------------------------------------- %>
    <%# Bouton "Installer l'app" — PWA install prompt %>
    <%# Caché par défaut (display:none) — le Stimulus controller le montre %>
    <%# uniquement quand le navigateur signale que l'app est installable %>
    <%# Il disparaît automatiquement une fois l'app installée %>
    <%# data-controller : active le pwa_install_controller.js %>
    <%# data-action : déclenche install() au clic %>
    <%# ---------------------------------------------------------------- %>
    <button
      class="sidebar-install-btn"
      style="display:none"
      data-controller="pwa-install"
      data-action="click->pwa-install#install"
      title="<%= t('nav.install_title') %>"
    >
      <%# Icône téléchargement / flèche vers le bas %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      <span class="sidebar-install-label"><%= t("nav.install") %></span>
    </button>

    <%# Bouton Admin — visible UNIQUEMENT pour les comptes admin.
        Raccourci direct vers le dashboard de statistiques /admin.
        Réutilise le style ghost doré du bouton Abonnement (sidebar-sub-btn).
        La garde require_admin! protège déjà la page côté serveur ; ce bouton
        ne fait que masquer le lien aux non-admins. %>
    <% if current_user.admin? %>
      <%= link_to admin_root_path, class: "sidebar-sub-btn", title: "Admin" do %>
        <%# Icône bouclier — évoque l'espace d'administration %>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span class="sidebar-sub-label">Admin</span>
      <% end %>
    <% end %>

    <%# Bouton Abonnement — accès rapide à la page Premium (style ghost doré) %>
    <%= link_to subscription_path, class: "sidebar-sub-btn", title: t("nav.subscription") do %>
      <%# Icône couronne — évoque le Premium %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 7l5 5 5-7 5 7 5-5-2 12H4L2 7z"/>
      </svg>
      <span class="sidebar-sub-label"><%= t("nav.subscription") %></span>
    <% end %>

    <%# CTA Créer — bouton pill doré %>
    <%= link_to new_story_path, class: "sidebar-cta-btn" do %>
      <%# Étoile ✦ immobile, qui tourne uniquement au survol (variante spin-star--hover) %>
      <span class="spin-star--hover">✦</span> <%= t("nav.create") %>
    <% end %>

    <%# Avatar utilisateur — lien direct vers "Mon compte" %>
    <%# Plus de dropdown : Trophées et Espace parent sont dans la bottom nav, %>
    <%# la déconnexion est dans la page Mon compte. Un seul clic = page compte. %>
    <div class="sidebar-user">
      <%# Pastille niveau — affichée juste à côté de l'avatar %>
      <%# Le niveau vient de User#level (1 niveau tous les 500 XP) %>
      <span class="sidebar-level" title="<%= t('nav.level_title', level: current_user.level) %>">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
        <%= t("nav.level", level: current_user.level) %>
      </span>

      <%# L'avatar mène directement à la page Mon compte %>
      <%= link_to account_path, class: "sidebar-user-avatar", title: t("nav.account") do %>
        <%# nil-safe : un compte Google OAuth peut ne pas avoir de prénom/nom.
            first_name[0] planterait (nil[0]) ; to_s.first.to_s renvoie "" sans erreur. %>
        <%= current_user.first_name.to_s.first.to_s.upcase %><%= current_user.last_name.to_s.first.to_s.upcase %>
      <% end %>
    </div>

  </div>

</aside>
