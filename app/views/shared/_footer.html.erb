<%# ============================================================ %>
<%# Footer global — compact, une seule bande %>
<%# Structure : [Logo] [Hibou animé] [Réseaux sociaux] %>
<%# Canvas étoiles en fond pour continuer l'ambiance nuit du dashboard %>
<%# ============================================================ %>

<footer class="app-footer">

  <%# Canvas étoiles — scintillement doré discret, même palette que le dashboard %>
  <canvas id="footer-stars" class="app-footer__stars" aria-hidden="true"></canvas>

  <%# --- Ligne principale : logo + hibou animé + réseaux sociaux --- %>
  <div class="app-footer__row">

    <%# Logo à gauche — mascotte PNG + nom %>
    <%= link_to root_path, class: "app-footer__logo" do %>
      <%= image_tag "mascot.png", alt: "Noctilio", width: 50, height: 50,
            style: "object-fit: contain; flex-shrink: 0;" %>
      <span class="app-footer__logo-name">Noctilio</span>
    <% end %>

    <%# Réseaux sociaux à droite — SVG inline, pas d'icônes externes %>
    <div class="app-footer__socials">

      <%# Instagram — lien vers le compte @noctilioapp %>
      <a href="https://www.instagram.com/noctilioapp"
         target="_blank"
         rel="noopener noreferrer"
         class="app-footer__social-btn"
         aria-label="Noctilio sur Instagram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>

      <%# TikTok — compte @Noctili5 %>
      <a href="https://www.tiktok.com/@Noctili5"
         target="_blank"
         rel="noopener noreferrer"
         class="app-footer__social-btn"
         aria-label="Noctilio sur TikTok">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.95a8.2 8.2 0 0 0 4.78 1.52V7.03a4.85 4.85 0 0 1-1.01-.34z"/>
        </svg>
      </a>

      <%# Facebook — page Noctilio %>
      <a href="https://www.facebook.com/profile.php?id=61575427511719"
         target="_blank"
         rel="noopener noreferrer"
         class="app-footer__social-btn"
         aria-label="Noctilio sur Facebook">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>

    </div>

  </div>

  <%# --- Barre de copyright — centrée, très fine, en bas --- %>
  <div class="app-footer__bottom">
    <span class="app-footer__copyright">
      © <%= Date.today.year %> Noctilio · Tous droits réservés · Fait avec ✦ pour les familles
    </span>
  </div>

</footer>

<%# ============================================================ %>
<%# JS — Étoiles du footer (version allégée, moins dense que le dashboard) %>
<%# ============================================================ %>
<script nonce="<%= content_security_policy_nonce %>">
(function() {
  // turbo:load se déclenche à chaque navigation Turbo — pas seulement au premier chargement
  document.addEventListener('turbo:load', function() {
    const canvas = document.getElementById('footer-stars');
    if (!canvas) return;

    const ctx  = canvas.getContext('2d');
    let stars  = [];

    // Redimensionne le canvas à la taille réelle du footer
    function resize() {
      const footer = canvas.parentElement;
      canvas.width  = footer.offsetWidth;
      canvas.height = footer.offsetHeight;
      createStars();
    }

    // Crée 80 étoiles — moins dense que le dashboard (250), adapté à la hauteur du footer
    function createStars() {
      stars = [];
      for (let i = 0; i < 80; i++) {
        stars.push({
          x:     Math.random() * canvas.width,
          y:     Math.random() * canvas.height,
          r:     Math.random() * 1.0 + 0.3,   // Petites étoiles — subtiles
          speed: Math.random() * 0.003 + 0.001,
          phase: Math.random() * Math.PI * 2
        });
      }
    }

    // Scintillement doré — même couleur que le dashboard (240, 201, 122)
    function draw(t) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(function(s) {
        const alpha = 0.15 + 0.35 * Math.sin(s.phase + t * s.speed);
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(240, 201, 122, ' + alpha + ')';
        ctx.fill();
      });
      requestAnimationFrame(draw);
    }

    resize();
    requestAnimationFrame(draw);

    // Recalcule si la fenêtre change de taille
    window.addEventListener('resize', resize);
  });
})();
</script>
