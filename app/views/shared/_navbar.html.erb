<%# ============================================================ %>
<%# Navbar Noctilio — adaptée selon l'état de connexion %>
<%# ============================================================ %>

<nav class="navbar navbar-expand-md navbar-light bg-white shadow-sm">
  <div class="container">
    <%# Logo et nom de l'app %>
    <%= link_to root_path, class: "navbar-brand fw-bold d-flex align-items-center gap-2" do %>
      <span style="font-size: 1.5rem;">🌙</span>
      <span>Noctilio</span>
    <% end %>

    <%# Bouton toggle pour mobile %>
    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNoctilio"
            aria-controls="navbarNoctilio"
            aria-expanded="false"
            aria-label="Menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNoctilio">
      <% if user_signed_in? %>
        <%# Navigation principale (utilisateur connecté) %>
        <ul class="navbar-nav me-auto gap-1">
          <li class="nav-item">
            <%= link_to "🏠 Accueil", dashboard_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "📚 Mes histoires", stories_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "✨ Créer", new_story_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "🧒 Mes héros", children_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "🏆 Trophées", trophy_room_path, class: "nav-link" %>
          </li>
        </ul>

        <%# Menu utilisateur (dropdown) %>
        <ul class="navbar-nav ms-auto">
          <%# Badge Premium si abonné %>
          <% if current_user.premium? %>
            <li class="nav-item d-flex align-items-center me-2">
              <span class="badge bg-primary px-2 py-1">✨ Premium</span>
            </li>
          <% end %>

          <%# Dropdown profil %>
          <li class="nav-item dropdown">
            <a href="#" class="nav-link dropdown-toggle d-flex align-items-center gap-2"
               id="userDropdown"
               data-bs-toggle="dropdown"
               aria-expanded="false">
              <span class="fw-semibold"><%= current_user.first_name %></span>
            </a>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
              <%= link_to "👨‍👩‍👧 Dashboard parental", parental_path, class: "dropdown-item" %>
              <%= link_to "💳 Mon abonnement", subscription_path, class: "dropdown-item" %>
              <div class="dropdown-divider"></div>
              <%= link_to "Déconnexion", destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "dropdown-item text-danger" %>
            </div>
          </li>
        </ul>

      <% else %>
        <%# Navigation publique (non connecté) %>
        <ul class="navbar-nav ms-auto gap-2">
          <li class="nav-item">
            <%= link_to "Se connecter", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Commencer gratuitement", new_user_registration_path,
                  class: "btn btn-primary btn-sm" %>
          </li>
        </ul>
      <% end %>
    </div>
  </div>
</nav>
