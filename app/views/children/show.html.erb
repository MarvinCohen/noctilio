<%# ============================================================ %>
<%# Profil d'un enfant — affiche ses infos et ses histoires %>
<%# ============================================================ %>

<div class="container py-4">

  <%# En-tête : nom de l'enfant + actions %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
      <%# Avatar avec initiale %>
      <div class="child-show-avatar"><%= @child.name[0].upcase %></div>
      <div>
        <h1 class="fw-bold mb-0"><%= @child.name %></h1>
        <p class="text-muted mb-0"><%= @child.age %> ans</p>
      </div>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "✏️ Modifier", edit_child_path(@child), class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "✨ Créer une histoire", new_story_path(child_id: @child.id), class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  <%# Histoires de cet enfant %>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h2 class="h5 fw-bold mb-3">Ses histoires</h2>

      <% if @stories.any? %>
        <div class="d-flex flex-column gap-2">
          <% @stories.each do |story| %>
            <div class="d-flex align-items-center p-3 rounded-3 bg-light">
              <div class="me-3 fs-3"><%= story.world_emoji %></div>
              <div class="flex-grow-1">
                <div class="fw-semibold"><%= story.title || "Histoire sans titre" %></div>
                <small class="text-muted"><%= story.world_label %> · <%= story.duration_minutes %> min · <%= story.created_at.strftime("%d/%m/%Y") %></small>
              </div>
              <%= link_to "Lire", story_path(story), class: "btn btn-sm btn-outline-primary" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted text-center py-4">
          Aucune histoire pour l'instant.<br>
          <%= link_to "Créer la première ✨", new_story_path(child_id: @child.id) %>
        </p>
      <% end %>
    </div>
  </div>

</div>
