<%# ============================================================ %>
<%# Formulaire partagé pour créer et modifier un profil enfant %>
<%# Utilisé par new.html.erb et edit.html.erb %>
<%# DA cosmique : cartes dark ch-form-section, inputs sombres, labels uppercase %>
<%# Les styles sont définis dans _children.scss %>
<%# ============================================================ %>

<%= simple_form_for child, url: child.new_record? ? children_path : child_path(child) do |f| %>
  <%= f.error_notification %>

  <%# ── Section 1 : Informations de base ── %>
  <div class="ch-form-section mb-0">
    <h2 class="ch-form-section-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg><%= t("children.form.section_basic") %>
    </h2>

    <div class="row g-3">
      <div class="col-md-6">
        <%# Prénom du héros — obligatoire %>
        <%= f.input :name,
              label: t("children.form.name_label"),
              placeholder: t("children.form.name_placeholder"),
              input_html: { class: "form-control" } %>
      </div>
      <div class="col-md-3">
        <%# Âge — nombre entier entre 1 et 15 %>
        <%= f.input :age,
              label: t("children.form.age_label"),
              as: :integer,
              input_html: { class: "form-control", min: 1, max: 15 } %>
      </div>
      <div class="col-md-3">
        <%# Genre — sélection simple avec placeholder %>
        <%# Les libellés sont traduits ; les valeurs (boy/girl) restent stables %>
        <%= f.input :gender,
              label: t("children.form.gender_label"),
              as: :select,
              collection: [[t("children.form.gender_boy"), "boy"], [t("children.form.gender_girl"), "girl"]],
              include_blank: t("children.form.gender_blank"),
              input_html: { class: "form-select" } %>
      </div>
    </div>
  </div>

  <%# Séparateur visuel entre les sections %>
  <div class="ch-divider"></div>

  <%# ── Section 2 : Apparence (optionnel) ── %>
  <%# Les options sont des radio buttons stylisés en pills (badge-check) avec un point coloré %>
  <%# Approche pure CSS — :has(input:checked) gère la sélection, pas de Stimulus %>
  <%# display:inline-flex !important sur .color-badge override la règle globale label{display:block} %>
  <div class="ch-form-section mb-0">
    <h2 class="ch-form-section-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><circle cx="13.5" cy="6.5" r="2.5"/><path d="M17 10.5V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h8.5"/><path d="m3 15 4-4 4 4 4-4"/></svg><%= t("children.form.section_appearance") %>
    </h2>
    <p class="ch-form-hint"><%= t("children.form.appearance_hint") %></p>

    <%# ── Cheveux ── %>
    <%# Chaque label.color-badge contient un radio caché + un point coloré + le nom %>
    <div class="color-field">
      <span class="color-field-label"><%= t("children.form.hair_label") %></span>
      <div class="color-field-options">
        <%# [clé stable stockée en base, couleur du point] — le libellé est traduit via i18n %>
        <% [["black","#1a1108"],["dark_brown","#3d2314"],["brown","#6b3a22"],["dark_blonde","#9c6f2a"],["blonde","#c9a84c"],["light_blonde","#e8d5a3"],["red","#8b3a0f"],["white","#e8e4d8"]].each do |key, col| %>
          <label class="color-badge">
            <input type="radio" name="child[hair_color]" value="<%= key %>" <% if child.hair_color == key %>checked<% end %>>
            <span class="color-badge-dot" style="background:<%= col %>;<%= col == '#e8e4d8' ? 'border:1px solid rgba(0,0,0,0.2)' : '' %>"></span>
            <%= t("children.appearance.hair.#{key}") %>
          </label>
        <% end %>
      </div>
    </div>

    <%# ── Yeux ── %>
    <div class="color-field">
      <span class="color-field-label"><%= t("children.form.eyes_label") %></span>
      <div class="color-field-options">
        <%# [clé stable stockée en base, couleur du point] — le libellé est traduit via i18n %>
        <% [["dark_brown","#2d1200"],["brown","#6b3a2a"],["hazel","#8b6520"],["dark_green","#2d5a27"],["green","#3a8c4a"],["light_green","#52b788"],["dark_blue","#1a3a6b"],["blue","#2d6aab"],["light_blue","#74b3ce"],["grey","#7a7a8a"]].each do |key, col| %>
          <label class="color-badge">
            <input type="radio" name="child[eye_color]" value="<%= key %>" <% if child.eye_color == key %>checked<% end %>>
            <span class="color-badge-dot" style="background:<%= col %>"></span>
            <%= t("children.appearance.eyes.#{key}") %>
          </label>
        <% end %>
      </div>
    </div>

    <%# ── Teinte de peau ── %>
    <div class="color-field">
      <span class="color-field-label"><%= t("children.form.skin_label") %></span>
      <div class="color-field-options">
        <%# [clé stable stockée en base, couleur du point] — le libellé est traduit via i18n %>
        <% [["ebony","#2d1b0e"],["dark_brown","#4a2c12"],["brown","#7c4a1e"],["caramel","#c68a4a"],["golden","#d4a853"],["olive","#c4a882"],["beige","#e8c99a"],["light","#f5deb3"],["very_light","#fef0e7"]].each do |key, col| %>
          <label class="color-badge">
            <input type="radio" name="child[skin_tone]" value="<%= key %>" <% if child.skin_tone == key %>checked<% end %>>
            <span class="color-badge-dot" style="background:<%= col %>;<%= ['#e8c99a','#f5deb3','#fef0e7'].include?(col) ? 'border:1px solid rgba(0,0,0,0.15)' : '' %>"></span>
            <%= t("children.appearance.skin.#{key}") %>
          </label>
        <% end %>
      </div>
    </div>

  </div>

  <%# Séparateur visuel %>
  <div class="ch-divider"></div>

  <%# ── Section 3 : Personnalité ── %>
  <div class="ch-form-section mb-0">
    <h2 class="ch-form-section-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg><%= t("children.form.section_personality") %>
    </h2>

    <%# Traits de personnalité — pills checkboxes (badge-check) %>
    <div class="mb-4">
      <span class="ch-form-hint" style="display:block; margin-bottom: 0.6rem;"><%= t("children.form.traits_label") %></span>
      <div class="d-flex flex-wrap gap-2">
        <%# clé stable stockée en base ; le libellé affiché est traduit via i18n %>
        <% %w[brave curious shy funny generous creative adventurous gentle].each do |trait| %>
          <%# badge-check : checkbox cachée, label joue le rôle de bouton %>
          <%# :has(input:checked) → style doré si sélectionné (via _children.scss) %>
          <label class="badge-check">
            <% if child.personality_traits&.include?(trait) %>
              <input type="checkbox" name="child[personality_traits][]" value="<%= trait %>" class="d-none" checked>
            <% else %>
              <input type="checkbox" name="child[personality_traits][]" value="<%= trait %>" class="d-none">
            <% end %>
            <%= t("children.appearance.traits.#{trait}") %>
          </label>
        <% end %>
      </div>
    </div>

    <%# Centres d'intérêt — même système badge-check %>
    <div class="mb-4">
      <span class="ch-form-hint" style="display:block; margin-bottom: 0.6rem;"><%= t("children.form.hobbies_label") %></span>
      <div class="d-flex flex-wrap gap-2">
        <%# Le libellé est traduit via une clé i18n ; la valeur stockée reste stable %>
        <% [
          [t("children.form.hobby_space"), "espace"], [t("children.form.hobby_dinos"), "dinosaures"], [t("children.form.hobby_sport"), "sport"],
          [t("children.form.hobby_drawing"), "dessin"], [t("children.form.hobby_animals"), "animaux"], [t("children.form.hobby_science"), "science"],
          [t("children.form.hobby_music"), "musique"], [t("children.form.hobby_books"), "livres"]
        ].each do |label, value| %>
          <label class="badge-check">
            <% if child.hobbies&.include?(value) %>
              <input type="checkbox" name="child[hobbies][]" value="<%= value %>" class="d-none" checked>
            <% else %>
              <input type="checkbox" name="child[hobbies][]" value="<%= value %>" class="d-none">
            <% end %>
            <%= label %>
          </label>
        <% end %>
      </div>
    </div>

    <%# Description libre — textarea sombre %>
    <%= f.input :child_description,
          label: t("children.form.description_label"),
          as: :text,
          placeholder: t("children.form.description_placeholder"),
          input_html: { class: "form-control", rows: 3 } %>
  </div>

  <%# ── Consentement parental (RGPD) — uniquement à la création ── %>
  <%# new_record? : la case n'est affichée que pour un nouveau profil, %>
  <%# pas en modification (la validation est on: :create côté modèle) %>
  <% if child.new_record? %>
    <div class="ch-divider"></div>
    <div class="ch-form-section mb-0">
      <%# label englobe la checkbox → cliquer le texte coche la case %>
      <label style="display: flex; align-items: flex-start; gap: 0.6rem; cursor: pointer; color: rgba(212, 207, 196, 0.8); font-size: 0.88rem; line-height: 1.5;">
        <%# f.check_box envoie "0" si décochée, "1" si cochée — %>
        <%# c'est ce "0" qui déclenche l'erreur de validation acceptance %>
        <%= f.check_box :parental_consent, style: "margin-top: 3px; flex-shrink: 0; accent-color: #f0c97a;" %>
        <span>
          <%= t("children.form.consent_before") %>
          <%= link_to t("children.form.consent_link"), "/confidentialite", target: "_blank", style: "color: #f0c97a;" %>.
        </span>
      </label>
    </div>
  <% end %>

  <%# ── Boutons d'action ── %>
  <div class="ch-form-actions mt-3">
    <%# Bouton submit — fond doré pill %>
    <%= f.submit child.new_record? ? t("children.form.submit_create") : t("children.form.submit_update"),
          class: "ch-btn-submit" %>

    <%# Bouton annuler — outline doré transparent %>
    <%= link_to t("children.form.cancel"), children_path, class: "ch-btn-cancel" %>
  </div>

<% end %>
