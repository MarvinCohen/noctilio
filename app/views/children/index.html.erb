<%# ============================================================ %>
<%# Liste des profils enfants de l'utilisateur %>
<%# DA cosmique : cartes dark #111527, accents dorés #f0c97a %>
<%# ============================================================ %>

<div class="container py-5">

  <%# En-tête : titre Cormorant Garamond + bouton CTA pill doré %>
  <div class="ch-page-header">
    <div>
      <%# Titre principal — Cormorant Garamond italic, couleur Cream %>
      <h1 class="ch-page-title"><%= t("children.index_title") %></h1>
      <%# Sous-titre discret en text-dim %>
      <p class="ch-page-subtitle"><%= t("children.index_subtitle") %></p>
    </div>

    <%# Bouton pill doré — crée un nouveau profil enfant %>
    <%= link_to new_child_path, class: "ch-btn-primary" do %>
      <%= t("children.new_hero") %>
    <% end %>
  </div>

  <%# -------------------------------------------------------- %>
  <%# Grille de cartes ou état vide %>
  <%# -------------------------------------------------------- %>

  <% if @children.any? %>

    <%# Grille responsive — 3 colonnes desktop, 2 tablette, 1 mobile %>
    <div class="ch-grid">
      <% @children.each do |child| %>

        <%# Carte d'un profil enfant %>
        <div class="ch-card">

          <%# Corps de la carte : avatar + nom + âge + traits %>
          <div class="ch-card-body">

            <%# Avatar DiceBear personnalisé selon la couleur de peau et de cheveux de l'enfant %>
            <%# dicebear_avatar_url(child) construit l'URL avec les bons paramètres de couleur %>
            <div class="ch-avatar-circle">
              <%= image_tag dicebear_avatar_url(child),
                    alt: child.name,
                    width: 80,
                    height: 80,
                    style: "border-radius: 50%; object-fit: cover;" %>
            </div>

            <%# Nom en Cormorant Garamond italic %>
            <h3 class="ch-child-name"><%= child.name %></h3>

            <%# Âge en text-dim — libellé partagé avec l'espace parent %>
            <p class="ch-child-age"><%= t("parental.age", age: child.age) %></p>

            <%# Traits de personnalité — pills dorés %>
            <%# Affichés uniquement s'il en existe au moins un %>
            <% if child.personality_traits.present? %>
              <div class="ch-traits">
                <%# trait = clé stable stockée en base ; on affiche le libellé traduit %>
                <% child.personality_traits.each do |trait| %>
                  <span class="ch-trait-pill"><%= t("children.appearance.traits.#{trait}") %></span>
                <% end %>
              </div>
            <% end %>

            <%# Compteur d'histoires complètes — badge doré %>
            <%# Nombre rendu en gras, mot pluralisé via i18n (one/other) %>
            <% completed_count = child.stories.completed.count %>
            <p class="ch-story-count">
              <strong><%= completed_count %></strong>
              <%= t("children.stories_word", count: completed_count) %>
            </p>

          </div><%# /ch-card-body %>

          <%# Pied de carte : boutons d'action %>
          <div class="ch-card-footer">

            <%# Créer une histoire — CTA principal en pill doré %>
            <%= link_to new_story_path(child_id: child.id), class: "ch-btn-primary" do %>
              <%# Étoile ✦ immobile, qui tourne uniquement au survol (variante spin-star--hover) %>
              <span class="spin-star--hover" style="margin-right:4px">✦</span><%= t("children.create") %>
            <% end %>

            <%# Modifier le profil — outline doré %>
            <%= link_to edit_child_path(child), class: "ch-btn-secondary" do %>
              <%= t("children.edit") %>
            <% end %>

            <%# Supprimer le profil — outline rouge, avec confirmation Turbo %>
            <%= button_to child_path(child),
                  method: :delete,
                  class: "ch-btn-danger",
                  data: { turbo_confirm: t("children.delete_confirm", name: child.name) } do %>
              <%= t("children.delete") %>
            <% end %>

          </div><%# /ch-card-footer %>

        </div><%# /ch-card %>

      <% end %>
    </div><%# /ch-grid %>

  <% else %>

    <%# État vide — affiché quand l'utilisateur n'a aucun profil enfant %>
    <div class="ch-empty-state">
      <%# Emoji central — légèrement transparent pour l'ambiance %>
      <span class="ch-empty-emoji">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </span>

      <%# Titre de l'état vide — Cormorant italic %>
      <h2><%= t("children.empty_title") %></h2>

      <%# Description invitant à créer un premier profil %>
      <p><%= t("children.empty_desc") %></p>

      <%# CTA pill doré — lien vers la page de création %>
      <%= link_to new_child_path, class: "ch-btn-primary" do %>
        <%= t("children.empty_cta") %>
      <% end %>
    </div>

  <% end %>

</div>
