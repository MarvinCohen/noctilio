<%# ============================================================ %>
<%# Liste des profils enfants de l'utilisateur %>
<%# ============================================================ %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold">Mes héros</h1>
      <p class="text-muted">Les profils de vos enfants pour personnaliser leurs histoires</p>
    </div>
    <%= link_to "+ Nouveau profil", new_child_path, class: "btn btn-primary" %>
  </div>

  <% if @children.any? %>
    <div class="row g-4">
      <% @children.each do |child| %>
        <div class="col-md-6 col-lg-4">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4 text-center">
              <%# Avatar emoji selon le genre %>
              <div class="mb-3" style="font-size: 3.5rem;">
                <%= child.gender == "girl" ? "👧" : "🧒" %>
              </div>
              <h3 class="fw-bold"><%= child.name %></h3>
              <p class="text-muted"><%= child.age %> ans</p>

              <%# Traits de personnalité %>
              <% if child.personality_traits.present? %>
                <div class="d-flex flex-wrap gap-1 justify-content-center mb-3">
                  <% child.personality_traits.each do |trait| %>
                    <span class="badge bg-primary bg-opacity-10 text-primary"><%= trait %></span>
                  <% end %>
                </div>
              <% end %>

              <%# Nombre d'histoires créées pour cet enfant %>
              <p class="small text-muted">
                <%= child.stories.completed.count %> histoire<%= "s" if child.stories.completed.count > 1 %>
              </p>
            </div>

            <div class="card-footer bg-transparent border-0 p-3 d-flex gap-2 justify-content-center">
              <%= link_to "✨ Créer une histoire", new_story_path(child_id: child.id), class: "btn btn-sm btn-primary" %>
              <%= link_to "Modifier", edit_child_path(child), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Supprimer", child_path(child), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    data: { turbo_confirm: "Supprimer #{child.name} et toutes ses histoires ?" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-6">
      <div class="mb-3" style="font-size: 5rem;">🧒</div>
      <h2 class="h4 fw-bold mb-3">Aucun profil créé</h2>
      <p class="text-muted mb-4">Créez le profil de votre enfant pour personnaliser ses histoires.</p>
      <%= link_to "+ Créer le premier profil", new_child_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
