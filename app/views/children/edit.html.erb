<%# Page de modification d'un profil enfant %>
<%# DA cosmique : titre Cormorant Garamond, formulaire via _form.html.erb %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <%# Titre Cormorant Garamond italic avec le prénom de l'enfant %>
      <h1 class="ch-form-title">Modifier <%= @child.name %></h1>
      <p class="ch-form-subtitle">Mettez à jour le profil de votre héros</p>

      <%# Le formulaire partagé (new + edit) %>
      <%= render "form", child: @child %>

    </div>
  </div>
</div>
