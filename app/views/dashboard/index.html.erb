<%# ============================================================ %>
<%# Dashboard — ambiance landing page %>
<%# Contenu flottant dans le vide cosmique, pas de cartes conventionnelles %>
<%# Étoiles, lune, typographie éditoriale Cormorant Garamond %>
<%# ============================================================ %>

<%# full_bleed : le dashboard gère son propre fond (pas de carte blanche du layout) %>
<% content_for :full_bleed, true %>

<%# ---------------------------------------------------------------- %>
<%# Textures et effets d'arrière-plan %>
<%# ---------------------------------------------------------------- %>

<%# Texture de bruit — même que la landing, donne le côté "filmic" premium %>
<div class="db-noise"></div>

<%# Canvas étoiles animées — même logique que la landing page %>
<canvas id="db-stars" class="db-stars-canvas"></canvas>

<%# Canvas sillage doré — trail qui suit le curseur comme sur la landing %>
<canvas id="db-trail" class="db-trail-canvas"></canvas>

<%# ================================================================ %>
<%# ONBOARDING PREMIÈRE FOIS — utilisateur sans aucun héros %>
<%# ================================================================ %>
<%# Détection : @children est vide (compte neuf). On affiche un parcours %>
<%# plein écran qui présente les 3 étapes (héros → univers → 1re histoire %>
<%# offerte) puis renvoie vers le formulaire de création de héros. %>
<%# Dès qu'un héros existe, c'est le dashboard normal qui s'affiche. %>
<% if @children.empty? %>
  <%= render "dashboard/onboarding" %>

<% else %>

<%# ---------------------------------------------------------------- %>
<%# HERO — flotte dans le vide, pas de carte %>
<%# ---------------------------------------------------------------- %>
<section class="db-hero">

  <%# Lune réelle — canvas dessiné en JS selon la phase lunaire du jour %>
  <%# data-phase transmis depuis le controller (0.0 = nouvelle, 0.5 = pleine) %>
  <canvas id="db-moon-canvas"
          class="db-hero-moon"
          data-phase="<%= @moon_phase %>"
          width="160" height="160"
          aria-label="Phase de la lune ce soir"></canvas>

  <%# Nébuleuse — halo diffus derrière le titre %>
  <div class="db-hero-nebula"></div>

  <%# Signature typographique centrée — "Noctilio" + chouette en haut du hero %>
  <%# aria-hidden : élément purement décoratif %>
  <div class="db-noctilio-display" aria-hidden="true">
    <%# Mascotte hibou — remplace l'emoji 🦉 %>
    <%= image_tag "mascot.svg", alt: "", class: "db-owl-img", width: 110, height: 110,
          style: "object-fit: contain;" %>
    <div class="db-owl-perch"></div>
    <p class="db-noctilio-word">Noctilio</p>
    <div class="db-noctilio-sparks">
      <span class="db-spark db-spark--1">✦</span>
      <span class="db-spark db-spark--2">✦</span>
      <span class="db-spark db-spark--3">✦</span>
    </div>
  </div>

  <%# Contenu centré en dessous du logo %>
  <div class="db-hero-text">

    <%# Eyebrow — petit texte doré espacé, style landing %>
    <p class="db-eyebrow"><%= t("dashboard.hero_eyebrow") %></p>

    <%# Titre principal — Cormorant Garamond, énorme, aérien %>
    <%# Clé _html : contient <br> et <em>, rendue en HTML brut par t() %>
    <h1 class="db-hero-title">
      <%= t("dashboard.hero_title_html") %>
    </h1>

    <%# Description %>
    <p class="db-hero-desc">
      <%= t("dashboard.hero_desc") %>
    </p>

    <%# CTA normal — pill doré, même style que landing %>
    <%# (Le cas "aucun héros" n'arrive jamais ici : l'onboarding plein écran %>
    <%# est rendu à la place du dashboard quand @children est vide — voir plus haut.) %>
    <%= link_to new_story_path, class: "db-cta-btn" do %>
      <span class="spin-star--hover">✦</span> <%= t("dashboard.cta") %>
    <% end %>

    <%# Limite gratuite — discrète %>
    <% unless current_user.premium? %>
      <p class="db-limit-text">
        <%= t("dashboard.weekly_limit", count: @stories_this_week) %>
        <%= link_to t("dashboard.go_premium"), subscription_path, class: "db-limit-link" %>
      </p>
    <% end %>

  </div>

  <%# Alerte histoires en cours — discrète, sous le hero %>
  <% if @pending_stories.any? %>
    <div class="db-generating-alert">
      <span class="db-generating-dot"></span>
      <%# Pluralisation gérée par I18n (clés one / other) %>
      <%= t("dashboard.generating", count: @pending_stories.count) %>
      <%= link_to t("dashboard.see"), story_path(@pending_stories.first), class: "db-generating-link" %>
    </div>
  <% end %>

</section>

<%# ================================================================ %>
<%# RITUEL DU SOIR — carte progression + constellation (esprit app mobile) %>
<%# Affichée seulement si l'utilisateur a déjà un héros (compte configuré). %>
<%# 1) Orbe de niveau + barre XP : montre l'avancement de façon ludique. %>
<%# 2) Constellation des 7 derniers soirs : habitude douce, jamais punitive. %>
<%# 3) Suggestion "histoire du soir" : reprise en 1 tap. %>
<%# ================================================================ %>
<% if @children.any? %>
  <section class="db-ritual" data-reveal="up">

    <%# --- Carte progression : orbe de niveau + barre XP + trophées --- %>
    <div class="db-ritual-card">

      <%# Orbe de niveau — pastille dorée avec le chiffre du niveau au centre %>
      <div class="db-ritual-orb">
        <span class="db-ritual-orb-level"><%= @level %></span>
        <span class="db-ritual-orb-label"><%= t("dashboard.level") %></span>
      </div>

      <%# Bloc droite : barre XP + méta (XP restant, nombre de trophées) %>
      <div class="db-ritual-progress">

        <%# Ligne titre + nombre de trophées %>
        <div class="db-ritual-progress-head">
          <span class="db-ritual-progress-title"><%= t("dashboard.progress") %></span>
          <%# Lien vers la salle des trophées — compteur de badges obtenus %>
          <%= link_to trophy_room_path, class: "db-ritual-trophies" do %>
            <span class="db-ritual-trophies-icon">✦</span>
            <%# Pluralisation gérée par I18n (clés one / other) %>
            <%= t("dashboard.trophies", count: @badges_count) %>
          <% end %>
        </div>

        <%# Barre XP — largeur pilotée par level_progress (0 à 100 %) %>
        <%# inline style uniquement pour la largeur dynamique (impossible en SCSS pur) %>
        <div class="db-ritual-xpbar" role="progressbar"
             aria-valuenow="<%= @level_progress %>" aria-valuemin="0" aria-valuemax="100">
          <div class="db-ritual-xpbar-fill" style="width: <%= @level_progress %>%;"></div>
        </div>

        <%# XP restant avant le prochain niveau — message d'encouragement %>
        <p class="db-ritual-xp-text">
          <%= t("dashboard.xp_to_next", xp: @xp_to_next, level: @level + 1) %>
        </p>
      </div>
    </div>

    <%# --- Constellation des 7 derniers soirs --- %>
    <%# Chaque étoile = un soir. Allumée si une histoire a été créée ce jour-là. %>
    <div class="db-constellation">
      <p class="db-constellation-label"><%= t("dashboard.last_7_nights") %></p>
      <div class="db-constellation-stars">
        <% @constellation.each do |lit| %>
          <%# Étoile dorée si soir "allumé", sinon point discret (pas de croix rouge : %>
          <%# on valorise, on ne punit jamais un soir manqué). %>
          <span class="db-constellation-star <%= 'db-constellation-star--lit' if lit %>">✦</span>
        <% end %>
      </div>
    </div>

    <%# --- Suggestion "histoire du soir" — reprise en 1 tap --- %>
    <% if @suggested_story.present? %>
      <%= link_to story_path(@suggested_story), class: "db-suggestion" do %>
        <%# Vignette de couverture (ou emoji d'univers en repli) %>
        <% if @suggested_story.cover_image_source.present? %>
          <%= image_tag @suggested_story.cover_image_source, alt: @suggested_story.title,
                class: "db-suggestion-cover" %>
        <% else %>
          <span class="db-suggestion-cover db-suggestion-cover--emoji">
            <%= @suggested_story.world_emoji %>
          </span>
        <% end %>

        <%# Texte : libellé + titre de l'histoire suggérée %>
        <span class="db-suggestion-text">
          <span class="db-suggestion-eyebrow"><%= t("dashboard.bedtime_story") %></span>
          <span class="db-suggestion-title"><%= @suggested_story.title %></span>
        </span>

        <%# Flèche de reprise %>
        <span class="db-suggestion-arrow">→</span>
      <% end %>
    <% end %>

  </section>
<% end %>

<%# ---------------------------------------------------------------- %>
<%# Séparateur vertical doré — inspiré de la landing %>
<%# ---------------------------------------------------------------- %>
<div class="db-divider"></div>

<%# ================================================================ %>
<%# REPRENDRE LA LECTURE — dernières histoires terminées %>
<%# Affichée seulement si l'utilisateur a déjà des histoires %>
<%# @recent_stories : 5 dernières histoires complétées (chargées avec includes(:child)) %>
<%# ================================================================ %>
<% if @recent_stories.any? %>
  <section class="db-section db-section--centered">

    <div class="db-section-head db-section-head--centered" data-reveal="up">
      <p class="db-eyebrow db-eyebrow--small"><%= t("dashboard.resume_eyebrow") %></p>
      <h2 class="db-section-title"><%= t("dashboard.resume_title") %></h2>
    </div>

    <%# Grille de cartes histoires — flex centré, wrap sur mobile %>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.25rem; max-width: 980px; margin: 0 auto;">
      <% @recent_stories.each_with_index do |story, i| %>
        <%# Toute la carte est cliquable → page de lecture de l'histoire %>
        <%= link_to story_path(story), data: { reveal: "up" }, style: "--reveal-delay: #{i * 100}ms; text-decoration: none; width: 280px; background: #111527; border: 1px solid rgba(240, 201, 122, 0.15); border-radius: 16px; overflow: hidden; display: block;" do %>

          <%# Couverture — version ActiveStorage si attachée, sinon URL OpenAI %>
          <% if story.cover_image_source.present? %>
            <%= image_tag story.cover_image_source, alt: story.title,
                  style: "width: 100%; height: 150px; object-fit: cover; display: block;" %>
          <% else %>
            <%# Pas d'image — placeholder avec l'emoji de l'univers %>
            <div style="width: 100%; height: 150px; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; background: rgba(240, 201, 122, 0.05);">
              <%= story.world_emoji %>
            </div>
          <% end %>

          <div style="padding: 1rem 1.1rem;">
            <%# Titre de l'histoire — tronqué à 2 lignes max via line-clamp %>
            <div style="color: #d4cfc4; font-weight: 600; font-size: 0.95rem; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
              <%= story.title %>
            </div>
            <%# Prénom de l'enfant + univers — méta discrète %>
            <div style="color: rgba(212, 207, 196, 0.55); font-size: 0.8rem; margin-top: 0.4rem;">
              <%= story.world_emoji %> <%= story.child.name %> · <%= story.world_label %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Lien vers la bibliothèque complète %>
    <div style="text-align: center; margin-top: 1.75rem;">
      <%= link_to t("dashboard.see_all_library"), stories_path,
            style: "color: #f0c97a; text-decoration: none; font-size: 0.9rem;" %>
    </div>

  </section>

  <div class="db-divider"></div>
<% end %>

<%# ================================================================ %>
<%# MES HÉROS — raccourcis vers les profils enfants %>
<%# Affichée seulement si au moins un profil existe (sinon le hero gère l'onboarding) %>
<%# ================================================================ %>
<% if @children.any? %>
  <section class="db-section db-section--centered db-section--last">

    <div class="db-section-head db-section-head--centered" data-reveal="up">
      <p class="db-eyebrow db-eyebrow--small"><%= t("dashboard.heroes_eyebrow") %></p>
      <h2 class="db-section-title"><%= t("dashboard.heroes_title") %></h2>
    </div>

    <%# Cartes héros — avatar rond en grand, prénom + âge dessous, cliquables vers le profil %>
    <%# Format carte (plus chaleureux que les anciennes pills) : grille flex centrée, wrap sur mobile %>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.25rem;" data-reveal="up">
      <% @children.each_with_index do |child, i| %>
        <%# Carte verticale cliquable → fiche du héros. --reveal-delay décale l'apparition de chaque carte. %>
        <%= link_to child_path(child),
              data: { reveal: "up" },
              style: "--reveal-delay: #{i * 80}ms; display: flex; flex-direction: column; align-items: center; gap: 0.65rem; width: 150px; padding: 1.4rem 1rem 1.2rem; background: #111527; border: 1px solid rgba(240, 201, 122, 0.18); border-radius: 18px; text-decoration: none; transition: transform 0.2s ease, border-color 0.2s ease;" do %>
          <%# Avatar DiceBear personnalisé (mêmes couleurs peau/cheveux que la fiche enfant). %>
          <%# Cerclé d'un anneau doré discret pour le mettre en valeur. %>
          <%= image_tag dicebear_avatar_url(child),
                alt: child.name,
                width: 72,
                height: 72,
                style: "width: 72px; height: 72px; border-radius: 50%; object-fit: cover; background: rgba(240, 201, 122, 0.06); border: 2px solid rgba(240, 201, 122, 0.3); flex-shrink: 0;" %>
          <%# Prénom en évidence %>
          <span style="color: #fdf6e3; font-size: 1rem; font-weight: 600; line-height: 1.2; text-align: center;">
            <%= child.name %>
          </span>
          <%# Âge en sous-titre discret %>
          <span style="color: rgba(212, 207, 196, 0.6); font-size: 0.82rem;">
            <%= t("dashboard.age", age: child.age) %>
          </span>
        <% end %>
      <% end %>

      <%# Carte "Ajouter un héros" — même gabarit, bordure pointillée pour la distinguer %>
      <%= link_to new_child_path,
            style: "display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.6rem; width: 150px; padding: 1.4rem 1rem 1.2rem; background: transparent; border: 1px dashed rgba(240, 201, 122, 0.35); border-radius: 18px; text-decoration: none; color: #f0c97a; transition: border-color 0.2s ease, background 0.2s ease;" do %>
        <%# Cercle avec un "+" — fait écho à l'avatar rond des autres cartes %>
        <span style="display: flex; align-items: center; justify-content: center; width: 72px; height: 72px; border-radius: 50%; border: 2px dashed rgba(240, 201, 122, 0.4); font-size: 1.8rem; line-height: 1; color: #f0c97a;">+</span>
        <span style="font-size: 0.9rem; font-weight: 500; text-align: center;">
          <%# Le "+" est déjà affiché dans le cercle ci-dessus → on retire celui en %>
          <%# tête du libellé traduit (toutes les locales commencent par "+ ") %>
          <%= t("dashboard.add_hero").sub(/\A\+\s*/, "") %>
        </span>
      <% end %>
    </div>

  </section>
<% end %>

<%# Espace final %>
<div style="height: 80px;"></div>

<% end %>
<%# Fin du branchement onboarding / dashboard normal %>

<%# ============================================================ %>
<%# JS — Étoiles + Trail doré (même logique que la landing) %>
<%# ============================================================ %>
<script nonce="<%= content_security_policy_nonce %>">
// turbo:load se déclenche à chaque navigation Turbo (et au premier chargement)
// contrairement à window.load qui ne s'exécute qu'une seule fois
document.addEventListener('turbo:load', function() {
  // Annule les boucles d'animation précédentes si on revient sur la page
  // Sans ça, chaque retour sur le dashboard crée une nouvelle boucle en doublon
  if (window._dbAnimFrame) cancelAnimationFrame(window._dbAnimFrame);
  if (window._dbTrailFrame) cancelAnimationFrame(window._dbTrailFrame);

  try {

    // ============================================================
    // Étoiles animées — canvas fixe en arrière-plan
    // ============================================================
    const canvas = document.getElementById('db-stars');
    const ctx    = canvas ? canvas.getContext('2d') : null;
    let stars    = [];

    if (canvas && ctx) {
      function resizeStars() {
        const dpr    = window.devicePixelRatio || 1;
        canvas.width  = window.innerWidth  * dpr;
        canvas.height = window.innerHeight * dpr;
      }

      function createStars() {
        const dpr = window.devicePixelRatio || 1;
        stars = [];
        for (let i = 0; i < 250; i++) {
          stars.push({
            x:     Math.random() * canvas.width,
            y:     Math.random() * canvas.height,
            r:     (Math.random() * 1.3 + 0.6) * dpr,
            speed: Math.random() * 0.004 + 0.001,
            phase: Math.random() * Math.PI * 2
          });
        }
      }

      // Scintillement doré — même couleur que la landing (240, 201, 122)
      function drawStars(t) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        stars.forEach(s => {
          const alpha = 0.2 + 0.5 * Math.sin(s.phase + t * s.speed);
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(240, 201, 122, ${alpha})`;
          ctx.fill();
        });
        // Stocke l'ID pour pouvoir l'annuler au prochain turbo:load
        window._dbAnimFrame = requestAnimationFrame(drawStars);
      }

      resizeStars(); createStars(); window._dbAnimFrame = requestAnimationFrame(drawStars);

      // Resize — ignore les scrolls mobile (seul la largeur compte)
      let lastW = window.innerWidth, rTimer;
      window.addEventListener('resize', () => {
        clearTimeout(rTimer);
        rTimer = setTimeout(() => {
          if (Math.abs(window.innerWidth - lastW) > 10) {
            lastW = window.innerWidth; resizeStars(); createStars();
          }
        }, 250);
      });
    }

    // ============================================================
    // Trail doré — sillage qui suit le curseur et se rétracte à l'arrêt
    // Chaque particule a une durée de vie (life) qui décroît à chaque frame
    // Quand la souris s'arrête, les particules s'effacent naturellement
    // ============================================================
    const trail    = document.getElementById('db-trail');
    const trailCtx = trail ? trail.getContext('2d') : null;
    let particles  = [];
    let mx = 0, my = 0;

    if (trail && trailCtx) {
      function resizeTrail() {
        trail.width  = window.innerWidth;
        trail.height = window.innerHeight;
      }
      resizeTrail();
      window.addEventListener('resize', resizeTrail);

      // Ajoute une particule à chaque mouvement de souris
      // life : durée de vie de 1.0 → 0, décrémentée à chaque frame dans drawTrail
      document.addEventListener('mousemove', e => {
        mx = e.clientX; my = e.clientY;
        particles.push({
          x: mx, y: my,
          r: Math.random() * 2 + 0.5,
          life: 1.0  // Vie pleine à la création — s'estompe jusqu'à 0
        });
      });

      // Dessine le trail — chaque particule vieillit et disparaît
      function drawTrail() {
        trailCtx.clearRect(0, 0, trail.width, trail.height);

        // Diminue la vie de chaque particule et supprime celles épuisées
        // 0.03 = vitesse de décroissance (1/0.03 ≈ 33 frames ≈ 0.55s à 60fps)
        particles = particles.filter(function(p) {
          p.life -= 0.03;
          return p.life > 0;
        });

        particles.forEach(function(p, i) {
          // progress : position dans la queue (0 = plus vieille, 1 = plus récente)
          const progress = i / Math.max(particles.length, 1);
          // Opacité = vie restante × position dans la queue × intensité max
          const alpha = p.life * progress * 0.7;
          trailCtx.beginPath();
          trailCtx.arc(p.x, p.y, p.r * progress, 0, Math.PI * 2);
          trailCtx.fillStyle = 'rgba(240, 201, 122, ' + alpha + ')';
          trailCtx.fill();
        });

        window._dbTrailFrame = requestAnimationFrame(drawTrail);
      }
      window._dbTrailFrame = requestAnimationFrame(drawTrail);
    }

    // ============================================================
    // Dessin de la vraie phase lunaire sur canvas
    // ============================================================
    // L'algorithme utilise deux arcs + une ellipse (le terminateur)
    // pour reproduire fidèlement la forme de la lune vue de France
    // (hémisphère nord : croissant éclairé à droite en phase croissante)
    const moonCanvas = document.getElementById('db-moon-canvas');
    if (moonCanvas) {
      const phase = parseFloat(moonCanvas.dataset.phase || '0.5');
      drawMoonPhase(moonCanvas, phase);
    }

    // ============================================================
    // Split-text — révélation mot par mot pour les titres de section
    // Inspiré de GSAP SplitText mais en pur JS natif
    // Technique : chaque mot est enveloppé dans un .db-word-wrap (overflow:hidden)
    // avec un .db-word-inner qui part du bas et remonte quand le titre est visible
    // ============================================================
    document.querySelectorAll('.db-section-title').forEach(function(title) {
      // Découpe le texte en mots, en préservant les espaces entre eux
      const words = title.textContent.trim().split(/\s+/);

      // Reconstruit le HTML avec les spans de masque et d'animation
      // --wi : index du mot, utilisé par CSS pour calculer le délai en cascade
      title.innerHTML = words.map(function(word, i) {
        return '<span class="db-word-wrap">' +
                 '<span class="db-word-inner" style="--wi:' + i + '">' + word + '</span>' +
               '</span>';
      }).join(' '); // L'espace entre les spans assure les espaces entre les mots

      // Marque le titre comme "splité" — requis par le sélecteur CSS
      title.classList.add('db-title-split');
    });

    // Intersection Observer dédié aux titres de section
    // Rejoue à chaque fois que le titre entre / quitte le viewport
    const titleObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          // Entre dans le viewport — lance l'animation mot par mot
          entry.target.classList.add('db-title-revealed');
        } else {
          // Sort du viewport (remontée) — réinitialise pour le prochain passage
          entry.target.classList.remove('db-title-revealed');
        }
      });
    }, { threshold: 0.4, rootMargin: '0px 0px -30px 0px' });

    document.querySelectorAll('.db-section-title').forEach(function(title) {
      titleObserver.observe(title);
    });

    // ============================================================
    // Scroll Reveal — Intersection Observer
    // Observe chaque élément [data-reveal] et lui ajoute .revealed
    // quand il entre dans le viewport (15% de visibilité suffit)
    // Une fois révélé, l'élément n'est plus observé (animation unique)
    // ============================================================
    const revealEls = document.querySelectorAll('[data-reveal]');
    if (revealEls.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            // Entre dans le viewport — déclenche l'animation
            entry.target.classList.add('revealed');
          } else {
            // Sort du viewport (remontée) — réinitialise pour rejouer au prochain passage
            entry.target.classList.remove('revealed');
          }
        });
      }, {
        threshold: 0.12,
        rootMargin: '0px 0px -40px 0px'
      });

      revealEls.forEach(function(el) { observer.observe(el); });
    }

  } catch(e) {
    console.error('Dashboard FX error:', e);
  }
});

// ============================================================
// drawMoonPhase — dessine la phase lunaire sur un canvas
// phase : 0.0 = nouvelle lune, 0.5 = pleine lune, 1.0 = nouvelle lune
// Vue depuis l'hémisphère nord (France) : croissant éclairé à droite en phase croissante
// ============================================================
function drawMoonPhase(canvas, phase) {
  const dpr  = window.devicePixelRatio || 1;
  const size = canvas.getBoundingClientRect().width || 80;

  // Adapte la résolution pour les écrans Retina (Mac → devicePixelRatio = 2)
  canvas.width  = size * dpr;
  canvas.height = size * dpr;
  canvas.style.width  = size + 'px';
  canvas.style.height = size + 'px';

  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr); // Toutes les coords en CSS pixels

  const r  = size / 2;
  const cx = r;
  const cy = r;

  // Palette — identique à la landing
  const litColor  = '#fff9e6'; // Crème — face éclairée
  const darkColor = '#0b0e1a'; // Nuit profonde — face sombre

  // Fraction d'illumination visible : 0 = nouvelle lune, 1 = pleine lune
  const illum = (1 - Math.cos(2 * Math.PI * phase)) / 2;

  // ── 1. Disque sombre de base ────────────────────────────────────────
  ctx.beginPath();
  ctx.arc(cx, cy, r - 1, 0, 2 * Math.PI);
  ctx.fillStyle = darkColor;
  ctx.fill();

  // Nouvelle lune = disque noir avec halo très léger
  if (phase < 0.01 || phase > 0.99) {
    addMoonGlow(ctx, cx, cy, r, 0.05);
    return;
  }

  // ── 2. Zone éclairée ────────────────────────────────────────────────
  // Technique : demi-cercle (côté éclairé) + ellipse terminateur
  // Hémisphère nord (France) :
  //   Lune croissante  (0 → 0.5) : lumière à droite
  //   Lune décroissante (0.5 → 1) : lumière à gauche
  const isWaxing = phase < 0.5;

  ctx.save();
  ctx.beginPath();

  if (isWaxing) {
    // Demi-cercle droit (arc du bas vers le haut en passant par la droite)
    ctx.arc(cx, cy, r - 1, Math.PI / 2, -Math.PI / 2, false);
    // Terminateur : ellipse dont le rayon X varie de r (0°) à 0 (90°) à -r (180°)
    const tx = r * Math.cos(phase * 2 * Math.PI);
    if (tx >= 0) {
      // Croissant (0→0.25) : terminateur courbe vers la droite, réduit la zone éclairée
      ctx.ellipse(cx, cy, tx, r - 1, 0, Math.PI / 2, -Math.PI / 2, false);
    } else {
      // Gibbeuse croissante (0.25→0.5) : terminateur courbe vers la gauche, agrandit
      ctx.ellipse(cx, cy, Math.abs(tx), r - 1, 0, -Math.PI / 2, Math.PI / 2, false);
    }
  } else {
    // Demi-cercle gauche (arc du bas vers le haut en passant par la gauche)
    ctx.arc(cx, cy, r - 1, -Math.PI / 2, Math.PI / 2, false);
    const tx = r * Math.cos(phase * 2 * Math.PI);
    if (tx <= 0) {
      // Gibbeuse décroissante (0.5→0.75)
      ctx.ellipse(cx, cy, Math.abs(tx), r - 1, 0, Math.PI / 2, -Math.PI / 2, false);
    } else {
      // Croissant décroissant (0.75→1)
      ctx.ellipse(cx, cy, tx, r - 1, 0, -Math.PI / 2, Math.PI / 2, false);
    }
  }

  ctx.closePath();
  ctx.fillStyle = litColor;
  ctx.fill();
  ctx.restore();

  // ── 3. Texture de volume ─────────────────────────────────────────────
  // Gradient interne qui donne du relief à la face éclairée
  const volGrad = ctx.createRadialGradient(
    cx - r * 0.2, cy - r * 0.2, r * 0.05,
    cx, cy, r
  );
  volGrad.addColorStop(0, 'rgba(255,255,255,0.18)');
  volGrad.addColorStop(1, 'rgba(200,148,58,0.22)'); // Bord doré chaud

  ctx.save();
  ctx.globalCompositeOperation = 'source-atop'; // S'applique uniquement sur le dessin existant
  ctx.beginPath();
  ctx.arc(cx, cy, r - 1, 0, 2 * Math.PI);
  ctx.fillStyle = volGrad;
  ctx.fill();
  ctx.restore();

  // ── 4. Halo extérieur — proportionnel à l'illumination ───────────────
  addMoonGlow(ctx, cx, cy, r, illum);
}

// Halo doré autour de la lune — s'intensifie à la pleine lune
function addMoonGlow(ctx, cx, cy, r, intensity) {
  const g = ctx.createRadialGradient(cx, cy, r * 0.8, cx, cy, r * 2.4);
  g.addColorStop(0,   `rgba(240,201,122,${(intensity * 0.45).toFixed(3)})`);
  g.addColorStop(0.4, `rgba(240,201,122,${(intensity * 0.15).toFixed(3)})`);
  g.addColorStop(1,   'rgba(240,201,122,0)');
  ctx.beginPath();
  ctx.arc(cx, cy, r * 2.4, 0, 2 * Math.PI);
  ctx.fillStyle = g;
  ctx.fill();
}
</script>

