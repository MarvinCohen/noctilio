<%# ============================================================ %>
<%# JS — Étoiles + Trail doré (même logique que la landing) %>
<%# ============================================================ %>
<script nonce="<%= content_security_policy_nonce %>">
// turbo:load se déclenche à chaque navigation Turbo (et au premier chargement)
// contrairement à window.load qui ne s'exécute qu'une seule fois
document.addEventListener('turbo:load', function() {
  // Annule les boucles d'animation précédentes si on revient sur la page
  // Sans ça, chaque retour sur le dashboard crée une nouvelle boucle en doublon
  if (window._dbAnimFrame) cancelAnimationFrame(window._dbAnimFrame);
  if (window._dbTrailFrame) cancelAnimationFrame(window._dbTrailFrame);

  try {

    // ============================================================
    // Étoiles animées — canvas fixe en arrière-plan
    // ============================================================
    const canvas = document.getElementById('db-stars');
    const ctx    = canvas ? canvas.getContext('2d') : null;
    let stars    = [];

    if (canvas && ctx) {
      function resizeStars() {
        const dpr    = window.devicePixelRatio || 1;
        canvas.width  = window.innerWidth  * dpr;
        canvas.height = window.innerHeight * dpr;
      }

      function createStars() {
        const dpr = window.devicePixelRatio || 1;
        stars = [];
        for (let i = 0; i < 250; i++) {
          stars.push({
            x:     Math.random() * canvas.width,
            y:     Math.random() * canvas.height,
            r:     (Math.random() * 1.3 + 0.6) * dpr,
            speed: Math.random() * 0.004 + 0.001,
            phase: Math.random() * Math.PI * 2
          });
        }
      }

      // Scintillement doré — même couleur que la landing (240, 201, 122)
      function drawStars(t) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        stars.forEach(s => {
          const alpha = 0.2 + 0.5 * Math.sin(s.phase + t * s.speed);
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(240, 201, 122, ${alpha})`;
          ctx.fill();
        });
        // Stocke l'ID pour pouvoir l'annuler au prochain turbo:load
        window._dbAnimFrame = requestAnimationFrame(drawStars);
      }

      resizeStars(); createStars(); window._dbAnimFrame = requestAnimationFrame(drawStars);

      // Resize — ignore les scrolls mobile (seul la largeur compte)
      let lastW = window.innerWidth, rTimer;
      window.addEventListener('resize', () => {
        clearTimeout(rTimer);
        rTimer = setTimeout(() => {
          if (Math.abs(window.innerWidth - lastW) > 10) {
            lastW = window.innerWidth; resizeStars(); createStars();
          }
        }, 250);
      });
    }

    // ============================================================
    // Trail doré — sillage qui suit le curseur et se rétracte à l'arrêt
    // Chaque particule a une durée de vie (life) qui décroît à chaque frame
    // Quand la souris s'arrête, les particules s'effacent naturellement
    // ============================================================
    const trail    = document.getElementById('db-trail');
    const trailCtx = trail ? trail.getContext('2d') : null;
    let particles  = [];
    let mx = 0, my = 0;

    if (trail && trailCtx) {
      function resizeTrail() {
        trail.width  = window.innerWidth;
        trail.height = window.innerHeight;
      }
      resizeTrail();
      window.addEventListener('resize', resizeTrail);

      // Ajoute une particule à chaque mouvement de souris
      // life : durée de vie de 1.0 → 0, décrémentée à chaque frame dans drawTrail
      document.addEventListener('mousemove', e => {
        mx = e.clientX; my = e.clientY;
        particles.push({
          x: mx, y: my,
          r: Math.random() * 2 + 0.5,
          life: 1.0  // Vie pleine à la création — s'estompe jusqu'à 0
        });
      });

      // Dessine le trail — chaque particule vieillit et disparaît
      function drawTrail() {
        trailCtx.clearRect(0, 0, trail.width, trail.height);

        // Diminue la vie de chaque particule et supprime celles épuisées
        // 0.03 = vitesse de décroissance (1/0.03 ≈ 33 frames ≈ 0.55s à 60fps)
        particles = particles.filter(function(p) {
          p.life -= 0.03;
          return p.life > 0;
        });

        particles.forEach(function(p, i) {
          // progress : position dans la queue (0 = plus vieille, 1 = plus récente)
          const progress = i / Math.max(particles.length, 1);
          // Opacité = vie restante × position dans la queue × intensité max
          const alpha = p.life * progress * 0.7;
          trailCtx.beginPath();
          trailCtx.arc(p.x, p.y, p.r * progress, 0, Math.PI * 2);
          trailCtx.fillStyle = 'rgba(240, 201, 122, ' + alpha + ')';
          trailCtx.fill();
        });

        window._dbTrailFrame = requestAnimationFrame(drawTrail);
      }
      window._dbTrailFrame = requestAnimationFrame(drawTrail);
    }

    // ============================================================
    // Dessin de la vraie phase lunaire sur canvas
    // ============================================================
    // L'algorithme utilise deux arcs + une ellipse (le terminateur)
    // pour reproduire fidèlement la forme de la lune vue de France
    // (hémisphère nord : croissant éclairé à droite en phase croissante)
    const moonCanvas = document.getElementById('db-moon-canvas');
    if (moonCanvas) {
      const phase = parseFloat(moonCanvas.dataset.phase || '0.5');
      drawMoonPhase(moonCanvas, phase);
    }

    // ============================================================
    // Split-text — révélation mot par mot pour les titres de section
    // Inspiré de GSAP SplitText mais en pur JS natif
    // Technique : chaque mot est enveloppé dans un .db-word-wrap (overflow:hidden)
    // avec un .db-word-inner qui part du bas et remonte quand le titre est visible
    // ============================================================
    document.querySelectorAll('.db-section-title').forEach(function(title) {
      // Découpe le texte en mots, en préservant les espaces entre eux
      const words = title.textContent.trim().split(/\s+/);

      // Reconstruit le HTML avec les spans de masque et d'animation
      // --wi : index du mot, utilisé par CSS pour calculer le délai en cascade
      title.innerHTML = words.map(function(word, i) {
        return '<span class="db-word-wrap">' +
                 '<span class="db-word-inner" style="--wi:' + i + '">' + word + '</span>' +
               '</span>';
      }).join(' '); // L'espace entre les spans assure les espaces entre les mots

      // Marque le titre comme "splité" — requis par le sélecteur CSS
      title.classList.add('db-title-split');
    });

    // Intersection Observer dédié aux titres de section
    // Rejoue à chaque fois que le titre entre / quitte le viewport
    const titleObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          // Entre dans le viewport — lance l'animation mot par mot
          entry.target.classList.add('db-title-revealed');
        } else {
          // Sort du viewport (remontée) — réinitialise pour le prochain passage
          entry.target.classList.remove('db-title-revealed');
        }
      });
    }, { threshold: 0.4, rootMargin: '0px 0px -30px 0px' });

    document.querySelectorAll('.db-section-title').forEach(function(title) {
      titleObserver.observe(title);
    });

    // ============================================================
    // Scroll Reveal — Intersection Observer
    // Observe chaque élément [data-reveal] et lui ajoute .revealed
    // quand il entre dans le viewport (15% de visibilité suffit)
    // Une fois révélé, l'élément n'est plus observé (animation unique)
    // ============================================================
    const revealEls = document.querySelectorAll('[data-reveal]');
    if (revealEls.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            // Entre dans le viewport — déclenche l'animation
            entry.target.classList.add('revealed');
          } else {
            // Sort du viewport (remontée) — réinitialise pour rejouer au prochain passage
            entry.target.classList.remove('revealed');
          }
        });
      }, {
        threshold: 0.12,
        rootMargin: '0px 0px -40px 0px'
      });

      revealEls.forEach(function(el) { observer.observe(el); });
    }

  } catch(e) {
    console.error('Dashboard FX error:', e);
  }
});

// ============================================================
// drawMoonPhase — dessine la phase lunaire sur un canvas
// phase : 0.0 = nouvelle lune, 0.5 = pleine lune, 1.0 = nouvelle lune
// Vue depuis l'hémisphère nord (France) : croissant éclairé à droite en phase croissante
// ============================================================
function drawMoonPhase(canvas, phase) {
  const dpr  = window.devicePixelRatio || 1;
  const size = canvas.getBoundingClientRect().width || 80;

  // Adapte la résolution pour les écrans Retina (Mac → devicePixelRatio = 2)
  canvas.width  = size * dpr;
  canvas.height = size * dpr;
  canvas.style.width  = size + 'px';
  canvas.style.height = size + 'px';

  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr); // Toutes les coords en CSS pixels

  const r  = size / 2;
  const cx = r;
  const cy = r;

  // Palette — identique à la landing
  const litColor  = '#fff9e6'; // Crème — face éclairée
  const darkColor = '#0b0e1a'; // Nuit profonde — face sombre

  // Fraction d'illumination visible : 0 = nouvelle lune, 1 = pleine lune
  const illum = (1 - Math.cos(2 * Math.PI * phase)) / 2;

  // ── 1. Disque sombre de base ────────────────────────────────────────
  ctx.beginPath();
  ctx.arc(cx, cy, r - 1, 0, 2 * Math.PI);
  ctx.fillStyle = darkColor;
  ctx.fill();

  // Nouvelle lune = disque noir avec halo très léger
  if (phase < 0.01 || phase > 0.99) {
    addMoonGlow(ctx, cx, cy, r, 0.05);
    return;
  }

  // ── 2. Zone éclairée ────────────────────────────────────────────────
  // Technique : demi-cercle (côté éclairé) + ellipse terminateur
  // Hémisphère nord (France) :
  //   Lune croissante  (0 → 0.5) : lumière à droite
  //   Lune décroissante (0.5 → 1) : lumière à gauche
  const isWaxing = phase < 0.5;

  ctx.save();
  ctx.beginPath();

  if (isWaxing) {
    // Demi-cercle droit (arc du bas vers le haut en passant par la droite)
    ctx.arc(cx, cy, r - 1, Math.PI / 2, -Math.PI / 2, false);
    // Terminateur : ellipse dont le rayon X varie de r (0°) à 0 (90°) à -r (180°)
    const tx = r * Math.cos(phase * 2 * Math.PI);
    if (tx >= 0) {
      // Croissant (0→0.25) : terminateur courbe vers la droite, réduit la zone éclairée
      ctx.ellipse(cx, cy, tx, r - 1, 0, Math.PI / 2, -Math.PI / 2, false);
    } else {
      // Gibbeuse croissante (0.25→0.5) : terminateur courbe vers la gauche, agrandit
      ctx.ellipse(cx, cy, Math.abs(tx), r - 1, 0, -Math.PI / 2, Math.PI / 2, false);
    }
  } else {
    // Demi-cercle gauche (arc du bas vers le haut en passant par la gauche)
    ctx.arc(cx, cy, r - 1, -Math.PI / 2, Math.PI / 2, false);
    const tx = r * Math.cos(phase * 2 * Math.PI);
    if (tx <= 0) {
      // Gibbeuse décroissante (0.5→0.75)
      ctx.ellipse(cx, cy, Math.abs(tx), r - 1, 0, Math.PI / 2, -Math.PI / 2, false);
    } else {
      // Croissant décroissant (0.75→1)
      ctx.ellipse(cx, cy, tx, r - 1, 0, -Math.PI / 2, Math.PI / 2, false);
    }
  }

  ctx.closePath();
  ctx.fillStyle = litColor;
  ctx.fill();
  ctx.restore();

  // ── 3. Texture de volume ─────────────────────────────────────────────
  // Gradient interne qui donne du relief à la face éclairée
  const volGrad = ctx.createRadialGradient(
    cx - r * 0.2, cy - r * 0.2, r * 0.05,
    cx, cy, r
  );
  volGrad.addColorStop(0, 'rgba(255,255,255,0.18)');
  volGrad.addColorStop(1, 'rgba(200,148,58,0.22)'); // Bord doré chaud

  ctx.save();
  ctx.globalCompositeOperation = 'source-atop'; // S'applique uniquement sur le dessin existant
  ctx.beginPath();
  ctx.arc(cx, cy, r - 1, 0, 2 * Math.PI);
  ctx.fillStyle = volGrad;
  ctx.fill();
  ctx.restore();

  // ── 4. Halo extérieur — proportionnel à l'illumination ───────────────
  addMoonGlow(ctx, cx, cy, r, illum);
}

// Halo doré autour de la lune — s'intensifie à la pleine lune
function addMoonGlow(ctx, cx, cy, r, intensity) {
  const g = ctx.createRadialGradient(cx, cy, r * 0.8, cx, cy, r * 2.4);
  g.addColorStop(0,   `rgba(240,201,122,${(intensity * 0.45).toFixed(3)})`);
  g.addColorStop(0.4, `rgba(240,201,122,${(intensity * 0.15).toFixed(3)})`);
  g.addColorStop(1,   'rgba(240,201,122,0)');
  ctx.beginPath();
  ctx.arc(cx, cy, r * 2.4, 0, 2 * Math.PI);
  ctx.fillStyle = g;
  ctx.fill();
}
</script>
