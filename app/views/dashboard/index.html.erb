<%# ============================================================ %>
<%# Dashboard — ambiance landing page %>
<%# Contenu flottant dans le vide cosmique, pas de cartes conventionnelles %>
<%# Étoiles, lune, typographie éditoriale Cormorant Garamond %>
<%# ============================================================ %>

<%# full_bleed : le dashboard gère son propre fond (pas de carte blanche du layout) %>
<% content_for :full_bleed, true %>

<%# ---------------------------------------------------------------- %>
<%# Textures et effets d'arrière-plan %>
<%# ---------------------------------------------------------------- %>

<%# Texture de bruit — même que la landing, donne le côté "filmic" premium %>
<div class="db-noise"></div>

<%# Canvas étoiles animées — même logique que la landing page %>
<canvas id="db-stars" class="db-stars-canvas"></canvas>

<%# Canvas sillage doré — trail qui suit le curseur comme sur la landing %>
<canvas id="db-trail" class="db-trail-canvas"></canvas>

<%# ---------------------------------------------------------------- %>
<%# HERO — flotte dans le vide, pas de carte %>
<%# ---------------------------------------------------------------- %>
<section class="db-hero">

  <%# Lune réelle — canvas dessiné en JS selon la phase lunaire du jour %>
  <%# data-phase transmis depuis le controller (0.0 = nouvelle, 0.5 = pleine) %>
  <canvas id="db-moon-canvas"
          class="db-hero-moon"
          data-phase="<%= @moon_phase %>"
          width="160" height="160"
          aria-label="Phase de la lune ce soir"></canvas>

  <%# Nébuleuse — halo diffus derrière le titre %>
  <div class="db-hero-nebula"></div>

  <%# Signature typographique centrée — "Noctilio" + chouette en haut du hero %>
  <%# aria-hidden : élément purement décoratif %>
  <div class="db-noctilio-display" aria-hidden="true">
    <%# Mascotte hibou — remplace l'emoji 🦉 %>
    <%= image_tag "mascot.svg", alt: "", class: "db-owl-img", width: 110, height: 110,
          style: "object-fit: contain;" %>
    <div class="db-owl-perch"></div>
    <p class="db-noctilio-word">Noctilio</p>
    <div class="db-noctilio-sparks">
      <span class="db-spark db-spark--1">✦</span>
      <span class="db-spark db-spark--2">✦</span>
      <span class="db-spark db-spark--3">✦</span>
    </div>
  </div>

  <%# Contenu centré en dessous du logo %>
  <div class="db-hero-text">

    <%# Eyebrow — petit texte doré espacé, style landing %>
    <p class="db-eyebrow">✦ Ce soir, l'aventure commence ✦</p>

    <%# Titre principal — Cormorant Garamond, énorme, aérien %>
    <h1 class="db-hero-title">
      Quelle magie allez-vous<br>
      <em>créer</em> ce soir&nbsp;?
    </h1>

    <%# Description %>
    <p class="db-hero-desc">
      Transformez vos rêves en aventures illustrées grâce à notre créateur d'histoires IA.
    </p>

    <%# CTA — pill doré, même style que landing %>
    <%= link_to new_story_path, class: "db-cta-btn" do %>
      <span class="db-cta-star">✦</span> Créer mon histoire
    <% end %>

    <%# Limite gratuite — discrète %>
    <% unless current_user.premium? %>
      <p class="db-limit-text">
        <%= @stories_this_month %>/3 histoires ce mois ·
        <%= link_to "Passer en Premium →", subscription_path, class: "db-limit-link" %>
      </p>
    <% end %>

  </div>

  <%# Alerte histoires en cours — discrète, sous le hero %>
  <% if @pending_stories.any? %>
    <div class="db-generating-alert">
      <span class="db-generating-dot"></span>
      <%= pluralize(@pending_stories.count, "histoire est", "histoires sont") %> en cours de génération…
      <%= link_to "Voir →", story_path(@pending_stories.first), class: "db-generating-link" %>
    </div>
  <% end %>

</section>

<%# ---------------------------------------------------------------- %>
<%# Séparateur vertical doré — inspiré de la landing %>
<%# ---------------------------------------------------------------- %>
<div class="db-divider"></div>

<%# ================================================================ %>
<%# COMMENT ÇA MARCHE — 3 étapes numérotées %>
<%# ================================================================ %>
<section class="db-section db-section--centered">

  <div class="db-section-head db-section-head--centered" data-reveal="up">
    <p class="db-eyebrow db-eyebrow--small">Simple comme bonjour</p>
    <h2 class="db-section-title">Comment ça marche</h2>
    <p class="db-section-subtitle">Trois étapes vers une histoire magique</p>
  </div>

  <div class="db-steps-grid">

    <%# Étape 1 — apparaît en premier %>
    <div class="db-step-card" data-reveal="up" style="--reveal-delay: 100ms">
      <div class="db-step-number">1</div>
      <div class="db-step-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </div>
      <h3 class="db-step-title">Créer le profil</h3>
      <p class="db-step-desc">Prénom, âge, personnalité et centres d'intérêt de votre enfant.</p>
    </div>

    <%# Connecteur entre les étapes %>
    <div class="db-step-connector" aria-hidden="true">✦</div>

    <%# Étape 2 — décalée de 200ms %>
    <div class="db-step-card" data-reveal="up" style="--reveal-delay: 250ms">
      <div class="db-step-number">2</div>
      <div class="db-step-icon">
        <%# Sliders — personnalisation de l'histoire %>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
          <circle cx="8" cy="6" r="2" fill="currentColor" stroke="none"/>
          <circle cx="16" cy="12" r="2" fill="currentColor" stroke="none"/>
          <circle cx="10" cy="18" r="2" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <h3 class="db-step-title">Choisir l'histoire</h3>
      <p class="db-step-desc">Univers, valeur éducative, durée et mode interactif.</p>
    </div>

    <div class="db-step-connector" aria-hidden="true">✦</div>

    <%# Étape 3 — décalée de 400ms %>
    <div class="db-step-card" data-reveal="up" style="--reveal-delay: 400ms">
      <div class="db-step-number">3</div>
      <div class="db-step-icon">
        <%# Étoiles — la magie opère %>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
        </svg>
      </div>
      <h3 class="db-step-title">La magie opère</h3>
      <p class="db-step-desc">L'IA génère l'histoire et l'illustration en quelques secondes.</p>
    </div>

  </div>

</section>

<div class="db-divider"></div>

