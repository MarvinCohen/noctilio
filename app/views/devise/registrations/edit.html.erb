<%# ============================================================ %>
<%# Page "Mon compte" — modification du profil utilisateur %>
<%# DA cosmique : cartes dark, inputs sombres, Cormorant Garamond %>
<%# ============================================================ %>

<style nonce="<%= content_security_policy_nonce %>">
  /* ── Wrapper de page ── */
  .account-page { padding: 2.5rem 0 4rem; }

  /* ── Titre de page ── */
  .account-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 300;
    color: #fdf6e3;
    margin-bottom: 0.3rem;
    line-height: 1.1;
  }
  .account-subtitle { color: #8a8578; font-size: 0.9rem; margin-bottom: 2rem; }

  /* ── Cartes dark ── */
  .account-card {
    background: #111527;
    border: 1px solid rgba(240, 201, 122, 0.15);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }

  /* Titre de section — Cormorant italic */
  .account-section-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.2rem;
    color: #fdf6e3;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  /* ── Surcharge Simple Form — labels, inputs ── */
  .account-card .form-group { margin-bottom: 1.1rem; }
  .account-card .form-group > label, .account-card label.control-label {
    display: block; color: #8a8578;
    font-size: 0.78rem; font-weight: 500;
    letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.4rem;
  }
  .account-card .form-group input,
  .account-card .form-control {
    display: block; width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(240, 201, 122, 0.2);
    color: #d4cfc4; border-radius: 10px;
    padding: 0.7rem 1rem; font-size: 0.95rem;
    box-sizing: border-box; transition: border-color 0.2s ease;
  }
  .account-card .form-group input:focus, .account-card .form-control:focus {
    border-color: #f0c97a; outline: none;
    box-shadow: 0 0 0 3px rgba(240, 201, 122, 0.08);
  }
  .account-card .form-group input::placeholder { color: rgba(138, 133, 120, 0.6); }
  .account-card .form-text, .account-card .hint { color: #8a8578; font-size: 0.78rem; margin-top: 0.3rem; }
  .account-card .invalid-feedback,
  .account-card .form-group .error { color: rgba(220, 80, 80, 0.9); font-size: 0.85rem; margin-top: 0.3rem; }
  .account-card .help-block { color: rgba(220, 80, 80, 0.85); font-size: 0.78rem; margin-top: 0.25rem; display: block; }

  /* Séparateur de section dans la carte */
  .account-sep {
    border: none;
    border-top: 1px solid rgba(240, 201, 122, 0.08);
    margin: 1.5rem 0;
  }

  /* Note discrète (ex: "laisser vide si...") */
  .account-note { color: #8a8578; font-size: 0.82rem; margin-bottom: 1rem; }

  /* ── Bouton submit — pill doré ── */
  .account-btn-submit {
    display: inline-flex; align-items: center;
    padding: 0.65rem 1.75rem;
    background: #f0c97a; color: #0b0e1a;
    border: none; border-radius: 50px;
    font-weight: 600; font-size: 0.95rem;
    cursor: pointer; transition: opacity 0.2s ease;
  }
  .account-btn-submit:hover { opacity: 0.88; }

  /* ── Zone danger — suppression du compte ── */
  .account-danger-card {
    background: rgba(220, 80, 80, 0.05);
    border: 1px solid rgba(220, 80, 80, 0.2);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .account-danger-title { color: rgba(220, 80, 80, 0.8); font-size: 0.9rem; font-weight: 700; margin-bottom: 0.5rem; }
  .account-danger-note { color: #8a8578; font-size: 0.82rem; margin-bottom: 1rem; }
  .account-btn-danger {
    display: inline-flex; align-items: center;
    padding: 0.45rem 1.1rem;
    background: transparent;
    color: rgba(220, 100, 100, 0.9);
    border: 1px solid rgba(220, 80, 80, 0.4);
    border-radius: 50px; font-size: 0.82rem;
    cursor: pointer; transition: background 0.2s ease;
  }
  .account-btn-danger:hover { background: rgba(220, 80, 80, 0.1); }
  .account-btn-danger[type="submit"] { appearance: none; -webkit-appearance: none; }

  /* Lien retour */
  .account-back-link {
    color: rgba(240, 201, 122, 0.6); text-decoration: none; font-size: 0.88rem;
    transition: color 0.15s ease;
  }
  .account-back-link:hover { color: #f0c97a; text-decoration: none; }
</style>

<div class="container account-page">
  <div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

      <%# Titre de page %>
      <h1 class="account-title">Mon compte</h1>
      <p class="account-subtitle">Gérez vos informations personnelles</p>

      <%# ── Formulaire de modification ── %>
      <div class="account-card">
        <h2 class="account-section-title">Informations personnelles</h2>

        <%= simple_form_for(resource, as: resource_name,
              url: registration_path(resource_name),
              html: { method: :put }) do |f| %>
          <%= f.error_notification %>

          <%# Prénom et nom %>
          <div class="row g-2">
            <div class="col-6">
              <%= f.input :first_name,
                    label: "Prénom",
                    input_html: { autocomplete: "given-name" } %>
            </div>
            <div class="col-6">
              <%= f.input :last_name,
                    label: "Nom",
                    input_html: { autocomplete: "family-name" } %>
            </div>
          </div>

          <%# Email %>
          <%= f.input :email,
                label: "Adresse e-mail",
                required: true,
                input_html: { autocomplete: "email" } %>

          <hr class="account-sep">
          <p class="account-note">Laissez vide si vous ne souhaitez pas changer le mot de passe.</p>

          <%# Nouveau mot de passe %>
          <%= f.input :password,
                label: "Nouveau mot de passe",
                hint: nil,
                required: false,
                input_html: { autocomplete: "new-password" } %>

          <%# Confirmation %>
          <%= f.input :password_confirmation,
                label: "Confirmer le nouveau mot de passe",
                required: false,
                input_html: { autocomplete: "new-password" } %>

          <hr class="account-sep">

          <%# Mot de passe actuel — requis par Devise pour valider les changements %>
          <%= f.input :current_password,
                label: "Mot de passe actuel (requis pour confirmer)",
                required: true,
                input_html: { autocomplete: "current-password" } %>

          <%# Bouton submit — pill doré %>
          <%= f.button :submit, "Mettre à jour mon compte", class: "account-btn-submit" %>

        <% end %>
      </div>

      <%# ── Zone danger — suppression irréversible du compte ── %>
      <div class="account-danger-card">
        <div class="account-danger-title">⚠️ Zone de danger</div>
        <p class="account-danger-note">
          La suppression de votre compte est irréversible. Toutes vos histoires et profils seront supprimés.
        </p>
        <%= button_to "Supprimer mon compte",
              registration_path(resource_name),
              data: { turbo_confirm: "Êtes-vous sûr ? Cette action est irréversible." },
              method: :delete,
              class: "account-btn-danger" %>
      </div>

      <%# Lien retour %>
      <%= link_to "← Retour au dashboard", dashboard_path, class: "account-back-link" %>

    </div>
  </div>
</div>
