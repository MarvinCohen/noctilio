<%# ============================================================ %>
<%# Page de modification du compte utilisateur %>
<%# ============================================================ %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

      <h1 class="fw-bold mb-4">Mon compte</h1>

      <div class="card border-0 shadow-sm p-4 mb-4">
        <h2 class="h5 fw-bold mb-4">Informations personnelles</h2>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          <%= f.error_notification %>

          <%# Prénom et nom %>
          <div class="row g-3 mb-1">
            <div class="col-6">
              <%= f.input :first_name,
                    label: "Prénom",
                    input_html: { autocomplete: "given-name" } %>
            </div>
            <div class="col-6">
              <%= f.input :last_name,
                    label: "Nom",
                    input_html: { autocomplete: "family-name" } %>
            </div>
          </div>

          <%# Email %>
          <%= f.input :email,
                label: "Adresse e-mail",
                required: true,
                input_html: { autocomplete: "email" } %>

          <hr class="my-4">
          <p class="text-muted small mb-3">Laissez vide si vous ne souhaitez pas changer le mot de passe.</p>

          <%# Nouveau mot de passe %>
          <%= f.input :password,
                label: "Nouveau mot de passe",
                hint: nil,
                required: false,
                input_html: { autocomplete: "new-password" } %>

          <%# Confirmation %>
          <%= f.input :password_confirmation,
                label: "Confirmer le nouveau mot de passe",
                required: false,
                input_html: { autocomplete: "new-password" } %>

          <%# Mot de passe actuel — requis pour valider les changements %>
          <%= f.input :current_password,
                label: "Mot de passe actuel (requis pour confirmer)",
                required: true,
                input_html: { autocomplete: "current-password" } %>

          <div class="d-grid mt-3">
            <%= f.button :submit, "Mettre à jour mon compte", class: "btn btn-primary" %>
          </div>

        <% end %>
      </div>

      <%# Zone danger — suppression du compte %>
      <div class="card border-danger border-1 p-4">
        <h2 class="h6 fw-bold text-danger mb-3">Zone de danger</h2>
        <p class="text-muted small mb-3">
          La suppression de votre compte est irréversible. Toutes vos histoires et profils seront supprimés.
        </p>
        <%= button_to "Supprimer mon compte",
              registration_path(resource_name),
              data: { turbo_confirm: "Êtes-vous sûr ? Cette action est irréversible." },
              method: :delete,
              class: "btn btn-outline-danger btn-sm" %>
      </div>

      <div class="mt-3">
        <%= link_to "← Retour au dashboard", dashboard_path, class: "text-muted text-decoration-none" %>
      </div>

    </div>
  </div>
</div>
