<%# ============================================================ %>
<%# Page "Mot de passe oublié" — DA cosmique %>
<%# Card centrée, saisie email, lien de réinitialisation par email %>
<%# ============================================================ %>

<style nonce="<%= content_security_policy_nonce %>">
  .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
  .auth-card { background: #111527; border: 1px solid rgba(240,201,122,0.15); border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 420px; }
  .auth-logo { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem; }
  .auth-logo-icon { font-size: 2rem; line-height: 1; }
  .auth-logo-name { font-family: 'Cormorant Garamond', serif; color: #f0c97a; font-size: 1.5rem; font-weight: 400; letter-spacing: 0.04em; }
  .auth-title { font-family: 'Cormorant Garamond', serif; font-style: italic; color: #fdf6e3; font-size: 2rem; font-weight: 300; text-align: center; margin-bottom: 0.3rem; line-height: 1.2; }
  .auth-subtitle { color: #8a8578; font-size: 0.9rem; text-align: center; margin-bottom: 2rem; }
  .auth-card .form-group { margin-bottom: 1.1rem; }
  .auth-card .form-group > label, .auth-card label.control-label { display: block; color: #8a8578; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .auth-card .form-group input, .auth-card .form-control { display: block; width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(240,201,122,0.2); color: #d4cfc4; border-radius: 10px; padding: 0.75rem 1rem; font-size: 1rem; box-sizing: border-box; transition: border-color 0.2s ease; }
  .auth-card .form-group input:focus, .auth-card .form-control:focus { border-color: #f0c97a; outline: none; box-shadow: 0 0 0 3px rgba(240,201,122,0.1); }
  .auth-card .form-group input::placeholder { color: #8a8578; }
  .auth-btn { display: block; width: 100%; background: #f0c97a; color: #0b0e1a; border-radius: 50px; font-weight: 600; font-size: 1rem; padding: 0.75rem; border: none; cursor: pointer; margin-top: 1.5rem; transition: background 0.2s ease; }
  .auth-btn:hover { background: #e8b95a; }
  .auth-links { margin-top: 1.5rem; text-align: center; color: #8a8578; font-size: 0.88rem; }
  .auth-links a { color: rgba(240,201,122,0.8); text-decoration: none; }
  .auth-links a:hover { color: #f0c97a; }
  .auth-links-divider { display: block; height: 1px; background: rgba(240,201,122,0.1); margin: 1rem 0; }
  .auth-errors { background: rgba(220,80,80,0.08); border: 1px solid rgba(220,80,80,0.3); border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1rem; color: rgba(220,80,80,0.9); font-size: 0.85rem; }
</style>

<div class="auth-page">
  <div class="auth-card">

    <%# Logo %>
    <div class="auth-logo">
      <span class="auth-logo-icon">🌙</span>
      <span class="auth-logo-name">Noctilio</span>
    </div>

    <%# Titre et sous-titre %>
    <h1 class="auth-title">Mot de passe oublié ?</h1>
    <p class="auth-subtitle">Saisis ton email et on t'envoie un lien de réinitialisation.</p>

    <%# Formulaire Devise — envoi du lien de réinitialisation %>
    <%= simple_form_for(resource, as: resource_name,
          url: password_path(resource_name),
          html: { method: :post }) do |f| %>

      <%= f.error_notification message: f.object.errors.full_messages.to_sentence,
            html: { class: "auth-errors" } if f.object.errors.any? %>

      <%# Email %>
      <%= f.input :email,
            label: "Adresse e-mail",
            required: true,
            autofocus: true,
            placeholder: "votre@email.com",
            input_html: { autocomplete: "email" } %>

      <%# Bouton d'envoi — pill doré %>
      <%= f.button :submit, "Envoyer le lien de réinitialisation", class: "auth-btn" %>

    <% end %>

    <%# Liens alternatifs %>
    <div class="auth-links">
      <%= link_to "← Se connecter", new_user_session_path %>
      <span class="auth-links-divider"></span>
      Pas encore de compte ?
      <%= link_to "Créer un compte →", new_user_registration_path %>
    </div>

  </div>
</div>
