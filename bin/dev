#!/usr/bin/env ruby
# bin/dev — lance tous les processus de développement via foreman
#
# Démarre en parallèle :
#   - web    : rails server (port 3000)
#   - worker : solid_queue:start (jobs background — génération histoires + images)
#
# Usage : bin/dev
exec "foreman", "start", "-f", "Procfile.dev", *ARGV
